<main class="main">
    <div style="margin-bottom:32px;">
        <h1 style="font-size:28px;font-weight:800;margin-bottom:4px;">Private Sessions</h1>
        <p style="font-size:14px;color:var(--text-2);">One-on-one help · 100% voluntary</p>
    </div>

    <!-- Toast -->
    <div id="toast" style="display:none;position:fixed;bottom:24px;right:24px;background:var(--indigo);color:#fff;padding:12px 20px;border-radius:var(--radius);font-size:14px;font-weight:600;z-index:9999;box-shadow:0 4px 16px rgba(0,0,0,.15);"></div>

    <!-- Tabs -->
    <div class="tabs">
        <div class="tab active" onclick="showTab('tab-active',this)">
            Active Sessions
            @if (activeSessions.Count > 0)
            {
                <span class="nav-badge" style="background:var(--indigo);color:#fff;padding:2px 6px;border-radius:6px;font-size:11px;margin-left:6px;">@activeSessions.Count</span>
            }
        </div>
        <div class="tab" onclick="showTab('tab-requests',this)">
            Incoming Requests
            @if (incomingRequests.Count > 0)
            {
                <span class="nav-badge" style="background:var(--indigo);color:#fff;padding:2px 6px;border-radius:6px;font-size:11px;margin-left:6px;">@incomingRequests.Count</span>
            }
        </div>
        <div class="tab" onclick="showTab('tab-history',this)">History</div>
    </div>

    <div data-tabs-container>

        <!-- ══ TAB: ACTIVE SESSIONS ══════════════════════════════ -->
        <div id="tab-active" data-tab>
            @if (!activeSessions.Any())
            {
                <div class="card" style="text-align:center;padding:48px;color:var(--text-2);">
                    <div style="font-size:40px;margin-bottom:12px;">💬</div>
                    <div style="font-weight:600;">No active sessions yet</div>
                    <div style="font-size:13px;margin-top:4px;">Accept a request or wait for someone to accept yours.</div>
                </div>
            }
            else
            {
                <div class="chat-wrap">
                    <!-- Sidebar -->
                    <div class="chat-sidebar">
                        <div class="chat-sidebar-header">💬 Active (@activeSessions.Count)</div>
                        <div id="chat-list">
                            @foreach (var s in activeSessions)
                            {
                                var other = s.StudentID == me ? s.Helper : s.Student;
                                var otherName = other?.Name ?? "Unknown";
                                var isOnline = other?.IsOnline ?? false;
                                var lastSeen = other?.LastSeenAt;
                                string lastSeenText = "";
                                if (!isOnline && lastSeen.HasValue) {
                                    var diff = DateTime.UtcNow - lastSeen.Value;
                                    if (diff.TotalMinutes < 60) lastSeenText = $"{(int)diff.TotalMinutes}m ago";
                                    else if (diff.TotalHours < 24) lastSeenText = $"{(int)diff.TotalHours}h ago";
                                    else lastSeenText = lastSeen.Value.ToString("MMM d");
                                }
                                <div class="chat-item" data-session-id="@s.PrivateSessionID"
                                     onclick="openChat(@s.PrivateSessionID, '@otherName', @(s.StudentID == me ? s.HelperID : s.StudentID))"
                                     style="display:flex;gap:12px;padding:12px;border-radius:var(--radius);cursor:pointer;margin-bottom:8px;border:1px solid transparent;">
                                    <div style="position:relative;display:inline-block;flex-shrink:0;">
                                        <div class="av av-sm">
                                            <img src="@AvatarHelper.Url(otherName, 40)" alt="@otherName" />
                                        </div>
                                        @if (isOnline) {
                                            <span style="position:absolute;bottom:0;right:0;width:10px;height:10px;background:#10B981;border:2px solid white;border-radius:50%;"></span>
                                        }
                                    </div>
                                    <div style="flex:1;min-width:0;">
                                        <div style="font-weight:700;font-size:13px;">@(otherName.Split(' ').First())</div>
                                        <div style="font-size:11px;color:@(isOnline ? "#10B981" : "var(--text-3)");">
                                            @(isOnline ? "Online now" : (string.IsNullOrEmpty(lastSeenText) ? "Offline" : $"Last seen {lastSeenText}"))
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>

                    <!-- Chat Main -->
                    <div class="chat-main">
                        <!-- Empty state -->
                        <div id="chat-empty" style="flex:1;display:flex;align-items:center;justify-content:center;color:var(--text-2);flex-direction:column;gap:8px;">
                            <div style="font-size:32px;">👈</div>
                            <div style="font-weight:600;">Select a session to start chatting</div>
                        </div>

                        <!-- Chat panel (hidden until session selected) -->
                        <div id="chat-panel">
                            <div class="chat-panel-header">
                                <div class="av av-sm">
                                    <img id="chat-avatar" src="" alt="" />
                                </div>
                                <div style="flex:1;">
                                    <div id="chat-name" style="font-weight:700;font-size:14px;"></div>
                                    <div style="font-size:11px;color:var(--indigo);">● Online</div>
                                </div>
                                <button class="btn btn-ghost btn-sm" style="color:var(--danger,#e53e3e);" onclick="closeSession()">End Session</button>
                            </div>

                            <!-- Scrollable messages area -->
                            <div id="chat-messages"></div>

                            <!-- Image preview above input -->
                            <div id="chatImagePreview" style="display:none; padding:8px 16px 0;"></div>

                            <div class="chat-input-bar">
                                <label style="cursor:pointer;display:flex;align-items:center;justify-content:center;width:40px;height:40px;border-radius:9px;border:1.5px solid var(--border);color:var(--text-2);transition:all .2s;flex-shrink:0;" title="Attach image">
                                    <i class="ph ph-paperclip" style="font-size:18px;"></i>
                                    <input type="file" id="chatImageInput" accept="image/jpeg,image/png,image/gif,image/webp" style="display:none;" onchange="handleChatImageSelect(this)" />
                                </label>
                                <input id="chat-input" type="text" onkeydown="if(event.key==='Enter')sendMsg()" placeholder="Type your message..." class="form-input" style="flex:1;" />
                                <button class="btn btn-primary" onclick="sendMsg()">Send</button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- ══ TAB: INCOMING REQUESTS ═════════════════════════════ -->
        <div id="tab-requests" data-tab class="hidden">
            @if (!incomingRequests.Any())
            {
                <div class="card" style="text-align:center;padding:48px;color:var(--text-2);">
                    <div style="font-size:40px;margin-bottom:12px;">📭</div>
                    <div style="font-weight:600;">No incoming requests</div>
                </div>
            }
            else
            {
                <div style="display:flex;flex-direction:column;gap:12px;">
                    @foreach (var r in incomingRequests)
                    {
                        var ownerName = r.Owner?.Name ?? "Unknown";
                        var initials = Uri.EscapeDataString(ownerName);
                        <div class="card" id="req-@r.RequestID" style="display:flex;gap:16px;align-items:flex-start;">
                            <div class="av av-lg">
                                <img src="@AvatarHelper.Url(ownerName, 60)" alt="@ownerName" />
                            </div>
                            <div style="flex:1;">
                                <div style="margin-bottom:4px;">
                                    <span style="font-weight:700;">@ownerName</span>
                                    <span class="chip chip-violet" style="margin-left:8px;">@(r.Owner?.Faculty) · @(r.Owner?.YearOfStudy)</span>
                                </div>
                                <p style="font-size:14px;color:var(--text-2);line-height:1.6;">
                                    @r.Description
                                </p>
                                <div style="font-size:12px;color:var(--text-2);margin-top:4px;">
                                    Requested @r.CreatedAt.ToString("MMM dd, yyyy · HH:mm")
                                </div>
                            </div>
                            <div style="display:flex;gap:8px;">
                                <button class="btn btn-primary btn-sm" onclick="acceptRequest(@r.RequestID, this)">Accept</button>
                                <button class="btn btn-ghost btn-sm" style="color:var(--text-2);" onclick="declineRequest(@r.RequestID, this)">Decline</button>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>

        <!-- ══ TAB: HISTORY ══════════════════════════════════════ -->
        <div id="tab-history" data-tab class="hidden">
            @if (!history.Any())
            {
                <div class="card" style="text-align:center;padding:48px;color:var(--text-2);">
                    <div style="font-size:40px;margin-bottom:12px;">🗂️</div>
                    <div style="font-weight:600;">No past sessions</div>
                </div>
            }
            else
            {
                <div style="display:flex;flex-direction:column;gap:12px;">
                    @foreach (var s in history)
                    {
                        var other = s.StudentID == me ? s.Helper : s.Student;
                        var otherName = other?.Name ?? "Unknown";
                        <div class="card" style="display:flex;gap:16px;align-items:center;">
                            <div class="av av-sm">
                                <img src="@AvatarHelper.Url(otherName, 40)" alt="@otherName" />
                            </div>
                            <div style="flex:1;">
                                <div style="font-weight:700;">@otherName</div>
                                <div style="font-size:12px;color:var(--text-2);">@s.CreatedAt.ToString("MMM dd, yyyy")</div>
                            </div>
                            <span class="chip" style="background:#f1f5f9;color:var(--text-2);">Closed</span>
                            <button class="btn btn-ghost btn-sm" style="display:inline-flex;align-items:center;gap:6px;"
                                    onclick="openHistoryChat(@s.PrivateSessionID, '@otherName')">
                                <i class="ph ph-chat-circle-text" style="font-size:15px;"></i> View Chat
                            </button>
                        </div>
                    }
                </div>
            }
        </div>

    </div>
</main>


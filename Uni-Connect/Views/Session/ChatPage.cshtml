    var me = int.Parse(User.FindFirst(ClaimTypes.NameIdentifier)!.Value);
    var meName = User.FindFirst(ClaimTypes.Name)?.Value ?? "Me";

    var activeSessions = ViewBag.ActiveSessions as List<Uni_Connect.Models.PrivateSession> ?? new();
    var incomingRequests = ViewBag.IncomingRequests as List<Uni_Connect.Models.Request> ?? new();
    var history = ViewBag.History as List<Uni_Connect.Models.PrivateSession> ?? new();
}

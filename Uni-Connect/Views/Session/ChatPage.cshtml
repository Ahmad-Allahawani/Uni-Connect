    let pendingImageUrl = null;

    async function handleChatImageSelect(input) {
        const file = input.files[0];
        if (!file) return;
        if (file.size > 5 * 1024 * 1024) { showToast('Image too large (max 5MB)'); return; }

        const preview = document.getElementById('chatImagePreview');
        preview.innerHTML = `<div style="display:inline-flex;align-items:center;gap:8px;background:var(--indigo-light);padding:6px 10px;border-radius:8px;font-size:12px;">
            <img src="${URL.createObjectURL(file)}" style="width:40px;height:40px;object-fit:cover;border-radius:6px;" />
            <span>Uploading…</span>
            <button onclick="clearPendingImage()" style="background:none;border:none;cursor:pointer;color:var(--text-2);font-size:14px;">✕</button>
        </div>`;
        preview.style.display = 'block';

        const token = document.querySelector('#antiforgeryForm input[name="__RequestVerificationToken"]')?.value;
        const formData = new FormData();
        formData.append('file', file);
        try {
            const res = await fetch('/api/messages/upload-image', {
                method: 'POST',
                headers: token ? { 'RequestVerificationToken': token } : {},
                body: formData
            });
            const data = await res.json();
            pendingImageUrl = data.imageUrl;
            preview.querySelector('span').textContent = 'Image ready to send';
        } catch {
            showToast('Image upload failed');
            clearPendingImage();
        }
        input.value = '';
    }

    function clearPendingImage() {
        pendingImageUrl = null;
        const preview = document.getElementById('chatImagePreview');
        if (preview) { preview.innerHTML = ''; preview.style.display = 'none'; }
    }

    function escapeHtml(str) {
        if (!str) return '';

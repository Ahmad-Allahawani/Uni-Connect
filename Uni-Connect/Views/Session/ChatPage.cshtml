    function getToken() {
        var el = document.querySelector('#antiforgeryForm input[name="__RequestVerificationToken"]');
        return el ? el.value : '';
    }

    let _closedSessionId = null;
    let _selectedStar    = 0;

    async function closeSession() {
        if (!currentSessionId) return;
        const res = await fetch('/Session/CloseSession', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
                'RequestVerificationToken': getToken()
            },
            body: 'sessionId=' + encodeURIComponent(currentSessionId)
        });
        if (res.ok) {
            _closedSessionId = currentSessionId;
            showRatingModal();
        } else {
            showToast('Could not close session. Please try again.', 'error');
        }
    }

    function showRatingModal() {
        _selectedStar = 0;
        document.querySelectorAll('#starRow button').forEach(b => b.style.color = '#CBD5E1');
        document.getElementById('submitRatingBtn').disabled = true;
        const m = document.getElementById('ratingModal');
        m.style.display = 'flex';
    }

    function pickStar(n) {
        _selectedStar = n;
        document.querySelectorAll('#starRow button').forEach(b => {
            b.style.color = parseInt(b.dataset.star) <= n ? 'var(--amber)' : '#CBD5E1';
        });
        document.getElementById('submitRatingBtn').disabled = false;
    }

    async function submitRating() {
        if (!_selectedStar || !_closedSessionId) { skipRating(); return; }
        try {
            await fetch('/Session/RateSession', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': getToken()
                },
                body: `sessionId=${_closedSessionId}&rating=${_selectedStar}`
            });
        } catch { /* non-fatal */ }
        skipRating();
    }

    function skipRating() {
        document.getElementById('ratingModal').style.display = 'none';
        showToast('Session ended.');
        setTimeout(() => location.reload(), 800);
    }


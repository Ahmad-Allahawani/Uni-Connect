@model List<Uni_Connect.Models.PrivateSession>
@using System.Security.Claims
@{
    ViewData["Title"] = "Private Sessions";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";

    var me = int.Parse(User.FindFirst(ClaimTypes.NameIdentifier)!.Value);
}

<div style="max-width: 900px; margin: 0 auto; padding: 20px;">
   
    <div style="margin-bottom: 30px;">
        <h1 style="font-size: 32px; font-weight: 800; color: var(--text); margin: 0 0 8px 0;">
            Private Sessions
        </h1>
        <p style="font-size: 15px; color: var(--text-2); margin: 0;">
            One-on-one conversations with students and helpers
        </p>
    </div>

   
    @if (Model != null && Model.Count > 0)
    {
        <div style="display: grid; gap: 16px;">
            @foreach (var session in Model.OrderByDescending(s => s.CreatedAt))
            {
                var isStudent = session.StudentID == me;
                var otherUser = isStudent ? session.Helper : session.Student;
                var lastMessage = session.Messages?.OrderByDescending(m => m.SentAt).FirstOrDefault();
                var chatUrl = Url.Action("ChatPage", "Session");

                <a href="@chatUrl" style="text-decoration: none; display: block;">
                    <div style="background: var(--surface); border: 1.5px solid var(--border); border-radius: 12px; padding: 20px; cursor: pointer; transition: all 0.2s;"
                         onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='0 8px 20px rgba(61,82,160,0.08)'; this.style.borderColor='var(--indigo)'"
                         onmouseout="this.style.transform='none'; this.style.boxShadow='none'; this.style.borderColor='var(--border)'">

                        <div style="display: flex; gap: 16px; align-items: center;">
                           
                            <img src="@AvatarHelper.Url(otherUser?.Name, 56)"
                                 alt="User" style="width: 56px; height: 56px; border-radius: 50%; flex-shrink: 0;" />

                           
                            <div style="flex: 1; min-width: 0;">
                                <h3 style="font-size: 16px; font-weight: 800; color: var(--text); margin: 0 0 4px 0;">
                                    @(otherUser?.Name ?? "Unknown")
                                </h3>
                                <p style="font-size: 13px; color: var(--text-2); margin: 0 0 8px 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                                    @if (lastMessage != null)
                                    {
                                        @(lastMessage.SenderID == me ? "You: " + lastMessage.MessageText : lastMessage.MessageText)
                                    }
                                    else
                                    {
                                        <text>No messages yet — click to start chatting</text>
                                    }
                                </p>
                                <span style="font-size: 12px; color: var(--text-3);">
                                    @session.CreatedAt.ToString("MMM dd, yyyy")
                                </span>
                            </div>

                           
                            <div style="text-align: center; flex-shrink: 0;">
                                <div style="background: var(--indigo); color: white; width: 36px; height: 36px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 13px;">
                                    @(session.Messages?.Count(m => !m.IsDeleted) ?? 0)
                                </div>
                            </div>
                        </div>
                    </div>
                </a>
            }
        </div>
    }
    else
    {
        <div style="text-align: center; padding: 80px 20px; background: white; border-radius: 12px;">
            <i class="ph-duotone ph-chat-dots" style="font-size:48px;color:var(--text-3);margin-bottom:12px;display:block;"></i>
            <p style="font-size: 18px; font-weight: 700; color: var(--text); margin: 0 0 12px 0;">
                No sessions yet
            </p>
            <p style="font-size: 14px; color: var(--text-2); margin: 0 0 30px 0;">
                Start a session by asking a question or helping another student
            </p>
            <a asp-action="CreatePost" class="btn btn-primary">
                <i class="ph-bold ph-pencil" style="font-size:15px;"></i> Ask Question
            </a>
        </div>
    }
</div>

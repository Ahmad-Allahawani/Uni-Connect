@using System.Security.Claims

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - UniConnect</title>
    <link rel="icon" type="image/svg+xml" href="~/images/logo/icon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link href="~/css/design-system.css" rel="stylesheet" />
    <link href="~/css/brand.css" rel="stylesheet" />
    <script src="https://unpkg.com/@@phosphor-icons/web@@2.1.1"></script>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <!-- NAVBAR -->
    <nav class="navbar">
        <div style="display: flex; align-items: center; gap: 16px; flex: 1;">
            <button class="nav-hamburger" id="sidebarToggle" aria-label="Open menu" style="display:none; border:none; background:none; cursor:pointer; padding:6px; border-radius:8px; color:var(--text-2); transition:background .2s;" onmouseover="this.style.background='var(--bg)'" onmouseout="this.style.background='none'">
                <i class="ph-bold ph-list" style="font-size:22px;" aria-hidden="true"></i>
            </button>
            <a asp-controller="Home" asp-action="Index" style="text-decoration:none;">
                <div class="nav-logo">
                    <div class="nav-logo-icon" style="padding:2px;overflow:hidden;background:var(--indigo-light);border:1px solid rgba(61,82,160,0.15);width:38px;height:38px;border-radius:11px;display:flex;align-items:center;justify-content:center;">
                        <img src="/images/logo/icon.svg" width="32" height="32" alt="UniConnect" style="display:block;border-radius:8px;" />
                    </div>
                    <span><span class="logo-uni">Uni</span><span class="logo-conn">Connect</span></span>
                </div>
            </a>
            <form method="get" asp-controller="Search" asp-action="Search" style="position:relative; flex:1; max-width:480px;">
                <input type="text" name="q" class="form-input" placeholder="Search questions... students..."
                       value="@Context.Request.Query["q"]"
                       autocomplete="off"
                       style="padding-right:42px; width:100%;" />
                <button type="submit" style="position:absolute; right:10px; top:50%; transform:translateY(-50%); background:none; border:none; cursor:pointer; color:var(--text-2); display:flex; align-items:center;">
                    <i class="ph-bold ph-magnifying-glass" style="font-size:18px;"></i>
                </button>
            </form>
        </div>
        <!-- University label -->
        <div class="nav-live-info" style="font-size:11px;color:var(--text-2);font-weight:500;display:flex;align-items:center;gap:8px;white-space:nowrap;">
          <span style="opacity:0.5;">Philadelphia University</span>
        </div>
        <div class="nav-actions">
            <a asp-controller="Dashboard" asp-action="Notifications" style="text-decoration:none; color:inherit;" aria-label="Notifications">
                <div class="nav-bell" id="notifBell" role="img" aria-hidden="true">
                    <i class="ph-duotone ph-bell" style="font-size:20px;"></i>
                    <span class="nav-bell-badge" id="notifBadge" style="display:none">0</span>
                </div>
            </a>
            <div style="position: relative;">
                <button class="nav-user" id="navUserBtn" aria-label="Open user menu" aria-haspopup="true" aria-expanded="false" style="display: flex; align-items: center; gap: 8px; padding: 6px 12px; border: none; background: none; cursor: pointer; border-radius: 8px; transition: background .2s;" onmouseover="this.style.background='var(--indigo-light)'" onmouseout="this.style.background='none'">
                    @{ var _navImg = User.FindFirst("ProfileImageUrl")?.Value; }
                    <div class="av-wrap">
                        @{ var _navName = User.FindFirst(ClaimTypes.Name)?.Value; }
                        <div class="av av-sm av-gradient-ring"><img src="@(string.IsNullOrEmpty(_navImg) ? AvatarHelper.Url(_navName, 44) : _navImg)" onerror="this.src='@AvatarHelper.FallbackUrl(_navName, 44)'" alt="User avatar" /></div>
                        <span class="av-dot"></span>
                    </div>
                    <span class="nav-user-name" style="font-size:13px; font-weight:600; color:var(--text); display:none;">@(User.FindFirst(ClaimTypes.Name)?.Value?.Split(' ').First() ?? "")</span>
                </button>
                <div class="nav-user-dropdown" id="navUserDropdown">
                    <a asp-controller="Profile" asp-action="Profile" class="nav-dropdown-item" style="text-decoration:none;"><i class="ph-fill ph-user-circle" style="font-size:16px;color:var(--indigo);"></i> My Profile</a>
                    <a asp-controller="Settings" asp-action="Settings" class="nav-dropdown-item" style="text-decoration:none;"><i class="ph-duotone ph-gear" style="font-size:16px;color:var(--text-2);"></i> Settings</a>
                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-controller="Admin" asp-action="AdminDashboard" class="nav-dropdown-item" style="text-decoration:none;"><i class="ph-duotone ph-gear" style="font-size:16px;color:var(--text-2);"></i> Admin Dashboard</a>
                    }
                    <hr style="margin:0; border:none; border-top:1px solid var(--border);">
                    <form method="post" asp-controller="Login" asp-action="Logout" style="display:inline;">
                        <button type="submit" class="nav-dropdown-item logout" style="text-decoration:none; background:none; border:none; cursor:pointer; padding:12px 16px; width:100%; text-align:left;"><i class="ph-fill ph-sign-out" style="font-size:16px;"></i> Sign Out</button>
                    </form>
                </div>
            </div>
        </div>
    </nav>

    <!-- SIDEBAR OVERLAY (Mobile) -->
    <div class="sidebar-overlay" id="sidebar-overlay"></div>

    <!-- MAIN CONTENT WITH SIDEBAR -->
    <div class="app-wrap">
        <!-- SIDEBAR -->
        <aside class="sidebar" id="sidebar">
            <a asp-controller="Profile" asp-action="Profile" class="sidebar-user" style="text-decoration:none;">
                @{ var _sideImg = User.FindFirst("ProfileImageUrl")?.Value; }
                <div class="av-wrap">
                    @{ var _sideName = User.FindFirst(ClaimTypes.Name)?.Value; }
                    <div class="av av-md av-gradient-ring"><img src="@(string.IsNullOrEmpty(_sideImg) ? AvatarHelper.Url(_sideName, 60) : _sideImg)" onerror="this.src='@AvatarHelper.FallbackUrl(_sideName, 60)'" alt="User" /></div>
                    <span class="av-dot av-dot-lg"></span>
                </div>
                <div>
                    <div class="sidebar-user-name">@(User.FindFirst(ClaimTypes.Name)?.Value ?? "Student")</div>
                    <div class="sidebar-user-pts"><i class="ph-fill ph-lightning" style="font-size:13px; vertical-align: middle; margin-right: 3px;"></i> <span id="sidebarPoints">-</span> pts</div>
                </div>
            </a>

            <nav class="sidebar-nav">
                <a asp-controller="Dashboard" asp-action="Dashboard" class="nav-item" id="navDashboard">
                    <span class="nav-icon-pill"><i class="ph-duotone ph-squares-four ni-dashboard" style="font-size:18px;"></i></span> Home Feed
                </a>
                <a asp-controller="Session" asp-action="ChatPage" class="nav-item" id="navChat">
                    <span class="nav-icon-pill"><i class="ph-duotone ph-chats ni-chat" style="font-size:18px;"></i></span> Private Sessions
                    <span class="nav-badge" id="msgBadge" style="display:none">0</span>
                </a>
                <a asp-controller="Leaderboard" asp-action="Leaderboard" class="nav-item" id="navLeaderboard">
                    <span class="nav-icon-pill"><i class="ph-duotone ph-trophy ni-trophy" style="font-size:18px;"></i></span> Leaderboard
                </a>
                <a asp-controller="Dashboard" asp-action="Notifications" class="nav-item" id="navNotifications">
                    <span class="nav-icon-pill"><i class="ph-duotone ph-bell ni-bell" style="font-size:18px;"></i></span> Notifications
                    <span class="nav-badge" id="sidebarNotifBadge" style="display:none">0</span>
                </a>
                <a asp-controller="Profile" asp-action="Profile" class="nav-item" id="navProfile">
                    <span class="nav-icon-pill"><i class="ph-duotone ph-user-circle ni-profile" style="font-size:18px;"></i></span> My Profile
                </a>
                <a asp-controller="Points" asp-action="Points" class="nav-item" id="navPoints">
                    <span class="nav-icon-pill"><i class="ph-duotone ph-lightning ni-points" style="font-size:18px;"></i></span> Points & Rewards
                </a>
                <a asp-controller="Settings" asp-action="Settings" class="nav-item" id="navSettings">
                    <span class="nav-icon-pill"><i class="ph-duotone ph-gear ni-settings" style="font-size:18px;"></i></span> Settings
                </a>
            </nav>

            <!-- Sidebar points widget — actionable "Next reward" (F8) -->
            <div class="pts-widget">
                <div class="pts-widget-header">
                    <i class="ph-fill ph-gift" aria-hidden="true"></i>
                    <span>Next reward</span>
                </div>
                <div class="pts-widget-reward" id="ptWidgetReward">Cafeteria 10% off</div>
                <div class="pts-widget-bar">
                    <div class="pts-widget-fill" id="ptWidgetBar" style="width: 0%;"></div>
                </div>
                <div class="pts-widget-sub" id="ptWidgetSub">— pts to unlock</div>
                <a asp-action="Points" asp-controller="Points" class="pts-widget-cta">
                    Browse rewards <i class="ph-bold ph-arrow-right" style="font-size:11px;" aria-hidden="true"></i>
                </a>
            </div>

            <form method="post" asp-controller="Login" asp-action="Logout" style="display: contents;">
                <button type="submit" class="sidebar-logout" style="border: none; background: none; cursor: pointer; padding: 12px 18px; width: 100%; text-align: left; font-size: 13.5px; color: var(--rose); transition: all 0.2s; display: flex; align-items: center; gap: 10px; font-weight:600;"><i class="ph-fill ph-sign-out" style="font-size:17px;"></i> Sign Out</button>
            </form>
        </aside>

        <div class="main">
            @RenderBody()
        </div>
    </div>

    <!-- Sidebar mobile behavior -->
    <script>
        function initSidebar() {
            const hamburger = document.getElementById('sidebarToggle');
            const sidebar = document.getElementById('sidebar');
            const overlay = document.getElementById('sidebar-overlay');

            if (!hamburger || !sidebar) return;

            hamburger.addEventListener('click', () => {
                const isOpen = sidebar.classList.toggle('open');
                hamburger.classList.toggle('open', isOpen);
                if (overlay) overlay.classList.toggle('open', isOpen);
                document.body.style.overflow = isOpen ? 'hidden' : '';
            });

            if (overlay) {
                overlay.addEventListener('click', closeSidebar);
            }

            document.addEventListener('keydown', e => {
                if (e.key === 'Escape') closeSidebar();
            });
        }

        function closeSidebar() {
            const sidebar = document.getElementById('sidebar');
            const overlay = document.getElementById('sidebar-overlay');
            const hamburger = document.getElementById('sidebarToggle');

            if (sidebar) sidebar.classList.remove('open');
            if (overlay) overlay.classList.remove('open');
            if (hamburger) hamburger.classList.remove('open');
            document.body.style.overflow = '';
        }

        function setActiveNav() {
            const path = window.location.pathname.toLowerCase();
            document.querySelectorAll('.sidebar-nav .nav-item').forEach(link => {
                link.classList.remove('active');
                const href = (link.getAttribute('href') || '').toLowerCase().replace(/\/$/, '');
                if (!href || href === '#') return;
                if (path === href || path.startsWith(href + '/') || path === href + '.cshtml') {
                    link.classList.add('active');
                }
            });
        }

        document.addEventListener('DOMContentLoaded', () => {
            initSidebar();
            setActiveNav();
        });
    </script>

    <!-- JavaScript -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script>
        // User dropdown — also update aria-expanded (F5)
        document.getElementById('navUserBtn')?.addEventListener('click', function(e) {
            e.stopPropagation();
            const dropdown = document.getElementById('navUserDropdown');
            const isOpen = dropdown.classList.toggle('open');
            this.setAttribute('aria-expanded', isOpen);
        });
        document.addEventListener('click', function() {
            document.getElementById('navUserDropdown').classList.remove('open');
            document.getElementById('navUserBtn')?.setAttribute('aria-expanded', 'false');
        });

        // Toast function
        function showToast(msg, type = 'success') {
            const t = document.createElement('div');
            t.className = `toast ${type === 'error' ? 'toast-error' : type === 'warn' ? 'toast-warn' : ''}`;
            t.textContent = msg;
            document.body.appendChild(t);
            setTimeout(() => t.remove(), 3000);
        }
    </script>
    <script>
               async function loadNotificationCount() {
            try {
                const res = await fetch('/api/notifications');
                if (!res.ok) return;
                const data = await res.json();

                // Navbar bell badge — total unread
                const badge = document.getElementById('notifBadge');
                const bell  = document.getElementById('notifBell');
                if (badge) {
                    badge.textContent = data.length;
                    badge.style.display = data.length > 0 ? 'inline-block' : 'none';
                }
                if (bell) {
                    if (data.length > 0) {
                        bell.classList.add('has-notif');
                        setTimeout(() => bell.classList.remove('has-notif'), 800);
                    } else {
                        bell.classList.remove('has-notif');
                    }
                }

                // Sidebar Notifications badge — exclude messages
                const notifCount = data.filter(n => n.type !== 'NewMessage').length;
                const sidebarNotifBadge = document.getElementById('sidebarNotifBadge');
                if (sidebarNotifBadge) {
                    sidebarNotifBadge.textContent = notifCount;
                    sidebarNotifBadge.style.display = notifCount > 0 ? 'inline-block' : 'none';
                }

                // Sidebar Private Sessions badge — only messages
                const msgCount = data.filter(n => n.type === 'NewMessage').length;
                const msgBadge = document.getElementById('msgBadge');
                if (msgBadge) {
                    msgBadge.textContent = msgCount;
                    msgBadge.style.display = msgCount > 0 ? 'inline-block' : 'none';
                }
            } catch (e) {
                console.error('Failed to load notifications', e);
            }
        }

        async function loadUserPoints() {
            try {
                const res = await fetch('/api/user/points');
                if (!res.ok) return;
                const data = await res.json();

                const sp = document.getElementById('sidebarPoints');
                if (sp) sp.textContent = data.points.toLocaleString();

                // Sidebar "Next reward" widget (F8)
                const rewards = [
                    { name: 'Computer Lab 2hr', cost: 100 },
                    { name: 'Print 20 pages free', cost: 150 },
                    { name: 'Cafeteria 10% off',  cost: 200 },
                    { name: 'Canteen free drink',  cost: 180 },
                    { name: 'Bookshop 15% off',    cost: 350 },
                    { name: 'Library 5 JD credit', cost: 400 },
                    { name: 'Gym 1 week free',     cost: 500 },
                ];
                const pts = data.points || 0;
                const next = rewards.find(r => r.cost > pts) || rewards[rewards.length - 1];
                const toNext = Math.max(0, next.cost - pts);
                const pct = Math.min((pts / next.cost) * 100, 100);

                const rewardEl = document.getElementById('ptWidgetReward');
                if (rewardEl) rewardEl.textContent = next.name;

                const bar = document.getElementById('ptWidgetBar');
                if (bar) bar.style.width = pct + '%';

                const sub = document.getElementById('ptWidgetSub');
                if (sub) sub.textContent = toNext > 0 ? `${toNext} more pts to unlock` : 'Ready to redeem!';
            } catch (e) { /* silent */ }
        }

        // Load on page ready, then refresh every 30 seconds
        document.addEventListener('DOMContentLoaded', () => {
            @if (User.Identity?.IsAuthenticated == true)
            {
                    <text>
                    loadNotificationCount();
                    loadUserPoints();
                    setInterval(loadNotificationCount, 30000);
                    setInterval(loadUserPoints, 60000);
                    </text>
            }
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)

    <!-- EFFECT 1: Lenis smooth scroll for dashboard -->
    <script src="https://cdn.jsdelivr.net/npm/@@studio-freight/lenis@@1.0.42/dist/lenis.min.js"></script>
    <script>
    (function(){
      if(window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
      var lenis = new Lenis({
        duration: 1.2,
        easing: function(t){ return Math.min(1, 1.001 - Math.pow(2, -10 * t)); },
        orientation: 'vertical',
        smoothWheel: true
      });
      function raf(time){ lenis.raf(time); requestAnimationFrame(raf); }
      requestAnimationFrame(raf);
      if(window.ScrollTrigger){
        lenis.on('scroll', ScrollTrigger.update);
        gsap.ticker.add(function(time){ lenis.raf(time * 1000); });
        gsap.ticker.lagSmoothing(0);
      }
      window.lenis = lenis;
    })();
    </script>
    <script>
        // Fallback for broken uploaded profile images — fires if an img fails to load
        document.addEventListener('DOMContentLoaded', function () {
            const pal = [
                ['3D52A0','7091E6'], ['7C3AED','A78BFA'], ['059669','34D399'],
                ['D97706','FBBF24'], ['0891B2','22D3EE'], ['BE185D','F472B6'],
                ['C2410C','FB923C'], ['0F766E','2DD4BF']
            ];
            function svgAvatar(name) {
                const n = name || 'U';
                const init = n.charAt(0).toUpperCase();
                const sum = n.split('').reduce(function(s,c){return s+c.charCodeAt(0);},0);
                const pair = pal[Math.abs(sum) % pal.length];
                const id = 'g' + Math.abs(sum);
                return "data:image/svg+xml," + encodeURIComponent(
                    '<svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 64 64">' +
                    '<defs><linearGradient id="' + id + '" x1="0%" y1="0%" x2="100%" y2="100%">' +
                    '<stop offset="0%" stop-color="#' + pair[0] + '"/>' +
                    '<stop offset="100%" stop-color="#' + pair[1] + '"/>' +
                    '</linearGradient></defs>' +
                    '<circle cx="32" cy="32" r="32" fill="url(#' + id + ')"/>' +
                    '<text x="50%" y="50%" dominant-baseline="central" text-anchor="middle" fill="white" font-size="24" font-family="Outfit,system-ui,sans-serif" font-weight="700">' + init + '</text>' +
                    '</svg>'
                );
            }
            // Apply fallback to all avatar images (DiceBear might fail offline)
        document.querySelectorAll('.av img, .q-avatar, .rank-avatar, .result-avatar, .how-lb-av, .hero-av').forEach(function(img) {
                img.addEventListener('error', function () {
                    this.src = svgAvatar(this.alt || this.getAttribute('data-name') || 'U');
                    this.onerror = null;
                });
            });
        });
    </script>
    <script>
        // taste-skill: IntersectionObserver scroll reveals — never window scroll listener
        (function () {
            var io = new IntersectionObserver(function (entries) {
                entries.forEach(function (e) {
                    if (e.isIntersecting) {
                        e.target.classList.add('visible');
                        io.unobserve(e.target);
                    }
                });
            }, { threshold: 0.08, rootMargin: '0px 0px -32px 0px' });
            document.querySelectorAll('.reveal, .reveal-stagger').forEach(function (el) {
                io.observe(el);
            });
        })();
    </script>
</body>
</html>

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Uni_Connect</title>
    <link href="~/css/login.css" rel="stylesheet" />
</head>
<style>
    .footer {
        background: #0F172A;
        color: #64748B;
        padding: 48px;
        text-align: center
    }
</style>
<body>
    @* shared side nav-bar *@
    @if (ViewData["HideNavbar"] == null || !(bool)ViewData["HideNavbar"])
    {
        <!-- NAVBAR -->
        <nav class="navbar">
            <button class="nav-hamburger" id="hamburger"><span></span><span></span><span></span></button>
            <a asp-controller="Dashboard" asp-action="Dashboard" class="nav-logo">
                <div class="nav-logo-icon">🎓</div><span>UniConnect</span>
            </a>
            <div class="nav-search">
                <input class="form-input" id="main-search" placeholder="🔍  Search questions, courses, topics..." autocomplete="off">
            </div>
            <div class="nav-actions">
                <a href="CreatePost"><button class="btn btn-primary btn-sm">+ Ask</button></a>
                <a href="Notifications" class="nav-bell">🔔<span class="nav-bell-badge">3</span></a>
                <!-- User menu with logout -->
                <div class="nav-user-menu">
                    <div onclick="toggleUserMenu()" style="cursor:pointer;display:flex;align-items:center;gap:7px">
                        <div class="av av-sm"><img src="https://i.pravatar.cc/36?img=11" alt="Ahmad"></div>
                        <span style="font-size:13px;font-weight:600;color:var(--text)">Ahmad</span>
                    </div>
                    <div class="nav-user-dropdown" id="user-dropdown">
                        <a href="Profile"><div class="nav-dropdown-item">👤 My Profile</div></a>
                        <a href="settings.html"><div class="nav-dropdown-item">⚙️ Settings</div></a>
                        <a href="points.html"><div class="nav-dropdown-item">🪙 Points &amp; Rewards</div></a>
                        <div class="nav-dropdown-sep"></div>

                    </div>
                </div>
            </div>
        </nav>
        <div class="app-wrap">
             
        <aside class="sidebar" id="sidebar">
            <a href="profile.html" class="sidebar-user">
                <div class="av av-md"><img src="https://i.pravatar.cc/44?img=11" alt="Ahmad"></div>
                <div><div class="sidebar-user-name">Ahmad K.</div><div class="sidebar-user-pts">🪙 840 pts</div></div>
            </a>
            <nav class="sidebar-nav">
                <a href="Dashboard"><div class="nav-item active"><span class="ni">🏠</span>Home Feed</div></a>
                <a href="CreatePost"><div class="nav-item"><span class="ni">✏️</span>Ask a Question</div></a>
                <a href="ChatPage"><div class="nav-item"><span class="ni">💬</span>My Sessions</div></a>
                <a href="Leaderboard"><div class="nav-item"><span class="ni">🏆</span>Leaderboard</div></a>
                <a href="Notifications"><div class="nav-item"><span class="ni">🔔</span>Notifications<span class="nav-badge">3</span></div></a>
                <a href="Profile"><div class="nav-item"><span class="ni">👤</span>My Profile</div></a>
                <a href="points.html"><div class="nav-item"><span class="ni">🪙</span>Points &amp; Rewards</div></a>
                <a href="settings.html"><div class="nav-item"><span class="ni">⚙️</span>Settings</div></a>
                <div class="nav-section">Browse by Faculty</div>
                <div class="nav-item" onclick="filterByFaculty('IT')"><span class="ni">💻</span>IT Faculty<span class="nav-count">48</span></div>
                <div class="nav-item" onclick="filterByFaculty('Engineering')"><span class="ni">⚙️</span>Engineering<span class="nav-count">31</span></div>
                <div class="nav-item" onclick="filterByFaculty('Business')"><span class="ni">💼</span>Business<span class="nav-count">27</span></div>
                <div class="nav-item" onclick="filterByFaculty('Law')"><span class="ni">⚖️</span>Law<span class="nav-count">14</span></div>
                <div class="nav-item" onclick="filterByFaculty('Arts')"><span class="ni">🎨</span>Arts<span class="nav-count">19</span></div>
                <div class="nav-item" onclick="filterByFaculty('Pharmacy')"><span class="ni">💊</span>Pharmacy<span class="nav-count">22</span></div>
            </nav>
            <a href="points.html">
                <div class="pts-widget">
                    <div class="pts-widget-num">840</div>
                    <div class="pts-widget-label">🪙 Your Points</div>
                    <div class="pts-widget-bar"><div class="pts-widget-fill" style="width:84%"></div></div>
                    <div class="pts-widget-sub">160 pts to Verified Tutor</div>
                </div>
            </a>
            <form asp-controller="Login" asp-action="Logout" method="post" id="logoutForm">
                @Html.AntiForgeryToken()
                <button type="submit" class="nav-dropdown-item logout" style="background:none;border:none;width:100%;text-align:left;font-family:inherit;padding-left:15px">🚪 Sign Out</button>
            </form>
        </aside>
            
                @RenderBody()
            



        </div>


    }
    else
    {
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    }
    


    
        
   
    <footer class="footer">
        <div style="max-width:900px;margin:0 auto">
            <div style="display:flex;align-items:center;justify-content:center;gap:10px;margin-bottom:20px">
                <div style="width:36px;height:36px;background:linear-gradient(135deg,#3D52A0,#7091E6);border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:16px">🎓</div>
                <span style="font-weight:900;font-size:18px;color:#CBD5E1">UniConnect</span>
            </div>
            <p style="font-size:14px;margin-bottom:18px">Philadelphia University Peer Learning Platform</p>
            <div style="display:flex;gap:28px;justify-content:center;flex-wrap:wrap;margin-bottom:24px">
                <a asp-controller="Login" asp-action="Login_Page" class="ftr-lnk">Sign In</a>
                <a asp-controller="Login" asp-action="Register_Page" class="ftr-lnk">Register</a>
                <a href="dashboard.html" class="ftr-lnk">Dashboard</a>
                <a href="leaderboard.html" class="ftr-lnk">Leaderboard</a>
                <a href="points.html" class="ftr-lnk">Rewards</a>
            </div>
            <div style="border-top:1px solid #1E293B;padding-top:22px;font-size:13px;line-height:1.8">
                Built by <strong style="color:#94A3B8">Ahmad Al-Hawwani · Ahmad Al-Atrash · Mustafa Maqousi · Abdul-Razzaq Qara</strong><br>
                Philadelphia University · Graduation Project 2026
            </div>
        </div>
    </footer>
   
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <script>
        // ── Sidebar hamburger ──
        function initSidebar(){const h=document.getElementById('hamburger'),s=document.getElementById('sidebar'),o=document.getElementById('sidebar-overlay');if(!h||!s)return;h.addEventListener('click',()=>{const open=s.classList.toggle('open');h.classList.toggle('open',open);if(o)o.classList.toggle('open',open);document.body.style.overflow=open?'hidden':''});if(o)o.addEventListener('click',closeSidebar);document.addEventListener('keydown',e=>{if(e.key==='Escape')closeSidebar()})}
        function closeSidebar(){const s=document.getElementById('sidebar'),o=document.getElementById('sidebar-overlay'),h=document.getElementById('hamburger');if(s)s.classList.remove('open');if(o)o.classList.remove('open');if(h)h.classList.remove('open');document.body.style.overflow=''}

        // ── Tabs ──
        function showTab(id,el){const parent=el.closest('.tabs');if(parent)parent.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));el.classList.add('active');document.querySelectorAll('[data-tab]').forEach(c=>c.classList.add('hidden'));const t=document.getElementById(id);if(t){t.classList.remove('hidden');t.classList.add('fade-in')}}

        // ── Wizard ──
        function wzStep(n){[1,2,3].forEach(i=>{const p=document.getElementById('wz'+i),s=document.getElementById('ws'+i);if(!p||!s)return;p.classList.toggle('hidden',i!==n);s.classList.remove('active','done');if(i===n)s.classList.add('active');if(i<n)s.classList.add('done')})}

        
        // ── Escape HTML ──
        function escapeHtml(str){return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;')}

        // ── User menu dropdown ──
        function toggleUserMenu(){const d=document.getElementById('user-dropdown');if(d)d.classList.toggle('open')}
        document.addEventListener('click',e=>{const d=document.getElementById('user-dropdown');if(d&&!e.target.closest('.nav-user-menu'))d.classList.remove('open')})



        // ── LIVE SEARCH ──
        const QUESTIONS=[
          {title:'How does AVL tree rotation actually work?',faculty:'IT Faculty',course:'CS302',url:'single-post.html',solved:true,answers:7,votes:42},
          {title:'Difference between Dijkstra and Bellman-Ford?',faculty:'IT Faculty',course:'CS401',url:'single-post.html',solved:false,answers:4,votes:18},
          {title:'How to prepare a trial balance from journal entries?',faculty:'Business',course:'ACCT201',url:'single-post.html',solved:true,answers:3,votes:9},
          {title:'Finding eigenvalues of a 3×3 matrix step by step?',faculty:'Engineering',course:'MATH201',url:'single-post.html',solved:false,answers:5,votes:14},
          {title:'Mechanism of action of beta-blockers explained simply?',faculty:'Pharmacy',course:'PHARM301',url:'single-post.html',solved:false,answers:6,votes:21},
          {title:'Best approach for solving memoization problems in DP?',faculty:'IT Faculty',course:'CS401',url:'single-post.html',solved:false,answers:3,votes:9},
          {title:'How to implement a stack using two queues?',faculty:'IT Faculty',course:'CS302',url:'single-post.html',solved:true,answers:4,votes:7},
          {title:'What is the time complexity of AVL tree operations?',faculty:'IT Faculty',course:'CS302',url:'single-post.html',solved:true,answers:4,votes:18},
        ];
        function initSearch(){const inp=document.querySelector('.nav-search .form-input');if(!inp)return;const wrap=inp.closest('.nav-search')||inp.parentElement;wrap.style.position='relative';const dd=document.createElement('div');dd.className='search-dropdown';dd.id='search-dropdown';wrap.appendChild(dd);inp.addEventListener('input',()=>runSearch(inp.value.trim()));inp.addEventListener('focus',()=>{if(inp.value.trim())runSearch(inp.value.trim())});document.addEventListener('click',e=>{if(!wrap.contains(e.target))dd.classList.remove('open')})}
        function runSearch(q){const dd=document.getElementById('search-dropdown');if(!dd)return;if(!q){dd.classList.remove('open');return}const results=QUESTIONS.filter(x=>x.title.toLowerCase().includes(q.toLowerCase())||x.course.toLowerCase().includes(q.toLowerCase())||x.faculty.toLowerCase().includes(q.toLowerCase()));dd.innerHTML='';if(!results.length){dd.innerHTML='<div class="search-no-results">No results found for "'+escapeHtml(q)+'"</div>'}else{results.slice(0,6).forEach(r=>{const el=document.createElement('a');el.href=r.url;el.className='search-result-item';el.innerHTML=`<span style="font-size:20px;flex-shrink:0">${r.solved?'✅':'❓'}</span><div><div class="search-result-title">${escapeHtml(r.title)}</div><div class="search-result-meta">${r.faculty} · ${r.course} · ${r.answers} answers · ${r.votes} votes</div></div>`;dd.appendChild(el)})}dd.classList.add('open')}

        // ── Session Request Modal ──
        function openSessionModal(name,img,topic){const existing=document.getElementById('session-modal');if(existing)existing.remove();const m=document.createElement('div');m.id='session-modal';m.className='modal-overlay';m.onclick=e=>{if(e.target===m)m.remove()};m.innerHTML=`<div class="modal-box"><div style="display:flex;align-items:center;gap:12px;margin-bottom:16px"><div class="av av-lg"><img src="${img}" alt="${name}"></div><div><div class="modal-title">Request Session with ${name}</div><div class="modal-sub">Send a session request — they can accept or decline</div></div></div><div class="form-group"><label class="form-label">Topic / Course</label><input class="form-input" id="modal-topic" value="${topic||''}" placeholder="e.g. CS302 — AVL Tree Rotations"></div><div class="form-group"><label class="form-label">Your message</label><textarea class="form-input form-textarea" id="modal-msg" style="min-height:90px" placeholder="Briefly describe what you need help with..."></textarea></div><div style="background:var(--amber-light);border:1px solid #FDE68A;border-radius:9px;padding:10px 14px;margin-bottom:18px;font-size:13px;color:#92400E">This will cost <strong>−5 pts</strong> from your balance.</div><div style="display:flex;gap:10px;justify-content:flex-end"><button class="btn btn-ghost btn-sm" onclick="document.getElementById('session-modal').remove()">Cancel</button><button class="btn btn-primary" onclick="submitSessionReq('${name}')">Send Request (−5 pts)</button></div></div>`;document.body.appendChild(m)}
        function submitSessionReq(name){document.getElementById('session-modal').remove();showToast('✅ Session request sent to '+name+'! −5 pts')}

        document.addEventListener('DOMContentLoaded',()=>{initSidebar();initSearch()})
    </script>
    <script>
        // ── INLINE SEARCH (filters the cards) ──
        function filterCards(q){
          const cards=document.querySelectorAll('#cards-container .q-card');
          const banner=document.getElementById('search-banner');
          const label=document.getElementById('search-label');
          const noRes=document.getElementById('no-results');
          let found=0;
          q=q.toLowerCase().trim();
          cards.forEach(c=>{
            const title=c.dataset.title||'';
            const fac=c.dataset.faculty||'';
            const course=c.dataset.course||'';
            const match=!q||title.toLowerCase().includes(q)||fac.toLowerCase().includes(q)||course.toLowerCase().includes(q);
            c.style.display=match?'block':'none';
            if(match)found++;
          });
          if(q){
            banner.style.display='flex';
            label.textContent='Showing '+found+' result'+(found!==1?'s':'')+ ' for "'+q+'"';
          } else {
            banner.style.display='none';
          }
          noRes.style.display=(found===0&&q)?'block':'none';
        }
        function filterByFaculty(fac){
          document.getElementById('main-search').value=fac;
          filterCards(fac);
          closeSidebar();
        }
        function filterByKeyword(kw){
          document.getElementById('main-search').value=kw;
          filterCards(kw);
        }
        function clearSearch(){
          document.getElementById('main-search').value='';
          filterCards('');
        }
        document.addEventListener('DOMContentLoaded',()=>{
          const inp=document.getElementById('main-search');
          if(inp)inp.addEventListener('input',e=>filterCards(e.target.value));
        });
    </script>


</body>
</html>

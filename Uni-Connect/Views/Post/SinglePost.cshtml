@model Uni_Connect.Models.Post
@{
    ViewData["Title"] = Model?.Title ?? "Post";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";

    int? currentUserId = null;
    bool isPostOwner = false;
    if (Model != null && User.Identity?.IsAuthenticated == true)
    {
        var uidClaim = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier);
        if (uidClaim != null)
        {
            currentUserId = int.Parse(uidClaim.Value);
            isPostOwner = Model.UserID == currentUserId.Value;
        }
    }
}

<link href="~/css/singlepoststyle.css" rel="stylesheet" />
<style>
    .answer-fab {
        position: fixed;
        right: 28px;
        bottom: 28px;
        width: 58px;
        height: 58px;
        border-radius: 50%;
        border: none;
        background: var(--indigo);
        color: #fff;
        z-index: 9999;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        box-shadow: 0 14px 32px rgba(79, 70, 229, 0.35);
        transition: transform .2s ease, box-shadow .2s ease;
    }

        .answer-fab i {
            font-size: 26px;
        }

        .answer-fab:hover {
            transform: translateY(-3px) scale(1.04);
            box-shadow: 0 18px 38px rgba(79, 70, 229, 0.45);
        }

    @@media (max-width: 700px) {
        .answer-fab {
            right: 18px;
            bottom: 18px;
            width: 54px;
            height: 54px;
        }
    }

</style>

<div style="max-width: 860px; margin: 0 auto; padding: 20px;">

    <a asp-action="Dashboard" asp-controller="Dashboard" class="btn btn-ghost btn-sm" style="margin-bottom:24px; display:inline-flex; align-items:center; gap:8px;">
        <i class="ph-bold ph-arrow-left" style="font-size:15px;"></i> Back to Feed
    </a>


    @if (TempData["SuccessMessage"] != null)
    {
        <div style="background:var(--emerald-light); color:var(--emerald); padding:12px 16px; border-radius:10px; margin-bottom:24px; font-size:14px; font-weight:600; display:flex; align-items:center; gap:8px;">
            <i class="ph-fill ph-check-circle" style="font-size:18px;"></i> @TempData["SuccessMessage"]
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div style="background:var(--rose-light); color:var(--rose); padding:12px 16px; border-radius:10px; margin-bottom:24px; font-size:14px; font-weight:600; display:flex; align-items:center; gap:8px;">
            <i class="ph-fill ph-x-circle" style="font-size:18px;"></i> @TempData["ErrorMessage"]
        </div>
    }

    @if (Model != null)
    {
        var answerCount = Model.Answers?.Count(a => !a.IsDeleted) ?? 0;
        var isSolved = Model.Answers?.Any(a => a.IsAccepted && !a.IsDeleted) == true;

        <!-- ── QUESTION ── -->
        <div class="card" style="margin-bottom:28px;">

            <!-- Author row -->
            <div style="display:flex; align-items:center; gap:10px; margin-bottom:18px; flex-wrap:wrap;">
                @if (!string.IsNullOrEmpty(Model.User?.ProfileImageUrl))
                {
                    <img src="@Model.User.ProfileImageUrl" alt="" class="q-avatar"
                         style="width:28px;height:28px;border-radius:50%;flex-shrink:0;" />
                }
                else
                {
                    <img src="@AvatarHelper.Url(Model.User?.Name, 28)" alt=""
                         style="width:28px;height:28px;border-radius:50%;flex-shrink:0;" />
                }

                <div style="flex:1;">
                    @if (!string.IsNullOrEmpty(Model.User?.Username))
                    {
                        <a href="@Url.Action("ViewProfile", "Profile", new { username = Model.User.Username })"
                           style="font-size:14px;font-weight:700;color:var(--text);text-decoration:none;display:block;">
                            @(Model.User.Name ?? "User")
                        </a>
                    }
                    else
                    {
                        <div style="font-size:14px;font-weight:700;color:var(--text);">@(Model.User?.Name ?? "User")</div>
                    }
                    <div style="font-size:12px;color:var(--text-2);">@Model.CreatedAt.ToString("MMM dd, yyyy · h:mm tt")</div>
                </div>

                @if (Model.Category != null)
                {
                    <span class="chip chip-indigo">@Model.Category.Name</span>
                }
                @if (isSolved)
                {
                    <span class="chip chip-emerald" style="display:inline-flex;align-items:center;gap:4px;">
                        <i class="ph-fill ph-check-circle" style="font-size:12px;"></i> Solved
                    </span>
                }
                @if (currentUserId.HasValue && !isPostOwner)
                {
                    <button onclick="openSessionModal(@Model.UserID, @Model.PostID)"
                            class="btn btn-primary btn-sm" style="margin-left:auto;">
                        <i class="ph-bold ph-calendar-plus" style="font-size:14px;"></i> Request Session
                    </button>
                }
            </div>

            <!-- Session modal -->
            <div id="sessionModal" style="display:none; background:var(--bg); border:1.5px solid var(--border); border-radius:var(--radius); padding:16px; margin-bottom:18px;">
                <p style="font-size:13px; font-weight:700; color:var(--text); margin:0 0 10px 0;">Describe what you need help with:</p>
                <textarea id="sessionDescription" class="form-input form-textarea" rows="3"
                      placeholder="e.g. I need help understanding your approach to this problem..."></textarea>
                <div style="display:flex; gap:8px; margin-top:10px;">
                    <button onclick="submitSessionRequest()" class="btn btn-primary btn-sm">Send Request</button>
                    <button onclick="document.getElementById('sessionModal').style.display='none'" class="btn btn-ghost btn-sm">Cancel</button>
                </div>
            </div>

            <!-- Post view mode -->
            <div id="postViewMode">
                <h1 style="font-size:26px; font-weight:800; color:var(--text); margin:0 0 14px 0; line-height:1.4; overflow-wrap:break-word; word-break:break-word;">
                    @Model.Title
                </h1>

                <div style="font-size:15px; color:var(--text); line-height:1.75; margin-bottom:20px; white-space:pre-wrap; overflow-wrap:break-word; word-break:break-word;">@Model.Content</div>

                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <div style="margin-bottom:20px; border-radius:12px; overflow:hidden; border:1px solid var(--border);">
                        <img src="@Model.ImageUrl" alt="" style="max-width:100%; display:block; cursor:pointer;" onclick="window.open(this.src)" />
                    </div>
                }
            </div>

            <!-- Post edit mode: same area turns editable, Reddit-style -->
            @if (isPostOwner)
            {
                <form id="postEditMode"
                      asp-action="EditPost"
                      asp-controller="Post"
                      method="post"
                      enctype="multipart/form-data"
                      style="display:none; margin-bottom:20px;">
                    @Html.AntiForgeryToken()

                    <input type="hidden" name="postId" value="@Model.PostID" />

                    <label style="font-size:13px; font-weight:800; color:var(--text); margin-bottom:6px; display:block;">
                        Title
                    </label>
                    <input name="title"
                           value="@Model.Title"
                           class="form-input"
                           placeholder="Post title"
                           style="width:100%; margin-bottom:14px;" />

                    <label style="font-size:13px; font-weight:800; color:var(--text); margin-bottom:6px; display:block;">
                        Description
                    </label>
                    <textarea name="content"
                      rows="7"
                      class="form-input form-textarea"
                      placeholder="Write your post description..."
                      style="width:100%; margin-bottom:14px;">@Model.Content</textarea>

                    <label style="font-size:13px; font-weight:800; color:var(--text); margin-bottom:6px; display:block;">
                        Image
                    </label>

                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <div style="margin-bottom:10px; border-radius:12px; overflow:hidden; border:1px solid var(--border); max-width:320px;">
                            <img src="@Model.ImageUrl" alt="" style="width:100%; display:block;" />
                        </div>

                        <label style="display:flex; align-items:center; gap:8px; font-size:13px; color:var(--text-2); margin-bottom:10px;">
                            <input type="checkbox" name="removeImage" value="true" />
                            Remove current image
                        </label>
                    }

                    <label class="edit-image-upload">
                        <i class="ph-duotone ph-image-square"></i>
                        <span id="editPostImageFileName">Choose new image</span>
                        <small>JPG, PNG, GIF, or WebP under 5MB</small>

                        <input id="editPostImageInput"
                               type="file"
                               name="ImageFile"
                               accept="image/*"
                               hidden />
                    </label>

                    <div style="display:flex; gap:8px; margin-bottom:4px;">
                        <button type="submit" class="btn btn-primary">Save Changes</button>
                        <button type="button" class="btn btn-ghost" onclick="cancelPostEdit()">Cancel</button>
                    </div>
                </form>
            }

            <!-- Stats bar -->
            <div style="display:flex; gap:16px; align-items:center; border-top:1px solid var(--border); padding-top:14px; font-size:13px; color:var(--text-2); font-weight:600; flex-wrap:wrap;">
                @if (currentUserId.HasValue && !isPostOwner)
                {
                    <button id="postUpvoteBtn" onclick="upvoteThisPost(@Model.PostID)" title="Upvote this question"
                            style="background:none;border:1.5px solid var(--border);border-radius:99px;cursor:pointer;font-size:13px;font-weight:700;color:var(--text-2);display:inline-flex;align-items:center;gap:6px;padding:5px 12px;transition:all .2s;font-family:inherit;">
                        <i class="ph-duotone ph-thumbs-up" id="postUpvoteIcon" style="font-size:15px;"></i>
                        <span id="postUpvoteCount">@Model.Upvotes</span> upvotes
                    </button>
                }
                else
                {
                    <span style="display:inline-flex;align-items:center;gap:5px;">
                        <i class="ph-fill ph-thumbs-up" style="font-size:15px;color:var(--amber);"></i>
                        <span id="postUpvoteCount">@Model.Upvotes</span> upvotes
                    </span>
                }

                <span style="display:inline-flex; align-items:center; gap:5px;">
                    <i class="ph-duotone ph-chat-circle-dots" style="font-size:15px;"></i> @answerCount answer@(answerCount != 1 ? "s" : "")
                </span>

                <span style="display:inline-flex; align-items:center; gap:5px;">
                    <i class="ph-duotone ph-eye" style="font-size:15px;"></i> @Model.ViewsCount views
                </span>

                @if (currentUserId.HasValue && !isPostOwner)
                {
                    <button onclick="openReportModal(@Model.PostID, 'Post')"
                            style="margin-left:auto; background:none; border:none; cursor:pointer; font-size:12px; color:var(--text-3); display:inline-flex; align-items:center; gap:4px; font-family:inherit; padding:4px 8px; border-radius:6px; transition:color .2s;"
                            onmouseover="this.style.color='var(--red,#EF4444)'" onmouseout="this.style.color='var(--text-3)'"
                            title="Report this post">
                        <i class="ph-duotone ph-flag-pennant" style="font-size:14px;"></i> Report
                    </button>
                }

                @if (isPostOwner)
                {
                    <button type="button"
                            id="openDeletePostModalBtn"
                            style="margin-left:auto; background:none; border:none; cursor:pointer; font-size:12px; color:var(--text-3); display:inline-flex; align-items:center; gap:4px; font-family:inherit; padding:4px 8px; border-radius:6px; transition:color .2s;"
                            onmouseover="this.style.color='#EF4444'"
                            onmouseout="this.style.color='var(--text-3)'"
                            title="Delete this post">
                        <i class="ph-duotone ph-trash-simple" style="font-size:14px;"></i> Delete
                    </button>

                    <button type="button"
                            id="editPostBtn"
                            onclick="openPostEdit()"
                            style="background:none; border:none; cursor:pointer; font-size:12px; color:var(--text-3); display:inline-flex; align-items:center; gap:4px; font-family:inherit; padding:4px 8px; border-radius:6px;">
                        <i class="ph-duotone ph-pencil-simple" style="font-size:14px;"></i> Edit
                    </button>
                }
            </div>
        </div>

        <div class="confirm-overlay" id="deletePostModal" role="dialog" aria-modal="true" aria-labelledby="deletePostModalTitle">
            <div class="confirm-modal">
                <div class="modal-icon">
                    <i class="ph-fill ph-warning"></i>
                </div>

                <h3 id="deletePostModalTitle">Delete this post?</h3>

                <p>
                    This will permanently delete your post from the platform.
                    This action cannot be undone.
                </p>

                <div class="modal-actions">
                    <button type="button" class="btn-cancel" id="cancelDeletePostBtn">Cancel</button>

                    <form asp-action="DeletePost" asp-controller="Post" method="post" style="flex:1;margin:0;">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="postId" value="@Model.PostID" />
                        <button type="submit" class="btn-danger" style="width:100%;">Yes, delete this post</button>
                    </form>
                </div>
            </div>
        </div>
        <div class="confirm-overlay" id="deleteAnswerModal">
            <div class="confirm-modal">
                <div class="modal-icon">
                    <i class="ph-fill ph-warning"></i>
                </div>

                <h3>Delete this answer?</h3>

                <p>
                    This will permanently delete your answer.
                    This action cannot be undone.
                </p>

                <div class="modal-actions">
                    <button type="button"
                            class="btn-cancel"
                            onclick="closeDeleteAnswerModal()">
                        Cancel
                    </button>

                    <form asp-action="DeleteAnswer"
                          asp-controller="Answer"
                          method="post"
                          style="flex:1;margin:0;">
                        @Html.AntiForgeryToken()

                        <input type="hidden"
                               id="deleteAnswerIdInput"
                               name="answerId" />

                        <input type="hidden"
                               name="postId"
                               value="@Model.PostID" />

                        <button type="submit"
                                class="btn-danger"
                                style="width:100%;">
                            Yes, delete this answer
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <!-- Report Modal -->
        <div id="reportModal" style="display:none; background:var(--bg); border:1.5px solid var(--border); border-radius:var(--radius); padding:16px; margin-bottom:18px;">
            <p style="font-size:13px; font-weight:700; color:var(--text); margin:0 0 8px 0;"><i class="ph-fill ph-flag-pennant" style="color:#EF4444; margin-right:4px;"></i> Report Content</p>
            <p style="font-size:12px; color:var(--text-2); margin:0 0 10px 0;">Describe why this content violates community guidelines.</p>
            <textarea id="reportReason" class="form-input form-textarea" rows="3" maxlength="500"
                  placeholder="e.g. Spam, inappropriate content, misinformation..."></textarea>
            <div style="display:flex; gap:8px; margin-top:10px; align-items:center;">
                <button onclick="submitReport()" class="btn btn-sm" style="background:#EF4444;color:white;border:none;">Submit Report</button>
                <button onclick="closeReportModal()" class="btn btn-ghost btn-sm">Cancel</button>
            </div>
        </div>

        <!-- ── ANSWERS ── -->
        <div style="display:flex; align-items:center; gap:10px; margin-bottom:16px;">
            <h2 style="font-size:18px; font-weight:800; color:var(--text); margin:0;">
                <i class="ph-fill ph-chat-circle" style="font-size:18px; color:var(--indigo); vertical-align:middle; margin-right:6px;"></i>
                @answerCount Answer@(answerCount != 1 ? "s" : "")
            </h2>
            @if (isSolved)
            {
                <span style="font-size:12px; color:var(--emerald); font-weight:700; background:var(--emerald-light); padding:3px 10px; border-radius:99px;">
                    Best answer marked
                </span>
            }
        </div>

        @if (answerCount > 0)
        {
            <div style="display:flex; flex-direction:column; gap:12px; margin-bottom:32px;">
                @foreach (var answer in Model.Answers!.Where(a => !a.IsDeleted).OrderByDescending(a => a.IsAccepted).ThenByDescending(a => a.Upvotes))
                {
                    var isAccepted = answer.IsAccepted;
                    <div style="display:flex; gap:16px; background:@(isAccepted ? "var(--emerald-light)" : "var(--surface)"); border:1.5px solid @(isAccepted ? "var(--emerald)" : "var(--border)"); border-radius:var(--radius); padding:18px; transition:box-shadow .2s;">

                        <!-- Vote column -->
                        <div style="display:flex; flex-direction:column; align-items:center; gap:4px; min-width:44px; padding-top:2px;">
                            <button class="upvote-btn" data-answer-id="@answer.AnswerID"
                                    title="Upvote this answer"
                                    style="width:40px;height:40px;border-radius:50%;border:1.5px solid var(--border);background:none;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .2s;color:var(--text-2);">
                                <i class="ph-duotone ph-thumbs-up" style="font-size:18px;pointer-events:none;"></i>
                            </button>
                            <span class="upvote-count" data-upvote-count="@answer.AnswerID"
                                  style="font-size:16px; font-weight:800; color:var(--text); line-height:1;">@answer.Upvotes</span>
                        </div>

                        <!-- Content column -->
                        <div style="flex:1; min-width:0;">
                            <!-- Answer author + accepted badge -->
                            <div style="display:flex; align-items:center; gap:8px; margin-bottom:12px; flex-wrap:wrap;">
                                @if (!string.IsNullOrEmpty(answer.User?.ProfileImageUrl))
                                {
                                    <img src="@answer.User.ProfileImageUrl" alt="" class="q-avatar"
                                         style="width:28px;height:28px;border-radius:50%;flex-shrink:0;" />
                                }
                                else
                                {
                                    <img src="@AvatarHelper.Url(answer.User?.Name, 28)" alt=""
                                         style="width:28px;height:28px;border-radius:50%;flex-shrink:0;" />
                                }

                                <strong style="font-size:13px; color:var(--text);">@(answer.User?.Name?.Split(' ').First() ?? "User")</strong>
                                <span style="font-size:12px; color:var(--text-2);">@answer.CreatedAt.ToString("MMM dd, yyyy")</span>

                                @if (isAccepted)
                                {
                                    <span class="chip chip-emerald" style="display:inline-flex;align-items:center;gap:4px;margin-left:auto;">
                                        <i class="ph-fill ph-seal-check" style="font-size:12px;"></i> Best Answer
                                    </span>
                                }

                                @if (isPostOwner && !isAccepted)
                                {
                                    <button class="accept-btn" data-answer-id="@answer.AnswerID"
                                            title="Send Best Answer request to admin"
                                            style="background:none;border:1.5px solid var(--emerald);border-radius:8px;cursor:pointer;font-size:12px;color:var(--emerald);font-weight:700;display:inline-flex;align-items:center;gap:4px;padding:4px 12px;font-family:inherit;transition:all .2s;">
                                        <i class="ph-fill ph-seal-check" style="font-size:13px;"></i> Request Best Answer
                                        <span style="font-size:10px;opacity:.75;font-weight:600;">Admin approval required</span>
                                    </button>
                                }

                                <span style="flex:1;"></span>

                                @if (currentUserId.HasValue && answer.UserID == currentUserId.Value)
                                {
                                    <button type="button"
                                            onclick="openAnswerEdit(@answer.AnswerID)"
                                            style="background:none;border:none;cursor:pointer;font-size:11px;color:var(--text-3);display:inline-flex;align-items:center;gap:3px;font-family:inherit;padding:3px 6px;border-radius:4px;"
                                            title="Edit this answer">
                                        <i class="ph-duotone ph-pencil-simple" style="font-size:12px;"></i>
                                    </button>

                                    <button type="button"
                                            onclick="openDeleteAnswerModal(@answer.AnswerID)"
                                            style="background:none;border:none;cursor:pointer;font-size:11px;color:var(--text-3);display:inline-flex;align-items:center;gap:3px;font-family:inherit;padding:3px 6px;border-radius:4px;transition:color .2s;"
                                            onmouseover="this.style.color='#EF4444'"
                                            onmouseout="this.style.color='var(--text-3)'"
                                            title="Delete this answer">
                                        <i class="ph-duotone ph-trash-simple" style="font-size:12px;"></i>
                                    </button>
                                }

                                @if (currentUserId.HasValue && answer.UserID != currentUserId.Value)
                                {
                                    <button onclick="openReportModal(@answer.AnswerID, 'Answer')"
                                            style="@(isPostOwner && !isAccepted ? "" : "margin-left:auto;") background:none;border:none;cursor:pointer;font-size:11px;color:var(--text-3);display:inline-flex;align-items:center;gap:3px;font-family:inherit;padding:3px 6px;border-radius:4px;transition:color .2s;"
                                            onmouseover="this.style.color='#EF4444'" onmouseout="this.style.color='var(--text-3)'"
                                            title="Report this answer">
                                        <i class="ph-duotone ph-flag-pennant" style="font-size:12px;"></i>
                                    </button>
                                }
                            </div>

                            <!-- Answer view mode -->
                            <div id="answerViewMode-@answer.AnswerID">
                                <p style="font-size:14px; color:var(--text); line-height:1.75; margin:0; white-space:pre-wrap; overflow-wrap:break-word; word-break:break-word;">@answer.Content</p>

                                @if (!string.IsNullOrEmpty(answer.ImageUrl))
                                {
                                    <div style="margin-top:12px; border-radius:8px; overflow:hidden; border:1px solid var(--border); max-width:400px;">
                                        <img src="@answer.ImageUrl" alt="" style="max-width:100%; display:block; cursor:pointer;" onclick="window.open(this.src)" />
                                    </div>
                                }
                            </div>

                            <!-- Answer edit mode -->
                            @if (currentUserId.HasValue && answer.UserID == currentUserId.Value)
                            {
                                <form id="editAnswerBox-@answer.AnswerID"
                                      asp-action="EditAnswer"
                                      asp-controller="Answer"
                                      method="post"
                                      style="display:none; margin-top:12px;">
                                    @Html.AntiForgeryToken()

                                    <input type="hidden" name="answerId" value="@answer.AnswerID" />
                                    <input type="hidden" name="postId" value="@Model.PostID" />

                                    <textarea name="content"
                              rows="4"
                              class="form-input form-textarea"
                              style="width:100%; margin-bottom:8px;">@answer.Content</textarea>

                                    <div style="display:flex; gap:8px; margin-top:8px;">
                                        <button type="submit" class="btn btn-primary">Save</button>
                                        <button type="button"
                                                class="btn btn-ghost"
                                                onclick="cancelAnswerEdit(@answer.AnswerID)">
                                            Cancel
                                        </button>
                                    </div>
                                </form>
                            }
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div style="text-align:center; display:flex; flex-direction:column; align-items:center; padding:48px 20px; background:var(--surface); border-radius:var(--radius); border:1px solid var(--border); margin-bottom:32px;">
                <i class="ph-duotone ph-chat-dots" style="font-size:44px; color:var(--text-3); display:block; margin-bottom:12px;"></i>
                <p style="font-size:15px; font-weight:700; color:var(--text); margin:0 0 6px 0;">No answers yet</p>
                <p style="font-size:13px; color:var(--text-2); margin:0;">Be the first to help — scroll down to write your answer!</p>
            </div>
        }

        <!-- ── WRITE YOUR ANSWER ── -->
        @if (User.Identity?.IsAuthenticated == true)
        {
            <div id="answerBox" style="border-top:2px solid var(--border); padding-top:28px;">
                <h2 style="font-size:18px; font-weight:800; color:var(--text); margin:0 0 6px 0; display:flex; align-items:center; gap:8px;">
                    <i class="ph-bold ph-pencil-simple" style="font-size:18px; color:var(--indigo);"></i> Write Your Answer
                </h2>
                <p style="font-size:13px; color:var(--text-2); margin:0 0 18px 0;">
                    <i class="ph-fill ph-seal-check" style="font-size:13px; color:var(--emerald); vertical-align:middle; margin-right:4px;"></i>
                    Earn <strong>+15 pts</strong> if the asker requests your answer as best and an admin approves it!
                </p>

                <form asp-action="PostAnswer" asp-controller="Answer" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="postId" value="@Model.PostID" />

                    <textarea name="content" class="form-input form-textarea" rows="6"
                      style="margin-bottom:14px; resize:vertical;"
                      placeholder="Explain your answer clearly. Include steps, formulas, or examples if helpful."
                      required></textarea>

                    <div style="display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:12px;">
                        <label style="display:inline-flex; align-items:center; gap:8px; font-size:13px; color:var(--text-2); cursor:pointer;">
                            <i class="ph-duotone ph-image" style="font-size:16px;"></i>
                            <span>Attach image</span>
                            <input type="file" name="ImageFile" accept="image/*" style="display:none;" />
                        </label>
                        <button type="submit" class="btn btn-primary" style="display:inline-flex; align-items:center; gap:8px; padding:10px 28px; font-size:15px;">
                            <i class="ph-bold ph-paper-plane-tilt" style="font-size:17px;"></i> Post Answer
                        </button>
                    </div>
                </form>
            </div>
        }
        else
        {
            <div style="border-top:2px solid var(--border); padding-top:28px; text-align:center;">
                <p style="font-size:14px; color:var(--text-2); margin:0 0 12px 0;">Sign in to post an answer</p>
                <a asp-controller="Login" asp-action="Login_Page" class="btn btn-primary">Sign In</a>
            </div>
        }

        <!-- Hidden antiforgery for AJAX -->
        <form id="antiforgeryForm" style="display:none;">@Html.AntiForgeryToken()</form>


    }
    @if (User.Identity?.IsAuthenticated == true)
    {
        <button type="button"
                class="answer-fab"
                onclick="scrollToAnswerBox()"
                title="Write an answer">
            <i class="ph-bold ph-pencil-simple"></i>
        </button>
    }
</div>

<script>
     const deletePostModal = document.getElementById('deletePostModal');
     const openDeletePostBtn = document.getElementById('openDeletePostModalBtn');
     const cancelDeletePostBtn = document.getElementById('cancelDeletePostBtn');

     openDeletePostBtn?.addEventListener('click', () => {
         deletePostModal.classList.add('active');
         cancelDeletePostBtn?.focus();
     });

     cancelDeletePostBtn?.addEventListener('click', () => {
         deletePostModal.classList.remove('active');
     });

     deletePostModal?.addEventListener('click', e => {
         if (e.target === deletePostModal) {
             deletePostModal.classList.remove('active');
         }
     });

     document.addEventListener('keydown', e => {
         if (e.key === 'Escape') {
             deletePostModal?.classList.remove('active');
         }
     });
     function getToken() {
         var el = document.querySelector('#antiforgeryForm input[name="__RequestVerificationToken"]');
         return el ? el.value : '';
     }

     // ── Post upvote ──────────────────────────────────────────
     async function upvoteThisPost(postId) {
         var btn = document.getElementById('postUpvoteBtn');
         if (btn && btn.dataset.pending === '1') return;
         if (btn) btn.dataset.pending = '1';
         try {
             var resp = await fetch('/Post/UpvotePost', {
                 method: 'POST',
                 headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'RequestVerificationToken': getToken() },
                 body: 'postId=' + encodeURIComponent(postId)
             });
             var data = await resp.json();
             if (!resp.ok) { showToast(data.message || 'Could not upvote.', 'error'); return; }
             var count = document.getElementById('postUpvoteCount');
             if (count) count.textContent = data.upvotes;
             markPostUpvoted(data.voted);
         } catch { showToast('Failed to upvote. Try again.', 'error'); }
         finally { if (btn) btn.dataset.pending = '0'; }
     }

     function markPostUpvoted(voted) {
         var btn  = document.getElementById('postUpvoteBtn');
         var icon = document.getElementById('postUpvoteIcon');
         if (btn) {
             btn.style.borderColor = voted ? 'var(--indigo)' : '';
             btn.style.color       = voted ? 'var(--indigo)' : '';
             btn.style.background  = voted ? 'var(--indigo-light)' : '';
         }
         if (icon) { icon.className = voted ? 'ph-fill ph-thumbs-up' : 'ph-duotone ph-thumbs-up'; }
     }

     document.addEventListener('DOMContentLoaded', async function() {
         try {
             const res = await fetch('/api/user/votes');
             if (res.ok) {
                 const data = await res.json();
                 if ((data.postIds || []).includes(@Model.PostID)) markPostUpvoted(true);
                 (data.answerIds || []).forEach(id => {
                     var btn = document.querySelector(`.upvote-btn[data-answer-id="${id}"]`);
                     if (btn) markVoted(btn);
                 });
             }
         } catch { /* silent */ }
     });

     // ── Session Request ──────────────────────────────────────
     let _recipientId, _postId;
     function openSessionModal(recipientId, postId) {
         _recipientId = recipientId; _postId = postId;
         document.getElementById('sessionModal').style.display = 'block';
     }
     async function submitSessionRequest() {
         const description = document.getElementById('sessionDescription').value.trim();
         if (!description) { showToast('Please describe what you need help with.', 'error'); return; }
         try {
             const res = await fetch('/Session/SendRequest', {
                 method: 'POST',
                 headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'RequestVerificationToken': getToken() },
                 body: `recipientId=${_recipientId}&postId=${_postId}&description=${encodeURIComponent(description)}`
             });
             const data = await res.json();
             showToast(data.message || 'Request sent!', res.ok ? 'success' : 'error');
             document.getElementById('sessionModal').style.display = 'none';
             document.getElementById('sessionDescription').value = '';
         } catch { showToast('Could not send request. Try again.', 'error'); }
     }

     // ── Answer Upvotes ────────────────────────────────────────
     document.querySelectorAll('.upvote-btn').forEach(function(btn) {
         var id = btn.dataset.answerId;

         btn.addEventListener('click', async function() {
             if (btn.dataset.pending === '1') return;
             btn.dataset.pending = '1';
             try {
                 var resp = await fetch('@Url.Action("UpvoteAnswer", "Answer")', {
                     method: 'POST',
                     headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'RequestVerificationToken': getToken() },
                     body: 'answerId=' + encodeURIComponent(id)
                 });
                 var data = await resp.json();
                 if (!resp.ok) {
                     showToast(data.message || 'Could not upvote.', 'error');
                     return;
                 }
                 var display = document.querySelector('[data-upvote-count="' + id + '"]');
                 if (display) display.textContent = data.upvotes;
                 setAnswerVoteState(btn, data.voted);
             } catch { showToast('Failed to upvote. Try again.', 'error'); }
             finally { btn.dataset.pending = '0'; }
         });
     });

     function markVoted(btn) { setAnswerVoteState(btn, true); }

     function setAnswerVoteState(btn, voted) {
         var icon = btn.querySelector('i');
         btn.style.background  = voted ? 'var(--indigo-light)' : '';
         btn.style.borderColor = voted ? 'var(--indigo)' : '';
         btn.style.color       = voted ? 'var(--indigo)' : '';
         btn.style.cursor      = 'pointer';
         if (icon) { icon.className = voted ? 'ph-fill ph-thumbs-up' : 'ph-duotone ph-thumbs-up'; }
         btn.title = voted ? 'Click to remove upvote' : 'Upvote this answer';
     }

     // ── Report content ────────────────────────────────────────
     let _reportTargetId, _reportTargetType;
     function openReportModal(targetId, targetType) {
         _reportTargetId = targetId; _reportTargetType = targetType;
         document.getElementById('reportReason').value = '';
         document.getElementById('reportModal').style.display = 'block';
         document.getElementById('reportModal').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
     }
     function closeReportModal() {
         document.getElementById('reportModal').style.display = 'none';
     }
     async function submitReport() {
         const reason = document.getElementById('reportReason').value.trim();
         if (!reason) { showToast('Please describe why you are reporting this.', 'error'); return; }
         try {
             const res = await fetch('/Post/ReportContent', {
                 method: 'POST',
                 headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'RequestVerificationToken': getToken() },
                 body: `targetId=${_reportTargetId}&targetType=${_reportTargetType}&reason=${encodeURIComponent(reason)}`
             });
             const data = await res.json();
             if (data.success) {
                 showToast('Report submitted. Thank you!', 'success');
                 closeReportModal();
             } else {
                 showToast(data.message || 'Could not submit report.', 'error');
             }
         } catch { showToast('Could not submit report. Try again.', 'error'); }
     }

     // ── Image attach label ────────────────────────────────────
     document.querySelector('label input[type="file"]')?.addEventListener('change', function() {
         var label = this.closest('label').querySelector('span');
         if (label) label.textContent = this.files[0]?.name || 'Attach image';
     });

     // ── Accept Answer ─────────────────────────────────────────
     document.querySelectorAll('.accept-btn').forEach(function(btn) {
         btn.addEventListener('click', async function() {
             var id = btn.dataset.answerId;
             try {
                 var resp = await fetch('@Url.Action("AcceptAnswer", "Answer")', {
                     method: 'POST',
                     headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'RequestVerificationToken': getToken() },
                     body: 'answerId=' + encodeURIComponent(id)
                 });
                 if (!resp.ok) throw new Error();
          showToast('Best Answer request sent to admin for approval.', 'success');
                 setTimeout(() => window.location.reload(), 800);
             } catch { showToast('Could not accept answer. Please try again.', 'error'); }
         });
     });
              function openPostEdit() {
         const view = document.getElementById('postViewMode');
         const edit = document.getElementById('postEditMode');
         const btn = document.getElementById('editPostBtn');

         if (view) view.style.display = 'none';
         if (edit) edit.style.display = 'block';
         if (btn) btn.style.display = 'none';
     }

     function cancelPostEdit() {
         const view = document.getElementById('postViewMode');
         const edit = document.getElementById('postEditMode');
         const btn = document.getElementById('editPostBtn');

         if (edit) edit.style.display = 'none';
         if (view) view.style.display = 'block';
         if (btn) btn.style.display = 'inline-flex';
     }

     function openAnswerEdit(answerId) {
         const view = document.getElementById('answerViewMode-' + answerId);
         const edit = document.getElementById('editAnswerBox-' + answerId);

         if (view) view.style.display = 'none';
         if (edit) edit.style.display = 'block';
     }

     function cancelAnswerEdit(answerId) {
         const view = document.getElementById('answerViewMode-' + answerId);
         const edit = document.getElementById('editAnswerBox-' + answerId);

         if (edit) edit.style.display = 'none';
         if (view) view.style.display = 'block';
     }

    document.getElementById('editPostImageInput')?.addEventListener('change', function () {
         const label = document.getElementById('editPostImageFileName');
         if (label) {
             label.textContent = this.files?.[0]?.name || 'Choose new image';
         }
     });
     function openDeleteAnswerModal(answerId) {
         document.getElementById('deleteAnswerIdInput').value = answerId;
         document.getElementById('deleteAnswerModal').classList.add('active');
      }

     function closeDeleteAnswerModal() {
         document.getElementById('deleteAnswerModal').classList.remove('active');
     }

     document.getElementById('deleteAnswerModal')
         ?.addEventListener('click', function (e) {
             if (e.target === this) {
                 closeDeleteAnswerModal();
             }
         });

    function scrollToAnswerBox() {
         const answerBox = document.getElementById('answerBox');
         const textarea = answerBox?.querySelector('textarea[name="content"]');

         if (!answerBox) return;

         answerBox.scrollIntoView({
             behavior: 'smooth',
             block: 'start'
         });

         setTimeout(() => {
             textarea?.focus();
         }, 450);
     }
</script>



@model Uni_Connect.Models.User
@using Uni_Connect.Models
@{
    ViewData["Title"] = "Search — UniConnect";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";

    var query = ViewBag.Query as string ?? "";
    var results = ViewBag.Results as List<Post> ?? new List<Post>();
    var users = ViewBag.UserResults as List<User> ?? new List<User>();
    var currentTab = ViewBag.CurrentTab as string ?? "posts";
}

@section Styles {
    <link href="~/css/search.css" rel="stylesheet" />
    <style>
        .search-tabs {
            display: flex;
            gap: 10px;
            margin-top: 18px;
            justify-content: center;
        }

        .search-tab {
            padding: 10px 18px;
            border-radius: 999px;
            background: var(--surface);
            color: var(--text-2);
            font-size: 14px;
            font-weight: 700;
            text-decoration: none;
            border: 1px solid var(--border);
        }

            .search-tab.active {
                background: var(--indigo);
                color: white;
                border-color: var(--indigo);
            }</style>
}

<div class="search-wrapper">

    <!-- Search Bar -->
    <div class="search-hero">
        <h1>Search Questions</h1>
        <form method="get" asp-controller="Search" asp-action="Search" class="search-bar">
            <input type="text" name="q" class="search-input"
                   placeholder="Search by title, content, or category…"
                   value="@query" autofocus autocomplete="off" />
            <button type="submit" class="btn btn-primary" style="display:inline-flex; align-items:center; gap:6px;">
                <i class="ph-bold ph-magnifying-glass" style="font-size:16px;"></i> Search
            </button>
        </form>
        @if (!string.IsNullOrWhiteSpace(query))
        {
            <div class="search-tabs">
                <a class="search-tab @(currentTab == "posts" ? "active" : "")"
                   asp-controller="Search"
                   asp-action="Search"
                   asp-route-q="@query"
                   asp-route-tab="posts">
                    Posts (@results.Count)
                </a>

                <a class="search-tab @(currentTab == "users" ? "active" : "")"
                   asp-controller="Search"
                   asp-action="Search"
                   asp-route-q="@query"
                   asp-route-tab="users">
                    Accounts (@users.Count)
                </a>
            </div>
        }
    </div>

    @if (!string.IsNullOrWhiteSpace(query))
    {
        <div class="results-header">
            @if (currentTab == "posts" && results.Any())
            {
                <text>Found <span>@results.Count result@(results.Count == 1 ? "" : "s")</span> for "<span>@query</span>"</text>
            }
            else
            {
                <text>Found <span>@users.Count account@(users.Count == 1 ? "" : "s")</span> for "<span>@query</span>"</text>
            }
        </div>
    }
    @if (currentTab == "posts" && results.Any())
    {
        foreach (var post in results)
        {
            var isSolved = post.Answers?.Any(a => a.IsAccepted && !a.IsDeleted) == true;
            var snippet = string.IsNullOrEmpty(post.Content) ? "" : (post.Content.Length > 110 ? post.Content[..110] + "…" : post.Content);
            var authorName = post.User?.Name?.Split(' ').First() ?? "User";



            <a href="@Url.Action("SinglePost", "Post", new { id = post.PostID })" class="result-card">
                <div class="result-preview">
                    <div class="result-main">
                        <div class="result-title">@post.Title</div>

                        @if (!string.IsNullOrEmpty(snippet))
                        {
                            <div class="result-snippet">@snippet</div>
                        }

                        <div class="result-stats">
                            <span><i class="ph-duotone ph-thumbs-up"></i> @post.Upvotes</span>
                            <span><i class="ph-duotone ph-chat-dots"></i> @(post.Answers?.Count(a => !a.IsDeleted) ?? 0) answers</span>
                            <span><i class="ph-duotone ph-eye"></i> @post.ViewsCount views</span>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(post.ImageUrl))
                    {
                        <div class="result-thumb">
                            <img src="@post.ImageUrl" alt="" />
                        </div>
                    }
                </div>
            </a>
        }
    }
    @if (currentTab == "users" && users.Any())
    {
        foreach (var account in users)
        {
            <a href="@Url.Action("ViewProfile", "Profile", new { username = account.Username })" class="result-card">
                <div class="result-preview">
                    <div style="display:flex;align-items:center;gap:14px;">
                        @if (!string.IsNullOrEmpty(account.ProfileImageUrl))
                        {
                            <img src="@account.ProfileImageUrl" alt=""
                                 style="width:48px;height:48px;border-radius:50%;object-fit:cover;" />
                        }
                        else
                        {
                            <img src="@AvatarHelper.Url(account.Name, 48)" alt=""
                                 style="width:48px;height:48px;border-radius:50%;" />
                        }

                        <div>
                            <div class="result-title">@account.Name</div>
                            <div class="result-snippet">
                                @account.UniversityID · @account.Faculty · Year @account.YearOfStudy
                            </div>
                            <div class="result-stats">
                                <span><i class="ph-duotone ph-user"></i> @account.Username</span>
                                <span><i class="ph-duotone ph-star"></i> @account.Points points</span>
                            </div>
                        </div>
                    </div>
                </div>
            </a>
        }
    }
    else if (currentTab == "users" && !string.IsNullOrWhiteSpace(query))
    {
        <div class="empty-search">
            <i class="ph-duotone ph-user-minus" style="font-size:48px; color:var(--text-3); margin-bottom:16px;"></i>
            <h3 style="font-size:16px; font-weight:700; margin-bottom:8px;">No accounts found</h3>
            <p style="font-size:14px; color:var(--text-2);">
                No student account matches "<strong>@query</strong>".
            </p>
        </div>
    }
    else if (currentTab == "posts" && !results.Any() && !string.IsNullOrWhiteSpace(query))
    {
        <div class="empty-search">
            <i class="ph-duotone ph-magnifying-glass-minus" style="font-size:48px; color:var(--text-3); margin-bottom:16px;"></i>
            <h3 style="font-size:16px; font-weight:700; margin-bottom:8px;">No results found</h3>
            <p style="font-size:14px; color:var(--text-2); margin-bottom:20px;">
                No questions match "<strong>@query</strong>". Try different keywords or browse all questions.
            </p>
            <a asp-action="Dashboard" class="btn btn-primary" style="display:inline-flex; align-items:center; gap:8px;">
                <i class="ph-duotone ph-list-bullets" style="font-size:16px;"></i> Browse All Questions
            </a>
            <div style="margin-top:20px;">
                <p style="font-size:13px;color:var(--text-2);margin-bottom:12px;">
                    Nobody has asked this yet — be the first!
                </p>
                <a asp-controller="Post" asp-action="CreatePost"
                   class="btn btn-primary btn-sm"
                   style="display:inline-flex;align-items:center;gap:8px;">
                    <i class="ph-bold ph-pencil-simple" style="font-size:14px;"></i>
                    Ask this Question
                </a>
            </div>
        </div>
    }
    else
    {
        <div class="empty-search">
            <i class="ph-duotone ph-magnifying-glass" style="font-size:48px; color:var(--text-3); margin-bottom:16px;"></i>
            <h3 style="font-size:16px; font-weight:700; margin-bottom:8px;">Start your search</h3>
            <p style="font-size:14px; color:var(--text-2);">
                Search for any question, topic, or category in the community.
            </p>
        </div>
    }

</div>

@model Uni_Connect.Models.User
@{
    ViewData["Title"] = "Leaderboard — UniConnect";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}
<style>
    :root {
        --indigo: #3D52A0; --indigo-dark: #2d3f7a; --indigo-light: #EEF2FF;
        --violet: #7091E6; --violet-light: #EDE9FE;
        --amber: #F59E0B; --amber-light: #FEF3C7;
        --bg: #F8F9FF; --surface: #fff; --border: #E2E8F0;
        --text: #0F172A; --text-2: #64748B;
        --radius: 12px;
    }

    body { background: var(--bg); color: var(--text); }
    .app-wrap { max-width: 1440px; margin: 0 auto; display: grid; grid-template-columns: 260px 1fr; gap: 24px; padding: 24px 5%; min-height: calc(100vh - 64px); }
    
    .sidebar { position: sticky; top: 24px; height: fit-content; }
    .sidebar-user { display: flex; align-items: center; gap: 12px; padding: 12px; border-radius: 16px; background: var(--surface); border: 1px solid var(--border); text-decoration: none; color: inherit; margin-bottom: 20px; }
    
    .nav-item { display: flex; align-items: center; gap: 12px; padding: 12px 16px; border-radius: 12px; font-size: 14px; font-weight: 700; color: var(--text-2); text-decoration: none; transition: all .2s; margin-bottom: 4px; }
    .nav-item:hover { background: var(--indigo-light); color: var(--indigo); }
    .nav-item.active { background: var(--indigo); color: #fff; box-shadow: 0 4px 12px rgba(61,82,160,0.15); }

    .podium-wrap { display: flex; align-items: flex-end; justify-content: center; gap: 20px; margin: 40px 0; flex-wrap: wrap; }
    .podium-card { background: var(--surface); border-radius: 20px; padding: 24px; text-align: center; border: 1.5px solid var(--border); width: 200px; }
    .podium-1st { width: 240px; border-color: var(--amber); box-shadow: 0 12px 32px rgba(245,158,11,0.1); border-width: 2.5px; z-index: 2; }
    
    .table-row { display: flex; align-items: center; padding: 16px 20px; background: var(--surface); border: 1px solid var(--border); margin-bottom: 8px; border-radius: 12px; transition: all .2s; }
    .table-row:hover { border-color: var(--indigo); transform: translateX(4px); }
    
    .rank-num { font-weight: 900; font-size: 18px; width: 40px; }
    .student-info { flex: 1; display: flex; align-items: center; gap: 12px; }
</style>
}

<div class="app-wrap">
    <aside class="sidebar">
        <a asp-action="Profile" class="sidebar-user">
            <div class="av av-md">
                <img src="https://ui-avatars.com/api/?name=@Model.Name&background=3D52A0&color=fff&size=44" alt="@Model.Name" />
            </div>
            <div>
                <div class="sidebar-user-name" style="font-weight:800; font-size:15px">@Model.Name</div>
                <div class="sidebar-user-pts" style="color:var(--amber); font-weight:700; font-size:13px">🪙 @Model.Points pts</div>
            </div>
        </a>

        <nav class="sidebar-nav">
            <a asp-action="Dashboard" class="nav-item"><span class="ni">🏠</span>Home Feed</a>
            <a asp-action="CreatePost" class="nav-item"><span class="ni">✏️</span>Ask a Question</a>
            <a asp-action="Sessions" class="nav-item"><span class="ni">💬</span>My Sessions</a>
            <a asp-action="Leaderboard" class="nav-item active"><span class="ni">🏆</span>Leaderboard</a>
            <a asp-action="Notifications" class="nav-item"><span class="ni">🔔</span>Notifications</a>
            <a asp-action="Profile" class="nav-item"><span class="ni">👤</span>My Profile</a>
        </nav>
    </aside>

    <main class="main">
        <div style="display:flex; justify-content:space-between; align-items:flex-end; margin-bottom:32px">
            <div>
                <h1 style="font-size:28px; font-weight:900; letter-spacing:-0.5px">🏆 Leaderboard</h1>
                <p style="color:var(--text-2); font-size:15px">Top contributors at Philadelphia University</p>
            </div>
            <div style="display:flex; gap:12px">
                <select class="form-input" style="width:160px; font-size:13px; font-weight:600"><option>All Faculties</option><option>IT Faculty</option></select>
                <select class="form-input" style="width:140px; font-size:13px; font-weight:600"><option>This Month</option></select>
            </div>
        </div>

        <!-- YOUR RANK BANNER -->
        <div style="background:linear-gradient(90deg, var(--indigo-light), var(--violet-light)); border:1.5px solid #C7D7FF; border-radius:16px; padding:20px 24px; margin-bottom:40px; display:flex; align-items:center; gap:20px">
            <div style="font-size:32px">🏅</div>
            <div style="flex:1">
                <div style="font-weight:800; font-size:16px; color:var(--indigo)">You are ranked #6 overall!</div>
                <div style="font-size:14px; color:var(--text-2); font-weight:600">Keep helping classmates to climb the leaderboard.</div>
            </div>
            <div style="text-align:right">
                <div style="font-weight:900; font-size:20px; color:var(--indigo)">@Model.Points</div>
                <div style="font-size:11px; text-transform:uppercase; font-weight:800; color:var(--text-2); letter-spacing:0.5px">Total Points</div>
            </div>
        </div>

        <!-- PODIUM -->
        <div class="podium-wrap">
            <div class="podium-card" style="order:1">
                <div style="font-size:32px; margin-bottom:12px">🥈</div>
                <div class="av av-lg" style="margin:0 auto 16px; border:3px solid #E2E8F0"><img src="https://i.pravatar.cc/60?img=20" alt="Mona" style="border-radius:50%"></div>
                <div style="font-weight:800; font-size:15px">Mona A.</div>
                <div style="font-size:12px; color:var(--text-2); font-weight:600">Business</div>
                <div style="font-size:20px; font-weight:900; color:var(--amber); margin-top:8px">1,080</div>
            </div>
            <div class="podium-card podium-1st" style="order:2">
                <div style="font-size:40px; margin-bottom:12px">🥇</div>
                <div class="av av-xl" style="margin:0 auto 16px; border:4px solid var(--amber)"><img src="https://i.pravatar.cc/80?img=65" alt="Sami" style="border-radius:50%"></div>
                <div style="font-weight:900; font-size:17px">Sami T. ✓</div>
                <div style="color:var(--emerald); font-size:12px; font-weight:800; text-transform:uppercase; letter-spacing:0.5px">Verified Tutor</div>
                <div style="font-size:28px; font-weight:900; color:var(--amber); margin-top:8px">1,240</div>
            </div>
            <div class="podium-card" style="order:3">
                <div style="font-size:32px; margin-bottom:12px">🥉</div>
                <div class="av av-lg" style="margin:0 auto 16px; border:3px solid #E2E8F0"><img src="https://i.pravatar.cc/60?img=47" alt="Rania" style="border-radius:50%"></div>
                <div style="font-weight:800; font-size:15px">Rania K.</div>
                <div style="font-size:12px; color:var(--text-2); font-weight:600">IT Faculty</div>
                <div style="font-size:20px; font-weight:900; color:var(--amber); margin-top:8px">960</div>
            </div>
        </div>

        <!-- FULL RANKINGS TABLE -->
        <div style="margin-top:40px">
            <div class="table-row" style="background:var(--indigo-light); border-color:var(--indigo)">
                <div class="rank-num" style="color:var(--indigo)">#6</div>
                <div class="student-info">
                    <div class="av av-sm"><img src="https://ui-avatars.com/api/?name=@Model.Name&background=3D52A0&color=fff&size=36" style="border-radius:50%" /></div>
                    <div>
                        <div style="font-weight:800; font-size:14px; color:var(--indigo)">@Model.Name (YOU)</div>
                        <div style="font-size:11px; color:var(--text-2); font-weight:600">@Model.Faculty</div>
                    </div>
                </div>
                <div style="font-weight:900; font-size:16px; color:var(--indigo)">@Model.Points pts</div>
            </div>
            <!-- Mock others -->
            <div class="table-row">
                <div class="rank-num">#4</div>
                <div class="student-info">
                    <div class="av av-sm"><img src="https://i.pravatar.cc/36?img=33" alt="Khalid" style="border-radius:50%"></div>
                    <div>
                        <div style="font-weight:800; font-size:14px">Khalid M.</div>
                        <div style="font-size:11px; color:var(--text-2); font-weight:600">Business</div>
                    </div>
                </div>
                <div style="font-weight:900; font-size:16px">912 pts</div>
            </div>
            <div class="table-row">
                <div class="rank-num">#5</div>
                <div class="student-info">
                    <div class="av av-sm"><img src="https://i.pravatar.cc/36?img=48" alt="Lina" style="border-radius:50%"></div>
                    <div>
                        <div style="font-weight:800; font-size:14px">Lina H.</div>
                        <div style="font-size:11px; color:var(--text-2); font-weight:600">Engineering</div>
                    </div>
                </div>
                <div style="font-weight:900; font-size:16px">892 pts</div>
            </div>
        </div>
    </main>
</div>
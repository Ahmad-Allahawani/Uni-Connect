        'OOP', 'design-patterns', 'UML', 'operating-systems', 'process-scheduling',
        'memory-management', 'file-systems', 'compilers', 'automata', 'formal-languages',
        'computer-architecture', 'assembly', 'discrete-math',

        // Software Engineering
        'software-engineering', 'SDLC', 'agile', 'scrum', 'requirements-engineering',
        'software-testing', 'unit-testing', 'software-design', 'MVC', 'REST-API',
        'version-control', 'git', 'DevOps', 'CI-CD', 'microservices', 'clean-code',

        // Information Security & Cybersecurity
        'cybersecurity', 'information-security', 'cryptography', 'encryption',
        'network-security', 'ethical-hacking', 'penetration-testing', 'firewalls',
        'SSL-TLS', 'authentication', 'authorization', 'digital-forensics',
        'malware-analysis', 'vulnerability', 'OWASP', 'cyber-law',

        // Data Science & AI
        'artificial-intelligence', 'machine-learning', 'deep-learning', 'neural-networks',
        'data-science', 'data-mining', 'NLP', 'computer-vision', 'regression',
        'classification', 'clustering', 'decision-trees', 'random-forest',
        'pandas', 'numpy', 'scikit-learn', 'TensorFlow', 'big-data', 'data-visualization',

        // Databases & Networking
        'database', 'SQL', 'NoSQL', 'MySQL', 'Oracle', 'normalization', 'ER-diagram',
        'transactions', 'indexing', 'networking', 'TCP-IP', 'OSI-model', 'routing',
        'subnetting', 'DNS', 'HTTP', 'wireless-networks', 'cloud-computing',

        // ─── Faculty of Engineering & Technology ─────────────────────────
        // General Engineering
        'engineering-math', 'statics', 'dynamics', 'thermodynamics', 'fluid-mechanics',
        'materials-science', 'engineering-drawing', 'CAD', 'simulation',

        // Civil Engineering
        'civil-engineering', 'structural-analysis', 'concrete-design', 'steel-design',
        'soil-mechanics', 'geotechnical', 'surveying', 'hydrology', 'transportation',
        'construction-management', 'AutoCAD',

        // Electrical Engineering
        'electrical-engineering', 'circuit-analysis', 'Kirchhoff', 'AC-DC',
        'transformers', 'electric-machines', 'power-systems', 'control-systems',
        'PLC', 'signal-processing', 'digital-electronics', 'logic-gates',
        'microcontrollers', 'Arduino', 'Raspberry-Pi',

        // Communications & Electronic Engineering
        'communications', 'electronics', 'analog-circuits', 'digital-circuits',
        'semiconductor', 'amplifiers', 'modulation', 'antenna', 'signal-theory',
        'VLSI', 'embedded-systems', 'PCB-design',

        // Mechanical Engineering
        'mechanical-engineering', 'mechanics', 'heat-transfer', 'manufacturing',
        'machine-design', 'vibration', 'CNC', 'robotics', 'MATLAB',

        // Mechatronics
        'mechatronics', 'sensors', 'actuators', 'automation', 'hydraulics',
        'pneumatics', 'control-theory', 'feedback-systems',

        // Renewable & Alternative Energy
        'renewable-energy', 'solar-energy', 'wind-energy', 'energy-storage',
        'power-electronics', 'smart-grid', 'sustainability', 'energy-audit',


        'AutoCAD', 'Revit', 'SketchUp', '3ds-Max', 'BIM', 'rendering',
        'interior-design', 'space-planning', 'color-theory', 'lighting-design',
        'furniture-design', 'materials-finishes',
        'animation', 'multimedia', '2D-animation', '3D-animation', 'motion-graphics',
        'video-editing', 'Adobe-Premiere', 'After-Effects', 'Maya', 'Blender',
        'graphic-design', 'typography', 'Photoshop', 'Illustrator',

        // ─── Faculty of Arts & Educational Sciences ──────────────────────
        'Arabic-literature', 'Arabic-grammar', 'Arabic-rhetoric', 'classical-Arabic',
        'English-literature', 'linguistics', 'applied-linguistics', 'phonetics',
        'translation', 'IELTS', 'academic-writing', 'research-writing',
        'Chinese-language', 'Mandarin',
        'counseling-psychology', 'psychology', 'cognitive-psychology',
        'behavioral-therapy', 'mental-health', 'educational-psychology',
        'educational-technology', 'curriculum-design', 'teaching-methods',

        // ─── Faculty of Law ──────────────────────────────────────────────
        'law', 'civil-law', 'criminal-law', 'constitutional-law', 'commercial-law',
        'international-law', 'administrative-law', 'Jordanian-law', 'legal-writing',
        'contract-law', 'labor-law', 'family-law', 'intellectual-property',
        'human-rights', 'public-law', 'private-law', 'litigation', 'jurisprudence',

        // ─── General / Cross-Faculty ─────────────────────────────────────
        'exam-prep', 'homework', 'project', 'lab', 'theory', 'concept',
        'graduation-project', 'research', 'presentation', 'report',
        'midterm', 'final-exam', 'quiz',
    ];

    function showTagSuggestions(val) {
        const box = document.getElementById('tag-suggestions');
        val = val.trim().toLowerCase();
        if (!val || val.length < 1) { box.style.display = 'none'; return; }

        const matches = TAG_SUGGESTIONS.filter(t =>
            t.toLowerCase().includes(val) && !tags.includes(t)
        ).slice(0, 6);

        if (!matches.length) { box.style.display = 'none'; return; }

        box.innerHTML = matches.map(t =>
            `<div onmousedown="pickTagSuggestion('${t}')"
                  style="padding:10px 16px; cursor:pointer; font-size:13px; font-weight:600;
                         color:var(--text-1); border-bottom:1px solid var(--border);"
                  onmouseover="this.style.background='var(--indigo-light)'"
                  onmouseout="this.style.background=''">${escapeHtml(t)}</div>`
        ).join('');
        box.style.display = 'block';
    }

    function pickTagSuggestion(val) {
        if (!val || tags.length >= 5 || tags.includes(val)) return;
        tags.push(val);
        renderTags();
        updateTagPreview();
        document.getElementById('tags-hidden').value = tags.join(',');
        // Clear error once user adds a tag
        document.getElementById('err-tags').style.display = 'none';
        document.getElementById('tags-wrap').classList.remove('error');
    }

    function hideTagSuggestions() {
        // small delay so onmousedown on suggestion fires first
        setTimeout(() => {
            const box = document.getElementById('tag-suggestions');
            if (box) box.style.display = 'none';
        }, 150);
    }
    // State
    const state = { title: '', faculty: '', course: '', body: '', tags: [] };
    const tags = [];

    // Course code formatter: uppercase, strip non-alphanumeric
    function formatCourseCode(input) {
        const pos = input.selectionStart;
        const cleaned = input.value.toUpperCase().replace(/[^A-Z0-9]/g, '');
        if (input.value !== cleaned) {
            input.value = cleaned;
            input.setSelectionRange(pos, pos);
        }
    }

    // Character counter
    function updateCharCount(inputId, counterId, min, max) {
        const inp = document.getElementById(inputId);
        const cnt = document.getElementById(counterId);
        if (!inp || !cnt) return;
        const len = inp.value.length;
        cnt.textContent = len + '/' + max;
        cnt.className = 'char-counter char-counter-right';
        if (len === 0) return;
        if (len < min) cnt.classList.add('char-err');
        else if (len > max * 0.85) cnt.classList.add('char-warn');
        else cnt.classList.add('char-ok');
    }

    // Wizard progress
    function setProgress(step) {
        const pct = { 1: 16, 2: 50, 3: 83, 4: 100 }[step] || 16;
        const bar = document.getElementById('wz-progress');
        if (bar) bar.style.width = pct + '%';
    }

    // Step switcher
    function switchToStep(n) {
        [1, 2, 3, 4].forEach(i => {
            const el = document.getElementById('wz' + i);
            if (el) el.classList.add('hidden');
        });
        [1, 2, 3].forEach(i => {
            const dot = document.getElementById('ws' + i);
            if (!dot) return;
            dot.classList.remove('active', 'done');
            if (i === n) dot.classList.add('active');
            if (i < n) dot.classList.add('done');
        });
        const target = document.getElementById('wz' + n);
        if (target) {
            target.classList.remove('hidden');
            target.classList.add('fade-in');
        }
        const isSuccess = n === 4;
        const wb = document.getElementById('wizard-bar');
        const ph = document.getElementById('page-header');
        if (wb) wb.style.display = isSuccess ? 'none' : '';
        if (ph) ph.style.display = isSuccess ? 'none' : '';
        setProgress(n);
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }



        let searchDebounceTimer = null;

    function step1Search(val) {
        clearTimeout(searchDebounceTimer);

        const resultsPanel = document.getElementById('s1-results');
        const noResults    = document.getElementById('s1-no-results');
        const list         = document.getElementById('s1-results-list');

        val = val.trim();

        if (val.length < 3) {
            resultsPanel.classList.add('hidden');
            noResults.classList.add('hidden');
            return;
        }

        // Debounce — wait 350ms after user stops typing before hitting the server
        searchDebounceTimer = setTimeout(async () => {
            try {
                const res  = await fetch(`/Dashboard/SearchPostsJson?q=${encodeURIComponent(val)}`);
                const data = await res.json();

                list.innerHTML = '';

                if (data.results && data.results.length > 0) {
                    data.results.forEach(m => {
                        const el = document.createElement('a');
                        el.href = `/Dashboard/SinglePost/${m.id}`;
                        el.target = '_blank';
                        el.rel = 'noopener noreferrer';
                        el.style.cssText = 'display:block;background:#fff;border:1.5px solid var(--border);border-radius:12px;padding:14px 18px;margin-bottom:10px;text-decoration:none;cursor:pointer;color:inherit;transition:all .2s';
                        el.onmouseover = () => { el.style.borderColor = 'var(--indigo)'; el.style.boxShadow = '0 4px 16px rgba(61,82,160,.12)'; el.style.transform = 'translateY(-1px)'; };
                        el.onmouseout  = () => { el.style.borderColor = 'var(--border)'; el.style.boxShadow = 'none'; el.style.transform = 'none'; };
                        el.innerHTML = `
                            <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;margin-bottom:8px">
                                <span style="display:inline-flex;align-items:center;gap:4px;padding:3px 10px;border-radius:99px;font-size:11px;font-weight:700;
                                    background:${m.solved ? 'var(--emerald-light)' : '#EEF2FF'};
                                    color:${m.solved ? '#065F46' : 'var(--indigo)'}">
                                    ${m.solved ? '✓ Solved' : '? Open'}
                                </span>
                                ${m.course ? `<span style="display:inline-flex;padding:3px 10px;border-radius:99px;font-size:11px;font-weight:700;background:var(--violet-light);color:#5B21B6">${escapeHtml(m.course)}</span>` : ''}
                                ${m.faculty ? `<span style="display:inline-flex;padding:3px 10px;border-radius:99px;font-size:11px;font-weight:700;background:#F3F4F6;color:#374151">${escapeHtml(m.faculty)}</span>` : ''}
                                <span style="font-size:11px;color:var(--text-2);margin-left:auto">${m.answers} answer${m.answers !== 1 ? 's' : ''} · ${m.upvotes} votes</span>
                            </div>
                            <div style="font-size:14px;font-weight:700;color:var(--indigo)">${escapeHtml(m.title)}</div>
                            <div style="font-size:11px;color:var(--text-2);margin-top:6px;display:flex;align-items:center;gap:4px;">
                                <i class="ph-bold ph-arrow-square-out" style="font-size:11px;"></i> Click to view full answer in a new tab
                            </div>`;
                        list.appendChild(el);
                    });

                    resultsPanel.classList.remove('hidden');
                    noResults.classList.add('hidden');

                } else {
                    resultsPanel.classList.add('hidden');
                    noResults.classList.remove('hidden');
                }

            } catch (err) {
                console.error('Search failed:', err);
                resultsPanel.classList.add('hidden');
                noResults.classList.add('hidden');
            }
        }, 350);
    }

    function goToStep1() { switchToStep(1); }
    function goToStep2() { switchToStep(2); }

    // Step 2: Validation
    function validateStep2() {
        let ok = true;
        const title = document.getElementById('s2-title').value.trim();
        const faculty = document.getElementById('s2-faculty').value;
        const course = document.getElementById('s2-course').value.trim();
        const body = document.getElementById('s2-body').value.trim();

        function check(inputId, errId, value, minLen) {
            const errTag = document.getElementById('err-tags');
            const tagsWrap = document.getElementById('tags-wrap');
                if (tags.length === 0) {
                    if (tagsWrap) tagsWrap.classList.add('error');
                    if (errTag) errTag.style.display = 'block';
                    ok = false;
                } else {
                    if (tagsWrap) tagsWrap.classList.remove('error');
                    if (errTag) errTag.style.display = 'none';
                }
        }
        check('s2-title', 'err-title', title, 10);
        check('s2-faculty', 'err-faculty', faculty, 1);
        check('s2-course', 'err-course', course, 2);
        check('s2-body', 'err-body', body, 50);
        return ok;
    }

    function goToStep3() {
        if (!validateStep2()) {
            showToast('⚠️ Please fix the errors above', 'warn');
            const err = document.querySelector('.form-input.error');
            if (err) err.scrollIntoView({ behavior: 'smooth', block: 'center' });
            return;
        }
        state.title = document.getElementById('s2-title').value.trim();
        state.faculty = document.getElementById('s2-faculty').value;
        state.course = document.getElementById('s2-course').value.trim();
        state.body = document.getElementById('s2-body').value.trim();
        updatePreview();
        switchToStep(3);
    }

    // Preview
    function updateTitle() {
        state.title = document.getElementById('s2-title').value;
        updatePreview();
    }
    function updateBody() {
        state.body = document.getElementById('s2-body').value;
        updatePreview();
    }
    function updatePreview() {
        state.faculty = document.getElementById('s2-faculty').value;
        state.course = document.getElementById('s2-course').value;
        const fChip = document.getElementById('prev-faculty-chip');
        const cChip = document.getElementById('prev-course-chip');
        const prevTitle = document.getElementById('prev-title');
        const prevBody = document.getElementById('prev-body');
        if (fChip) fChip.textContent = state.faculty || 'Faculty';
        if (cChip) cChip.textContent = state.course || 'Course';
        if (prevTitle) prevTitle.textContent = state.title || 'Your question title will appear here...';
        if (prevBody) prevBody.textContent = state.body || 'Your question description will appear here...';
        updateTagPreview();
    }

    // Tags
    function handleTagInput(e) {
        const inp = document.getElementById('tags-input');
        if ((e.key === 'Enter' || e.key === ',') && inp) {
            e.preventDefault();
            addTag(inp.value.replace(',', '').trim());
            inp.value = '';
            document.getElementById('tag-suggestions').style.display = 'none';
        }
        if (e.key === 'Backspace' && inp && inp.value === '' && tags.length) {
            removeTag(tags.length - 1);
        }
    }
    function addTag(val) {
        if (!val || tags.length >= 5 || tags.includes(val)) return;
        tags.push(val);
        renderTags();
        updateTagPreview();
        document.getElementById('tags-hidden').value = tags.join(',');
    }
    function removeTag(i) {
        tags.splice(i, 1);
        renderTags();
        updateTagPreview();
        document.getElementById('tags-hidden').value = tags.join(',');
    }
    function renderTags() {
        const wrap = document.getElementById('tags-wrap');
        const inp = document.getElementById('tags-input');
        if (!wrap) return;
        wrap.querySelectorAll('.tag-chip').forEach(t => t.remove());
        tags.forEach((t, i) => {
            const chip = document.createElement('div');
            chip.className = 'tag-chip';
            chip.innerHTML = `${escapeHtml(t)}<button type="button" onclick="removeTag(${i})">×</button>`;
            wrap.insertBefore(chip, inp);
        });
    }
    function updateTagPreview() {
        const container = document.getElementById('prev-tags');
        if (!container) return;
        container.innerHTML = '';
        tags.forEach(t => {
            const chip = document.createElement('span');
            chip.className = 'chip chip-gray';
            chip.style.fontSize = '12px';
            chip.textContent = t;
            container.appendChild(chip);
        });
    }

    // --- Image Handling ---
    function previewSelectedImage(input) {
        const file = input.files[0];
        if (file) {
            if (file.size > 5 * 1024 * 1024) {
                showToast("File too large. Maximum 5MB.", "error");
                input.value = "";
                return;
            }
            const reader = new FileReader();
            reader.onload = function(e) {
                document.getElementById('image-preview-img').src = e.target.result;
                document.getElementById('image-preview-container').classList.remove('hidden');
                document.getElementById('image-upload-zone').classList.add('hidden');
                
                // Also update preview step
                document.getElementById('prev-image-display').src = e.target.result;
                document.getElementById('prev-image-wrap').classList.remove('hidden');
            }
            reader.readAsDataURL(file);
        }
    }

    function removeSelectedImage() {
        document.getElementById('image-input').value = "";
        document.getElementById('image-preview-img').src = "";
        document.getElementById('image-preview-container').classList.add('hidden');
        document.getElementById('image-upload-zone').classList.remove('hidden');
        
        document.getElementById('prev-image-display').src = "";
        document.getElementById('prev-image-wrap').classList.add('hidden');
    }

    // Step 3: Post
    async function postQuestion() {
        const unchecked = ['chk1', 'chk2', 'chk3', 'chk4'].filter(id => !document.getElementById(id).checked);
        if (unchecked.length) {
            showToast('⚠️ Please check all boxes before posting', 'warn');
            return;
        }

        const btn = document.getElementById('btn-post');
        if (btn.disabled) return;

        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Posting...';

        try {
            const formData = new FormData();
            
            // Add basic fields
            formData.append("Title", document.getElementById('s2-title').value);
            formData.append("Content", document.getElementById('s2-body').value);
            formData.append("Faculty", document.getElementById('s2-faculty').value);
            formData.append("CourseCode", document.getElementById('s2-course').value);
            formData.append("Tags", document.getElementById('tags-hidden').value);
            
            // Add file
            const imgInput = document.getElementById('image-input');
            if (imgInput.files.length > 0) {
                formData.append("ImageFile", imgInput.files[0]);
            }

            const response = await fetch('@Url.Action("CreatePost","Dashboard")', {
                method: 'POST',
                headers: {
                    'X-Requested-With': 'XMLHttpRequest',
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value
                },
                body: formData
            });

            if (response.status === 401) {
                window.location.href = '@Url.Action("Login_Page", "Login")';
                return;
            }

            const result = await response.json();
            if (result.success) {
                // Update global points if possible (sidebar)
                const sidebarPts = document.querySelector('.pts-badge .pts-num');
                if (sidebarPts && result.pointsBalance !== undefined) {
                    sidebarPts.textContent = result.pointsBalance;
                }
                
                // Show success step
                switchToStep(4);
                
                // Add link to the real post
                const successActions = document.querySelector('.success-action-buttons');
                if (successActions && result.postId) {
                    const viewBtn = document.createElement('a');
                    viewBtn.href = `/Dashboard/SinglePost/${result.postId}`;
                    viewBtn.innerHTML = '<button type="button" class="btn btn-emerald btn-lg" style="margin-bottom:10px; display:inline-flex; align-items:center; gap:8px;"><i class="ph-fill ph-eye" style="font-size:20px;"></i> View Your Question</button>';
                    successActions.insertBefore(viewBtn, successActions.firstChild);
                }
            } else {
                showToast(result.message || 'An error occurred.', 'error');
                btn.disabled = false;
                btn.innerHTML = '<i class="ph-bold ph-rocket" style="font-size:16px;"></i> Post Question <span class="btn-cost-label">(−10 pts)</span>';
            }
        } catch (err) {
            console.error(err);
            showToast('Failed to post. Check your connection.', 'error');
            btn.disabled = false;
            btn.innerHTML = '<i class="ph-bold ph-rocket" style="font-size:16px;"></i> Post Question <span class="btn-cost-label">(−10 pts)</span>';
        }
    }

    // Toast
    function showToast(msg, type = '') {
        document.querySelector('.toast')?.remove();
        const el = document.createElement('div');
        el.className = 'toast' + (type ? ' toast-' + type : '');
        el.innerHTML = msg;
        document.body.appendChild(el);
        setTimeout(() => {
            el.style.opacity = '0';
            el.style.transition = 'opacity .4s';
            setTimeout(() => el.remove(), 400);
        }, 3500);
    }

    // Utility
    function escapeHtml(str) {
        return String(str).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
    }

    // Init
    document.addEventListener('DOMContentLoaded', () => {
        setProgress(1);
    });
</script>

        'anatomy', 'biomechanics', 'neurological-rehab',
        'clinical-nutrition', 'dietetics', 'therapeutic-diet', 'nutritional-assessment',

        // ─── Faculty of Architecture & Design ───────────────────────────
        'architecture', 'architectural-design', 'building-design', 'urban-planning',

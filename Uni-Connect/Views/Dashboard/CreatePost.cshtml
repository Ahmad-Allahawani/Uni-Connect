@model Uni_Connect.ViewModels.CreatePostViewModel
@{
    ViewData["Title"] = "Ask a Question — UniConnect";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<!-- CreatePost Wizard View -->
<div class="post-wizard-main">

    <!-- Breadcrumb -->
    <div class="breadcrumb">
        <a asp-action="Dashboard" asp-controller="Dashboard"><i class="ph-fill ph-house" style="font-size:14px;"></i> Home</a>
        <span class="breadcrumb-sep">›</span>
        <span>Ask a Question</span>
    </div>

    <!-- Page header (hidden on success step) -->
    <div class="page-header" id="page-header">
        <h1 class="page-title"><i class="ph-duotone ph-pen-nib" style="font-size:28px;"></i> Ask a Question</h1>
        <p class="page-subtitle">
            Posting costs <strong class="cost-deducted">−10 pts</strong>.
            A great answer earns you <strong class="cost-earned">+5 to +15 pts</strong> back!
        </p>
    </div>

    <!-- Wizard progress bar -->
    <div class="wizard-wrap" id="wizard-bar">
        <div class="wizard-steps">
            <div class="wz-step active" id="ws1">
                <div class="wz-num">1</div>
                <span class="wz-label">Search First</span>
            </div>
            <div class="wz-step" id="ws2">
                <div class="wz-num">2</div>
                <span class="wz-label">Write Question</span>
            </div>
            <div class="wz-step" id="ws3">
                <div class="wz-num">3</div>
                <span class="wz-label">Preview & Post</span>
            </div>
        </div>
        <div class="wizard-progress">
            <div class="wizard-progress-fill" id="wz-progress"></div>
        </div>
    </div>

    <!-- STEP 1 — SEARCH FIRST -->
    <div class="fade-in" id="wz1">
        <div class="card search-card">
            <div class="search-card-header">
                <div class="search-icon-box"><i class="ph-duotone ph-magnifying-glass"></i></div>
                <div>
                    <div class="search-prompt-title">Check if your question already exists</div>
                    <div class="search-prompt-desc">
                        Search first — you might find an instant answer and save your
                        <strong class="points-highlight">10 pts</strong>.
                        Most questions have already been answered!
                    </div>
                </div>
            </div>
            <div class="search-input-row">
                <input autocomplete="off" class="form-input search-field" id="s1-search"
                       oninput="step1Search(this.value)"
                       placeholder="e.g. AVL tree rotation, trial balance, eigenvalues..." />
                <button type="button" class="btn btn-ghost btn-sm"
                        onclick="step1Search(document.getElementById('s1-search').value)">
                    <i class="ph-bold ph-magnifying-glass"></i> Search
                </button>
            </div>
        </div>

        <div class="hidden" id="s1-results">
            <div class="search-results-label">
                <span><i class="ph-duotone ph-copy"></i> Similar questions found — check these first:</span>
            </div>
            <div id="s1-results-list"></div>
            <div class="search-answer-tip">
                <span class="search-tip-icon"><i class="ph-fill ph-lightbulb"></i></span>
                <p class="amber-tip-text">
                    Is your question answered above?
                    <a class="amber-tip-link" href="#">Click to view the full answer</a>
                    and save your 10 pts!
                </p>
            </div>
        </div>

        <div class="hidden search-no-results" id="s1-no-results">
            <span class="search-no-results-icon"><i class="ph-fill ph-check-circle"></i></span>
            <p class="search-no-results-text">No similar questions found — yours is unique! Go ahead and post it.</p>
        </div>

        <div class="wizard-step-actions">
            <a href="@Url.Action("Dashboard", "Dashboard")"><button type="button" class="btn btn-ghost"><i class="ph-bold ph-arrow-left" style="font-size:14px;"></i> Cancel</button></a>
            <button type="button" class="btn btn-primary btn-lg" onclick="goToStep2()">
                My question is different <i class="ph-bold ph-arrow-right" style="font-size:14px;"></i> <span class="btn-cost-label">(−10 pts)</span>
            </button>
        </div>
    </div>

    <!-- STEP 2 — WRITE QUESTION -->
    <div class="hidden" id="wz2">
        <form id="create-post-form" method="post" asp-action="CreatePost" asp-controller="Dashboard">
            <div class="card">
                <!-- Title -->
                <div class="form-group">
                    <label class="form-label">Question Title <span class="form-label-req">*</span></label>
                    <input class="form-input" id="s2-title" asp-for="Title" maxlength="150"
                           oninput="updateTitle(); updateCharCount('s2-title', 'tc-title', 10, 150)"
                           placeholder="e.g. what is DFS ..." />
                    <div class="form-field-footer">
                        <div class="form-hint">Be specific — good: "How does AVL tree LL rotation work?" · bad: "help with AVL"</div>
                        <div class="char-counter char-counter-right" id="tc-title">0/150</div>
                    </div>
                    <div class="form-error" id="err-title">⚠ Please enter a question title (minimum 10 characters)</div>
                </div>

                <!-- Faculty + Course grid -->
                <div class="faculty-course-grid">
                    <div>
                        <label class="form-label">Faculty <span class="form-label-req">*</span></label>
                        <select class="form-input form-select" id="s2-faculty" asp-for="Faculty" onchange="updatePreview()">
                            <option value="">Select your faculty...</option>
                            <option value="IT Faculty">💻 Information Technology</option>
                            <option value="Engineering">⚙️ Engineering &amp; Technology</option>
                            <option value="Business">💼 Business &amp; Finance</option>
                            <option value="Science">🔬 Faculty of Science</option>
                            <option value="Pharmacy">💊 Faculty of Pharmacy</option>
                            <option value="Law">⚖️ Faculty of Law</option>
                            <option value="Arts">🎨 Arts &amp; Educational Sciences</option>
                        </select>
                        <div class="form-error" id="err-faculty">⚠ Please select your faculty</div>
                    </div>
                    <div>
                        <label class="form-label">Course Code <span class="form-label-req">*</span></label>
                        <input class="form-input" id="s2-course" asp-for="CourseCode" maxlength="10"
                               oninput="formatCourseCode(this); updatePreview()"
                               placeholder="e.g. CS302, MATH201, ACCT101"
                               autocomplete="off" spellcheck="false" />
                        <div class="form-hint">Letters + numbers only, auto-formatted uppercase (e.g. CS302)</div>
                        <div class="form-error" id="err-course">⚠ Please enter the course code</div>
                    </div>
                </div>

                <!-- Content -->
                <div class="form-group">
                    <label class="form-label">Describe Your Question <span class="form-label-req">*</span></label>
                    <textarea class="form-input form-textarea" id="s2-body" asp-for="Content" maxlength="2000"
                              oninput="updateBody(); updateCharCount('s2-body', 'tc-body', 50, 2000)"
                              placeholder="Explain your question clearly: • What are you trying to understand? • What have you tried? • Where are you stuck?"></textarea>
                    <div class="form-field-footer">
                        <div class="form-hint">Minimum 50 characters — more detail gets faster, better answers</div>
                        <div class="char-counter char-counter-right" id="tc-body">0/2000</div>
                    </div>
                    <div class="form-error" id="err-body">⚠ Please describe your question (minimum 50 characters)</div>
                </div>

                <!-- Tags -->
                <div class="form-group tags-form-group">
                    <label class="form-label">
                        Tags <span class="form-label-req">*</span>
                        <span class="form-label-note">(at least 1, max 5)</span>
                    </label>
                    <div class="tags-wrap" id="tags-wrap"
                         onclick="document.getElementById('tags-input').focus()">
                        <input class="tags-input" id="tags-input" maxlength="20"
                               onkeydown="handleTagInput(event)"
                               oninput="showTagSuggestions(this.value)"
                               onblur="hideTagSuggestions()"
                               placeholder="Type a tag and press Enter..." type="text" />
                    </div>
                    <!-- Suggestions dropdown -->
                    <div id="tag-suggestions" style="display:none; border:1.5px solid var(--border); border-radius:10px; background:#fff; box-shadow:var(--shadow-md); margin-top:4px; overflow:hidden; z-index:100; position:relative;"></div>
                    <div class="form-hint">Press Enter or comma to add. Examples: AVL, recursion, data-structures</div>
                    <div class="form-error" id="err-tags" style="display:none;">⚠ Please add at least one tag before continuing</div>
                </div>

                <!-- Image Upload -->
                <div class="form-group" style="margin-top:24px;">
                    <label class="form-label" style="display:flex; justify-content:space-between; align-items:center;">
                        <span>Add an image <span class="form-label-note">(optional)</span></span>
                        <span style="font-size:11px; color:var(--text-3);">Max 5MB • JPG, PNG</span>
                    </label>
                    
                    <div id="image-upload-zone" onclick="document.getElementById('image-input').click()" 
                         style="border:2px dashed var(--border); border-radius:12px; padding:24px; text-align:center; cursor:pointer; background:rgba(248,250,252,0.5); transition:all .2s ease; display:flex; flex-direction:column; align-items:center; gap:8px;">
                        <i class="ph-duotone ph-image-plus" style="font-size:32px; color:var(--text-3);"></i>
                        <span id="upload-status-text" style="font-size:13px; color:var(--text-2); font-weight:600;">Click to upload a diagram or screenshot</span>
                        <input type="file" id="image-input" name="ImageFile" accept="image/*" style="display:none;" onchange="previewSelectedImage(this)">
                    </div>

                    <div id="image-preview-container" class="hidden" style="margin-top:12px; position:relative; display:inline-block;">
                        <img id="image-preview-img" src="" style="max-width:100%; max-height:200px; border-radius:8px; border:1.5px solid var(--border); box-shadow:var(--shadow-sm);">
                        <button type="button" onclick="removeSelectedImage()" 
                                style="position:absolute; top:-10px; right:-10px; background:var(--rose); color:white; border:none; border-radius:50%; width:24px; height:24px; cursor:pointer; display:flex; align-items:center; justify-content:center; box-shadow:var(--shadow-sm);">
                            <i class="ph-bold ph-x" style="font-size:14px;"></i>
                        </button>
                    </div>
                </div>

                <!-- Hidden input for tags to submit with form -->
                <input type="hidden" id="tags-hidden" name="Tags" />
            </div>

            <div class="wizard-step-actions">
                <button type="button" class="btn btn-ghost" onclick="goToStep1()"><i class="ph-bold ph-arrow-left" style="font-size:14px;"></i> Back</button>
                <button type="button" class="btn btn-primary btn-lg" id="btn-preview" onclick="goToStep3()">Preview Question <i class="ph-bold ph-arrow-right" style="font-size:14px;"></i></button>
            </div>
        </form>
    </div>

    <!-- STEP 3 — PREVIEW & POST -->
    <div class="hidden" id="wz3">
        <div class="posting-cost-banner">
            <span class="posting-cost-icon"><i class="ph-fill ph-coins"></i></span>
            <div>
                <div class="posting-cost-title">This will cost 10 points</div>
                <div class="amber-tip-text">
                    Posting a question costs 10 pts. <strong>Best answers earn +15 pts back!</strong>
                </div>
            </div>
        </div>

        <div class="preview-section-label"><i class="ph-duotone ph-eye"></i> Preview — this is how your question will look:</div>

        <div class="card preview-post-card">
            <div class="preview-post-meta">
                <span class="preview-author-name">You</span>
                <span class="preview-post-time">· Just now</span>
                <span class="chip chip-indigo preview-faculty-badge" id="prev-faculty-chip"></span>
                <span class="chip chip-gray" id="prev-course-chip"></span>
            </div>
            <div class="preview-post-title" id="prev-title" style="overflow-wrap:break-word;word-break:break-word;">Your question title will appear here...</div>
            <div class="preview-post-body" id="prev-body" style="overflow-wrap:break-word;word-break:break-word;">Your question description will appear here...</div>
            
            <div id="prev-image-wrap" class="hidden" style="margin-top:16px;">
                <img id="prev-image-display" src="" style="max-width:100%; border-radius:12px; border:1px solid var(--border);">
            </div>

            <div class="preview-post-tags" id="prev-tags"></div>
            <div class="preview-post-stats">
                <span><i class="ph-duotone ph-thumbs-up"></i> 0</span>
                <span><i class="ph-duotone ph-chat-dots"></i> 0 answers</span>
                <span><i class="ph-duotone ph-eye"></i> 0 views</span>
                <span class="chip chip-gray preview-status-chip">Open</span>
            </div>
        </div>

        <div class="card checklist-card">
            <div class="checklist-heading"><i class="ph-fill ph-check-circle"></i> Before you post — quick checklist:</div>
            <div class="checklist-items">
                <label class="checklist-item">
                    <input class="checklist-checkbox" id="chk1" type="checkbox" />
                    My question title is clear and specific
                </label>
                <label class="checklist-item">
                    <input class="checklist-checkbox" id="chk2" type="checkbox" />
                    I described what I already tried and where I'm stuck
                </label>
                <label class="checklist-item">
                    <input class="checklist-checkbox" id="chk3" type="checkbox" />
                    The faculty and course code are correct
                </label>
                <label class="checklist-item">
                    <input class="checklist-checkbox" id="chk4" type="checkbox" />
                    I searched first and this question doesn't already exist
                </label>
            </div>
        </div>

        <div class="wizard-step-actions">
            <button type="button" class="btn btn-ghost" onclick="goToStep2()"><i class="ph-bold ph-arrow-left" style="font-size:14px;"></i> Edit Question</button>
            <button type="button" class="btn btn-primary btn-lg" id="btn-post" onclick="postQuestion()">
                <i class="ph-bold ph-rocket" style="font-size:16px;"></i> Post Question <span class="btn-cost-label">(−10 pts)</span>
            </button>
        </div>
    </div>

    <!-- STEP 4 — SUCCESS -->
    <div class="hidden fade-in" id="wz4">
        <div class="card success-card-body">
            <div class="success-icon-circle"><i class="ph-fill ph-confetti" style="font-size:48px;"></i></div>
            <h2 class="success-heading">Question posted!</h2>
            <p class="success-description">Your question is now live. The community will start answering soon.</p>
            <p class="success-points-summary">
                You were charged <strong class="cost-deducted">−10 pts</strong>.
            </p>

            <div class="earn-back-panel">
                <div class="earn-back-heading"><i class="ph-fill ph-coins" style="font-size:16px;margin-right:8px"></i>How to earn your points back:</div>
                <div class="earn-ways-list">
                    <span style="display:inline-flex;align-items:center;gap:8px;"><i class="ph-duotone ph-thumbs-up" style="font-size:14px;flex-shrink:0;"></i>Every upvote on any of your answers = <strong>+10 pts</strong></span>
                    <span style="display:inline-flex;align-items:center;gap:8px;"><i class="ph-fill ph-seal-check" style="font-size:14px;flex-shrink:0;"></i>If your answer is marked Best Answer = <strong>+15 pts</strong></span>
                    <span style="display:inline-flex;align-items:center;gap:8px;"><i class="ph-fill ph-graduation-cap" style="font-size:14px;flex-shrink:0;"></i>Accept a tutoring session = <strong>+20 pts</strong></span>
                </div>
            </div>

            <div class="success-action-buttons">
                <a asp-action="Dashboard" asp-controller="Dashboard"><button type="button" class="btn btn-primary btn-lg">Back to Home Feed</button></a>
            </div>
        </div>
    </div>

</div>

<!-- Wizard JavaScript -->
<script>

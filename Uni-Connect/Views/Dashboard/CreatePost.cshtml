        'computer-engineering', 'digital-design', 'FPGA', 'VHDL', 'hardware',
        'memory-systems', 'pipeline', 'cache',

        // ─── Faculty of Administrative & Financial Sciences (Business) ────
        'accounting', 'financial-accounting', 'managerial-accounting', 'auditing',
        'cost-accounting', 'trial-balance', 'journal-entries', 'balance-sheet',
        'income-statement', 'IFRS', 'tax',
        'finance', 'corporate-finance', 'investment', 'banking', 'Islamic-banking',
        'financial-analysis', 'bonds', 'stocks', 'portfolio', 'risk-management',
        'business-administration', 'management', 'HRM', 'organizational-behavior',
        'strategic-management', 'operations-management', 'supply-chain',
        'marketing', 'consumer-behavior', 'market-research', 'digital-marketing',
        'branding', 'sales',
        'business-law', 'contracts', 'e-commerce',
        'hospital-management', 'healthcare-admin', 'health-economics',

        // ─── Faculty of Science ───────────────────────────────────────────
        'calculus', 'linear-algebra', 'differential-equations', 'numerical-methods',
        'discrete-math', 'probability', 'statistics', 'real-analysis',
        'physics', 'mechanics-physics', 'electromagnetism', 'quantum-mechanics',
        'optics', 'modern-physics',
        'biotechnology', 'genetic-engineering', 'molecular-biology', 'genetics',
        'microbiology', 'cell-biology', 'biochemistry', 'DNA', 'PCR', 'bioinformatics',
        'clinical-nutrition', 'dietetics', 'nutrition-science',

        // ─── Faculty of Pharmacy ─────────────────────────────────────────
        'pharmacy', 'pharmacology', 'pharmacokinetics', 'drug-interactions',
        'medicinal-chemistry', 'organic-chemistry', 'inorganic-chemistry',

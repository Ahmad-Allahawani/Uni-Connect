    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>

    <script>
        // ================= USER INFO =================
        const me = {
            id:   parseInt(document.body.dataset.userid),
            name: document.body.dataset.username
        };
        const otherId = parseInt(document.body.dataset.otherid); 

       
        const ROOM_ID = String(0 + parseInt(me.id));
        
        // const ROOM_ID = [me.id, "rani"].sort((a, b) => a - b).join("-");

        // ================= SIGNALR SETUP =================
        let myConnectionId = null;

        let connection = new signalR.HubConnectionBuilder()
            .withUrl("/chatHub")
            .build();

        connection.start()
            .then(() => {
                myConnectionId = connection.connectionId;
                return connection.invoke("JoinRoom", ROOM_ID);
            })
            .then(() => loadHistory())
            .catch(err => console.error("Connection error:", err));

        // ================= RECEIVE MESSAGE =================
        connection.on("ReceiveMessage", (connectionId, senderId, message, time) => {
            const side = connectionId === myConnectionId ? "me" : "them";
            appendMessage(side, message, time);
        });

        // ================= SEND MESSAGE =================
        function sendMsg() {
            const inp = document.querySelector('.chat-input-bar input');
            const message = inp.value.trim();
            if (!message) return;

            connection.invoke("SendMessage", ROOM_ID, message)
                .catch(err => console.error(err.toString()));

            inp.value = "";
        }

        // ================= LOAD HISTORY =================
        async function loadHistory() {
            const res = await fetch(`/api/messages/${ROOM_ID}`);
            const messages = await res.json();

            messages.forEach(msg => {
                appendMessage(
                    msg.senderId === me.id ? "me" : "them",
                    msg.content,
                    msg.time
                );
            });
        }

        // ================= APPEND MESSAGE =================
        function appendMessage(side, content, time) {
            const msgs = document.querySelector('.chat-messages');
            const wrapper = document.createElement('div');

            if (side === "me") {
                wrapper.style.cssText = "display:flex;flex-direction:column;align-items:flex-end";
                wrapper.innerHTML = `
                    <div class="msg msg-me">${escapeHtml(content)}</div>
                    <div class="msg-time" style="text-align:right">${time}</div>
                `;
            } else {
                wrapper.className = "div_cls_22";
                wrapper.innerHTML = `
                    <div class="av av-sm"><img src="https://i.pravatar.cc/36" /></div>
                    <div>
                        <div class="msg msg-them">${escapeHtml(content)}</div>
                        <div class="msg-time">${time}</div>
                    </div>
                `;
            }

            msgs.appendChild(wrapper);
            msgs.scrollTop = msgs.scrollHeight;
        }
        // ==================================

        function escapeHtml(str) {
            return str.replace(/&/g, '&amp;')
                      .replace(/</g, '&lt;')
                      .replace(/>/g, '&gt;')
                      .replace(/"/g, '&quot;');
        }

        // Keep ENTER key working
        document.addEventListener("DOMContentLoaded", () => {
            const input = document.querySelector(".chat-input-bar input");
            if (input) {
                input.addEventListener("keydown", function (e) {
                    if (e.key === "Enter") {
                        sendMsg();
                    }
                });
            }
        });


        
        // ── Sidebar hamburger ──
        function initSidebar() {
          const h = document.getElementById('hamburger'),
            s = document.getElementById('sidebar'),
            o = document.getElementById('sidebar-overlay');
          if (!h || !s) return;
          h.addEventListener('click', () => {
            const open = s.classList.toggle('open');
            h.classList.toggle('open', open);
            if (o) o.classList.toggle('open', open);
            document.body.style.overflow = open ? 'hidden' : ''
          });
          if (o) o.addEventListener('click', closeSidebar);
          document.addEventListener('keydown', e => {
            if (e.key === 'Escape') closeSidebar()
          })
        }

        function closeSidebar() {
          const s = document.getElementById('sidebar'),
            o = document.getElementById('sidebar-overlay'),
            h = document.getElementById('hamburger');
          if (s) s.classList.remove('open');
          if (o) o.classList.remove('open');
          if (h) h.classList.remove('open');
          document.body.style.overflow = ''
        }

        // ── Tabs ──
        function showTab(id, el) {
          const parent = el.closest('.tabs');
          if (parent) parent.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
          el.classList.add('active');
          document.querySelectorAll('[data-tab]').forEach(c => c.classList.add('hidden'));
          const t = document.getElementById(id);
          if (t) {
            t.classList.remove('hidden');
            t.classList.add('fade-in')
          }
        }

        // ── Wizard ──
        function wzStep(n) {
          [1, 2, 3].forEach(i => {
            const p = document.getElementById('wz' + i),
              s = document.getElementById('ws' + i);
            if (!p || !s) return;
            p.classList.toggle('hidden', i !== n);
            s.classList.remove('active', 'done');
            if (i === n) s.classList.add('active');
            if (i < n) s.classList.add('done')
          })
        }

       

        // ── Toast ──
        function showToast(msg, type = '') {
          const ex = document.querySelector('.toast');
          if (ex) ex.remove();
          const el = document.createElement('div');
          el.className = 'toast' + (type ? ' toast-' + type : '');
          el.textContent = msg;
          document.body.appendChild(el);
          setTimeout(() => {
            el.style.opacity = '0';
            el.style.transition = 'opacity .3s';
            setTimeout(() => el.remove(), 300)
          }, 3000)
        }

      




        // ── User menu dropdown ──
        function toggleUserMenu() {
          const d = document.getElementById('user-dropdown');
          if (d) d.classList.toggle('open')
        }
        document.addEventListener('click', e => {
          const d = document.getElementById('user-dropdown');
          if (d && !e.target.closest('.nav-user-menu')) d.classList.remove('open')
        })

        // ── Logout ──
        function doLogout() {
          if (confirm('Are you sure you want to sign out?')) window.location.href = 'login.html'
        }

       
    
    </script>
    
</body>


          <div class="q-card-meta">
            <a href="user-profile.html?user=ahmad" onclick="event.stopPropagation()" style="display:flex;align-items:center;gap:6px">
              <div class="av av-sm"><img src="https://i.pravatar.cc/36?img=11" alt="Ahmad"></div>
              <span style="font-weight:600;font-size:13px">Ahmad K.</span>
            </a>
            <span class="chip chip-indigo" style="margin-left:auto">IT Faculty</span>
            <span class="chip chip-violet">CS302</span>
          </div>
          <div class="q-card-title">How does AVL tree rotation actually work?</div>
          <div class="q-card-footer"><span>👍 42</span><span>💬 7 answers</span>
            <button class="btn btn-primary btn-sm" style="margin-left:auto" onclick="event.stopPropagation();event.preventDefault();openSessionModal('Ahmad K.','https://i.pravatar.cc/60?img=11','CS302')">💬 Request Session</button>

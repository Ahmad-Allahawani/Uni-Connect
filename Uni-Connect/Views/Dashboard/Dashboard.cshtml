@model Uni_Connect.Models.User
@{
    ViewData["Title"] = "Community Dashboard — UniConnect";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

@section Styles {
    <link href="~/css/dashboard.css" rel="stylesheet" />
}

<div style="max-width: 1000px; margin: 0 auto;">
    <!-- Page Header -->
    <div class="dashboard-header">
        <h1 class="dashboard-title">Welcome back, @(Model.Name.Split(' ').First())!</h1>
        <p class="dashboard-subtitle">See what's happening in your community today</p>
    </div>

    <!-- Composer Card -->
    <a asp-action="CreatePost" asp-controller="Dashboard" class="composer-card">
        <div class="av-wrap" style="flex-shrink:0;">
            <div class="av av-sm av-gradient-ring"><img src="@AvatarHelper.Url(Model.Name, 44)" alt="" /></div>
            <span class="av-dot"></span>
        </div>
        <span class="composer-prompt">What's your academic question today?</span>
        <span class="composer-icon" aria-hidden="true">
            <i class="ph-bold ph-pencil-simple"></i>
        </span>
    </a>


    <!-- Tabs -->
    <div class="tab-container">
        <button class="tab-btn active" onclick="filterTab('trending', this)"><i class="ph-fill ph-fire" style="font-size:15px;color:#F59E0B;"></i> Trending</button>
        <button class="tab-btn" onclick="filterTab('all', this)"><i class="ph-duotone ph-list-bullets" style="font-size:15px;"></i> All Questions</button>
        <button class="tab-btn" onclick="filterTab('faculty', this)"><i class="ph-duotone ph-users-three" style="font-size:15px;"></i> My Faculty</button>
    </div>

    <!-- Questions Feed -->
    <div class="questions-list" id="questionsList">
        @{
            var posts = ViewBag.Posts as List<Post>;
            if (posts != null && posts.Count > 0)
            {
                foreach (var post in posts)
                {
                    var isSolved    = post.Answers?.Any(a => a.IsAccepted && !a.IsDeleted) == true;
                    var trendScore  = post.Upvotes + (post.Answers?.Count(a => !a.IsDeleted) ?? 0) * 2 + post.ViewsCount;
                    var authorName  = post.User?.Name?.Split(' ').First() ?? "User";
                    var answerCount = post.Answers?.Count(a => !a.IsDeleted) ?? 0;
                    var snippet     = string.IsNullOrEmpty(post.Content) ? "" : (post.Content.Length > 150 ? post.Content[..150] + "…" : post.Content);
                    var postUrl     = Url.Action("SinglePost", new { id = post.PostID });

                    <!-- Card is a <div> so we can safely embed interactive buttons inside -->
                    <div class="q-card-enhanced @(isSolved ? "is-solved" : "")"
                         onclick="window.location.href='@postUrl'"
                         data-faculty="@(post.Category?.Name ?? "")"
                         data-tags="@(post.PostTags != null ? string.Join(",", post.PostTags.Select(pt => pt.Tag.Name)) : "")"
                         data-trend="@trendScore"
                         role="link" tabindex="0"
                         onkeydown="if(event.key==='Enter')window.location.href='@postUrl'">

                        <!-- Meta row -->
                        <div class="q-meta-row">
                            @if (!string.IsNullOrEmpty(post.User?.ProfileImageUrl))
                            {
                                <img src="@post.User.ProfileImageUrl" alt="" class="q-avatar" />
                            }
                            else
                            {
                                <img src="@AvatarHelper.Url(post.User?.Name, 28)" alt="" class="q-avatar" />
                            }
                            @if (!string.IsNullOrEmpty(post.User?.Username))
                            {
                                <button type="button" class="q-author"
                                        onclick="event.stopPropagation(); window.location.href='@Url.Action("ViewProfile", new { username = post.User.Username })';"
                                        style="background:none;border:none;padding:0;cursor:pointer;font-family:inherit;">@authorName</button>
                            }
                            else
                            {
                                <span class="q-author">@authorName</span>
                            }
                            <span class="q-date">· @post.CreatedAt.ToString("MMM d")</span>
                            @if (isSolved)
                            {
                                <span class="q-solved-badge">
                                    <i class="ph-fill ph-check-circle" style="font-size:12px;"></i> Solved
                                </span>
                            }
                        </div>

                        <!-- Title + content + optional thumbnail -->
                        <div style="display:flex; gap:18px; align-items:flex-start;">
                            <div style="flex:1; min-width:0;">
                                <h3 class="q-title">@post.Title</h3>
                                @if (!string.IsNullOrEmpty(snippet))
                                {
                                    <p class="q-content">@snippet</p>
                                }
                            </div>
                            @if (!string.IsNullOrEmpty(post.ImageUrl))
                            {
                                <div class="q-thumb">
                                    <img src="@post.ImageUrl" alt="" />
                                </div>
                            }
                        </div>

                        <!-- Tags -->
                        @if (post.Category != null)
                        {
                            <div class="q-tags">
                                <button type="button" class="chip chip-indigo"
                                        onclick="event.stopPropagation(); window.location.href='@Url.Action("Search", "Dashboard", new { q = post.Category.Name })';"
                                        style="cursor:pointer;font-family:inherit;">@post.Category.Name</button>
                            </div>
                        }

                        <!-- Stats row with upvote button -->
                        <div class="q-stats">
                            <!-- Upvote button — interactive, stops card navigation -->
                            <button class="q-upvote-btn" id="upvote-btn-@post.PostID"
                                    onclick="event.stopPropagation(); upvotePost(@post.PostID)"
                                    title="Upvote this question" type="button">
                                <i class="ph-duotone ph-thumbs-up" id="upvote-icon-@post.PostID"></i>
                                <span id="upvote-count-@post.PostID">@post.Upvotes</span>
                            </button>

                            <span class="q-stat-item">
                                <i class="ph-duotone ph-chat-circle" style="font-size:13px;"></i>
                                <b>@answerCount</b> answer@(answerCount != 1 ? "s" : "")
                            </span>
                            <span class="q-stat-item">
                                <i class="ph-duotone ph-eye" style="font-size:13px;"></i>
                                <b>@post.ViewsCount</b> views
                            </span>

                            <!-- "View answers" CTA — makes navigation intent obvious -->
                            <span style="margin-left:auto; color:var(--indigo); font-weight:700; font-size:12px; display:inline-flex; align-items:center; gap:3px; flex-shrink:0;">
                                View @(answerCount > 0 ? $"{answerCount} answer{(answerCount != 1 ? "s" : "")}" : "question")
                                <i class="ph-bold ph-arrow-right" style="font-size:11px;"></i>
                            </span>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="empty-state" id="emptyState">
                    <div class="empty-state-icon"><i class="ph-duotone ph-question"></i></div>
                    <h3 class="empty-state-title">No questions yet</h3>
                    <p class="empty-state-text">Be the first to ask a question in your community!</p>
                    <a asp-action="CreatePost" class="btn btn-primary">
                        <i class="ph-bold ph-pencil-simple" style="font-size:15px;"></i> Ask a Question
                    </a>
                </div>
            }
        }
    </div>

    <!-- No results for tab filter -->
    <div id="noTabResults" class="empty-state" style="display:none;">
        <div class="empty-state-icon"><i class="ph-duotone ph-magnifying-glass-minus"></i></div>
        <h3 class="empty-state-title">No questions found</h3>
        <p class="empty-state-text">No questions in this category yet. Be the first!</p>
        <a asp-action="CreatePost" class="btn btn-primary">
            <i class="ph-bold ph-pencil-simple" style="font-size:15px;"></i> Ask a Question
        </a>
    </div>
</div>

<!-- Hidden antiforgery for AJAX upvote -->
<form id="antiforgeryForm" style="display:none;">@Html.AntiForgeryToken()</form>

@section Scripts {
<script>
    const userFaculty = '@Model.Faculty';

    // ── Tab filter ──────────────────────────────────────────────
    function filterTab(type, btn) {
        document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');

        const cards = Array.from(document.querySelectorAll('#questionsList .q-card-enhanced'));
        const noResults = document.getElementById('noTabResults');

        if (type === 'all') {
            cards.forEach(c => {
                c.style.display = '';
                c.style.opacity = '1';
                c.style.transform = 'none';
                c.style.visibility = 'visible';
            });

            noResults.style.display = 'none';

            if (window.ScrollTrigger) {
                ScrollTrigger.refresh();
            }

            return;
        }
        if (type === 'faculty') {
            const lower = userFaculty.trim().toLowerCase();
            let visible = 0;

            cards.forEach(c => {
                const fac = (c.dataset.faculty || '').trim().toLowerCase();

                const show = !lower
                    ? true
                    : fac === lower || fac.includes(lower) || lower.includes(fac);

                c.style.display = show ? '' : 'none';

                if (show) {
                    visible++;

                    // FIX: make filtered cards visible even if GSAP kept them hidden
                    c.style.opacity = '1';
                    c.style.transform = 'none';
                    c.style.visibility = 'visible';
                }
            });

            noResults.style.display = visible === 0 ? 'flex' : 'none';

            if (window.ScrollTrigger) {
                ScrollTrigger.refresh();
            }

            return;
        }
        if (type === 'trending') {
            const list = document.getElementById('questionsList');
            cards.sort((a, b) => parseInt(b.dataset.trend || 0) - parseInt(a.dataset.trend || 0));
            cards.forEach(c => {
                c.style.display = '';
                c.style.opacity = '1';
                c.style.transform = 'none';
                c.style.visibility = 'visible';
                list.appendChild(c);
            });
            noResults.style.display = 'none';
        }
    }

    // ── Upvote post ─────────────────────────────────────────────
    function getToken() {
        var el = document.querySelector('#antiforgeryForm input[name="__RequestVerificationToken"]');
        return el ? el.value : '';
    }

    // Restore voted state + apply trending sort on page load
    document.addEventListener('DOMContentLoaded', async function () {
        // Apply trending sort as default
        const trendingBtn = document.querySelector('.tab-btn.active');
        if (trendingBtn) filterTab('trending', trendingBtn);

        try {
            const res = await fetch('/api/user/votes');
            if (res.ok) {
                const data = await res.json();
                (data.postIds || []).forEach(id => setPostVoteState(id, true, null));
            }
        } catch { /* silent */ }
    });

    async function upvotePost(postId) {
        const btn = document.getElementById('upvote-btn-' + postId);
        if (btn && btn.dataset.pending === '1') return;
        if (btn) btn.dataset.pending = '1';

        try {
            const resp = await fetch('/Dashboard/UpvotePost', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': getToken()
                },
                body: 'postId=' + encodeURIComponent(postId)
            });
            const data = await resp.json();

            const btn2 = document.getElementById('upvote-btn-' + postId);
            if (btn2) btn2.dataset.pending = '0';

            if (!resp.ok) {
                showToast(data.message || 'Could not upvote.', 'error');
                return;
            }

            setPostVoteState(postId, data.voted, data.upvotes);
        } catch {
            const btn2 = document.getElementById('upvote-btn-' + postId);
            if (btn2) btn2.dataset.pending = '0';
            showToast('Failed to upvote. Try again.', 'error');
        }
    }

    function setPostVoteState(postId, voted, newCount) {
        const btn   = document.getElementById('upvote-btn-'   + postId);
        const icon  = document.getElementById('upvote-icon-'  + postId);
        const count = document.getElementById('upvote-count-' + postId);

        if (btn)  { btn.classList.toggle('voted', voted); }
        if (icon) { icon.className = voted ? 'ph-fill ph-thumbs-up' : 'ph-duotone ph-thumbs-up'; }
        if (count && newCount !== null) count.textContent = newCount;
    }
</script>

<!-- EFFECT 7: GSAP card stagger + hover tilt -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
<script>
(function(){
  if(window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
  gsap.registerPlugin(ScrollTrigger);

  // Stagger cards in as they scroll into view
  gsap.utils.toArray('.q-card-enhanced').forEach(function(card, i){
    gsap.from(card, {
      scrollTrigger: {
        trigger: card,
        start: 'top 92%',
        toggleActions: 'play none none none'
      },
      y: 28,
      opacity: 0,
      duration: 0.48,
      delay: (i % 4) * 0.07,
      ease: 'power2.out'
    });
  });

  // Hover tilt — desktop only
  if(!window.matchMedia('(pointer: coarse)').matches){
    document.querySelectorAll('.q-card-enhanced').forEach(function(card){
      card.addEventListener('mousemove', function(e){
        var rect = card.getBoundingClientRect();
        var x = (e.clientX - rect.left) / rect.width - 0.5;
        var y = (e.clientY - rect.top)  / rect.height - 0.5;
        gsap.to(card, {
          rotateX: -y * 4,
          rotateY:  x * 4,
          transformPerspective: 800,
          duration: 0.3,
          ease: 'power1.out'
        });
      });
      card.addEventListener('mouseleave', function(){
        gsap.to(card, { rotateX: 0, rotateY: 0, duration: 0.5, ease: 'elastic.out(1, 0.5)' });
      });
    });
  }

  // GSAP + Lenis integration
  if(window.lenis){
    window.lenis.on('scroll', ScrollTrigger.update);
  }
})();
</script>
}

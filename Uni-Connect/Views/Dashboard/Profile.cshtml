@model Uni_Connect.Models.User
@{
    ViewData["Title"] = "My Profile — UniConnect";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

@section Styles {
<link href="~/css/profile.css" rel="stylesheet" />
}

<div class="profile-wrapper">
    @{
        var questionCount = Model.Posts?.Count(p => !p.IsDeleted) ?? 0;
        var answerCount   = Model.Answers?.Count(a => !a.IsDeleted) ?? 0;
        var sessionCount  = ViewBag.SessionCount as int? ?? 0;
        var avatarUrl     = !string.IsNullOrEmpty(Model.ProfileImageUrl)
                            ? Model.ProfileImageUrl
                            : AvatarHelper.Url(Model.Name, 120);
        var ptsToTutor    = Math.Max(0, 1000 - Model.Points);
        var tutorPct      = Math.Min((int)((Model.Points / 1000.0) * 100), 100);
        var viewerIdStr   = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        bool isOwnProfile = viewerIdStr != null && int.Parse(viewerIdStr) == Model.UserID;
        bool isTutor      = Model.Points >= 1000;
    }

    @if (!isOwnProfile)
    {
        <div style="background:var(--indigo-light); border:1px solid var(--indigo); border-radius:var(--radius); padding:10px 16px; margin-bottom:16px; font-size:13px; color:var(--indigo); font-weight:600; display:flex; align-items:center; gap:8px;">
            <i class="ph-fill ph-user-circle" style="font-size:16px;"></i>
            You are viewing <strong style="margin:0 4px;">@Model.Name</strong>'s profile
            <a asp-action="Dashboard" asp-controller="Dashboard" style="margin-left:auto; color:var(--indigo); font-size:12px; font-weight:600; text-decoration:underline;">← Back to Feed</a>
        </div>
    }

    <!-- Profile Cover -->
    <div class="profile-cover">
        <div class="profile-cover-overlay"></div>
        <div class="profile-avatar-wrap">
            <div class="profile-avatar" style="position:relative;">
                <img src="@avatarUrl" alt="@Model.Name" id="profileAvatarImg" />
                @if (isOwnProfile)
                {
                    <label for="quickPhotoInput"
                           id="photoOverlay"
                           style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;background:rgba(0,0,0,0.45);border-radius:16px;opacity:0;transition:opacity .2s;cursor:pointer;color:white;font-size:24px;">
                        <i class="ph-bold ph-camera"></i>
                        <input type="file" id="quickPhotoInput" accept="image/jpeg,image/png,image/gif,image/webp" style="display:none;" onchange="quickPhotoChange(this)" />
                    </label>
                }
            </div>
        </div>
    </div>
    @if (isOwnProfile)
    {
        <style>.profile-avatar:hover #photoOverlay { opacity: 1; }</style>
    }

    <!-- Profile Header -->
    <div class="profile-header">
        <div class="profile-info">
            <h1>@Model.Name</h1>
            <div class="profile-badges">
                <span class="chip chip-indigo" style="display:inline-flex;align-items:center;gap:6px;"><i class="ph-fill ph-buildings" style="font-size:13px;"></i> @Model.Faculty</span>
                <span class="chip chip-violet" style="display:inline-flex;align-items:center;gap:6px;"><i class="ph-fill ph-graduation-cap" style="font-size:13px;"></i> @Model.YearOfStudy</span>
                <span class="chip chip-amber" style="display:inline-flex;align-items:center;gap:6px;"><i class="ph-fill ph-lightning" style="font-size:13px;"></i> @Model.Points pts</span>
                @if (isTutor)
                {
                    <span class="chip chip-emerald" style="display:inline-flex;align-items:center;gap:4px;"><i class="ph-fill ph-seal-check" style="font-size:13px;"></i> Verified Tutor</span>
                }
            </div>
        </div>
        <div class="profile-actions">
            @if (isOwnProfile)
            {
                <a asp-action="Settings" class="btn btn-ghost btn-sm" style="display:inline-flex;align-items:center;gap:8px;"><i class="ph ph-pencil-simple" style="font-size:16px;"></i> Edit Profile</a>
            }
            else
            {
                var diff2 = Model.LastSeenAt.HasValue ? DateTime.UtcNow - Model.LastSeenAt.Value : (TimeSpan?)null;
                string lsText = diff2 == null ? "" :
                    diff2.Value.TotalMinutes < 60 ? $"{(int)diff2.Value.TotalMinutes}m ago" :
                    diff2.Value.TotalHours < 24   ? $"{(int)diff2.Value.TotalHours}h ago" :
                    Model.LastSeenAt!.Value.ToString("MMM d");
                <div style="display:inline-flex;align-items:center;gap:6px;font-size:13px;color:@(Model.IsOnline ? "#10B981" : "var(--text-2)");">
                    <span style="width:8px;height:8px;border-radius:50%;background:@(Model.IsOnline ? "#10B981" : "var(--text-3)");display:inline-block;flex-shrink:0;"></span>
                    @if (Model.IsOnline) { <text>Online now</text> }
                    else if (!string.IsNullOrEmpty(lsText)) { <text>Last seen @lsText</text> }
                </div>
            }
        </div>
    </div>

    <!-- Tutor Progress — promoted above stats (F12) -->
    <div class="progress-section">
        <div class="progress-content">
            <div class="progress-label">
                <span>Progress to <strong>Verified Tutor</strong></span>
                <span>@Model.Points / 1000 pts</span>
            </div>
            <div class="progress-bar">
                <div class="progress-fill" style="width: @tutorPct%"></div>
            </div>
            <div class="progress-text">
                @if (isTutor)
                { <span style="color:var(--emerald); font-weight:700;">Verified Tutor unlocked!</span> }
                else
                { <text>@ptsToTutor pts to go to unlock tutor badge.</text> }
            </div>
        </div>
        <a asp-action="Points" class="btn btn-amber btn-sm"><i class="ph-bold ph-arrow-right" style="font-size:14px;vertical-align:middle;margin-right:4px;"></i> View Rewards</a>
    </div>

    <!-- Stats Grid — CSS classes instead of inline colors (F2) -->
    <div class="profile-stats">
        <div class="stat-item">
            <div class="stat-num stat-num--indigo">@Model.Points</div>
            <div class="stat-label">Points</div>
        </div>
        <div class="stat-item">
            <div class="stat-num stat-num--emerald">@answerCount</div>
            <div class="stat-label">Answers</div>
        </div>
        <div class="stat-item">
            <div class="stat-num stat-num--amber">@questionCount</div>
            <div class="stat-label">Questions</div>
        </div>
        <div class="stat-item">
            <div class="stat-num stat-num--violet">@sessionCount</div>
            <div class="stat-label">Sessions</div>
        </div>
    </div>

    <!-- Activity Tabs — unified ds-tab pattern (F7); Sessions hidden if 0 (F12) -->
    <div class="ds-tabs">
        <button class="ds-tab active" onclick="switchTab('answers',this)">
            <i class="ph-bold ph-chat-circle" style="font-size:15px;"></i> Answers (@answerCount)
        </button>
        <button class="ds-tab" onclick="switchTab('questions',this)">
            <i class="ph-bold ph-question" style="font-size:15px;"></i> Questions (@questionCount)
        </button>
        @if (sessionCount > 0)
        {
            <button class="ds-tab" onclick="switchTab('sessions',this)">
                <i class="ph-bold ph-video-camera" style="font-size:15px;"></i> Sessions (@sessionCount)
            </button>
        }
    </div>

    <!-- Tab: Answers -->
    <div id="tab-answers">
        <div class="activity-list">
            @if (Model.Answers != null && Model.Answers.Any(a => !a.IsDeleted))
            {
                foreach (var answer in Model.Answers.Where(a => !a.IsDeleted).OrderByDescending(a => a.CreatedAt).Take(10))
                {
                    <a href="@(answer.Post != null ? Url.Action("SinglePost", new { id = answer.PostID }) : "#")" style="text-decoration:none; color:inherit;">
                        <div class="activity-card">
                            <div class="activity-meta">
                                @if (answer.IsAccepted) { <span class="chip chip-emerald">Best Answer</span> }
                                @if (answer.Post?.Category != null) { <span class="chip chip-indigo">@answer.Post.Category.Name</span> }
                                <span style="color:var(--text-2);">@answer.CreatedAt.ToString("MMM dd, yyyy")</span>
                            </div>
                            <div class="activity-title">@(answer.Post?.Title ?? "Question")</div>
                            <div class="activity-stats">
                                <span style="display:inline-flex;align-items:center;gap:4px;"><i class="ph ph-thumbs-up" style="font-size:13px;"></i> @answer.Upvotes upvotes</span>
                            </div>
                        </div>
                    </a>
                }
            }
            else
            {
                <div class="empty-state">
                    <div class="empty-state-icon emerald"><i class="ph-duotone ph-chat-dots"></i></div>
                    <h3 class="empty-state-title">No answers yet</h3>
                    <p class="empty-state-text">Help your peers by answering questions and earn points!</p>
                    <a asp-action="Dashboard" class="btn btn-primary">
                        <i class="ph-bold ph-list-bullets" style="font-size:15px;"></i> Browse Questions
                    </a>
                </div>
            }
        </div>
    </div>

    <!-- Tab: Questions -->
    <div id="tab-questions" class="hidden">
        <div class="activity-list">
            @if (Model.Posts != null && Model.Posts.Any(p => !p.IsDeleted))
            {
                foreach (var post in Model.Posts.Where(p => !p.IsDeleted).OrderByDescending(p => p.CreatedAt).Take(10))
                {
                    <a href="@Url.Action("SinglePost", new { id = post.PostID })" style="text-decoration:none; color:inherit;">
                        <div class="activity-card">
                            <div class="activity-meta">
                                @if (post.Answers?.Any(a => a.IsAccepted && !a.IsDeleted) == true) { <span class="chip chip-emerald">Solved</span> }
                                @if (post.Category != null) { <span class="chip chip-indigo">@post.Category.Name</span> }
                                <span style="color:var(--text-2);">@post.CreatedAt.ToString("MMM dd, yyyy")</span>
                            </div>
                            <div class="activity-title">@post.Title</div>
                            <div class="activity-stats">
                                <span style="display:inline-flex;align-items:center;gap:4px;"><i class="ph ph-chat-dots" style="font-size:13px;"></i> @(post.Answers?.Count(a => !a.IsDeleted) ?? 0) answers</span>
                                <span style="display:inline-flex;align-items:center;gap:4px;"><i class="ph ph-eye" style="font-size:13px;"></i> @post.ViewsCount views</span>
                            </div>
                        </div>
                    </a>
                }
            }
            else
            {
                <div class="empty-state">
                    <div class="empty-state-icon"><i class="ph-duotone ph-question"></i></div>
                    <h3 class="empty-state-title">No questions yet</h3>
                    <p class="empty-state-text">Ask your first question in the community!</p>
                    <a asp-action="CreatePost" class="btn btn-primary">
                        <i class="ph-bold ph-pencil-simple" style="font-size:15px;"></i> Ask a Question
                    </a>
                </div>
            }
        </div>
    </div>

    <!-- Tab: Sessions (only rendered if sessionCount > 0) -->
    @if (sessionCount > 0)
    {
        <div id="tab-sessions" class="hidden">
            <div class="empty-state">
                <div class="empty-state-icon emerald"><i class="ph-duotone ph-graduation-cap"></i></div>
                <h3 class="empty-state-title">@sessionCount session@(sessionCount == 1 ? "" : "s") total</h3>
                <p class="empty-state-text">View your full session history in Private Sessions.</p>
                <a asp-controller="Session" asp-action="ChatPage" class="btn btn-primary">
                    <i class="ph-bold ph-arrow-right" style="font-size:14px;"></i> Go to Sessions
                </a>
            </div>
        </div>
    }
</div>

<script>
    function switchTab(tabName, el) {
        ['answers', 'questions', 'sessions'].forEach(t => {
            const tab = document.getElementById('tab-' + t);
            if (tab) tab.classList.add('hidden');
        });
        const selected = document.getElementById('tab-' + tabName);
        if (selected) selected.classList.remove('hidden');
        document.querySelectorAll('.ds-tab').forEach(btn => btn.classList.remove('active'));
        if (el) el.classList.add('active');
    }
</script>

@if (isOwnProfile)
{
    <form id="afjForm" style="display:none;">@Html.AntiForgeryToken()</form>
    <script>
        async function quickPhotoChange(input) {
            const file = input.files[0];
            if (!file) return;
            if (file.size > 5 * 1024 * 1024) { showToast('Image too large (max 5MB)', 'error'); return; }

            showToast('Uploading…');
            const formData = new FormData();
            formData.append('profileImage', file);
            const tokenEl = document.querySelector('#afjForm input[name="__RequestVerificationToken"]');
            if (tokenEl) formData.append('__RequestVerificationToken', tokenEl.value);

            try {
                const res = await fetch('/Dashboard/QuickUpdatePhoto', { method: 'POST', body: formData });
                const data = await res.json();
                if (data.success) {
                    document.getElementById('profileAvatarImg').src = data.imageUrl;
                    document.querySelectorAll('.sidebar .av img, .nav-user .av img').forEach(img => img.src = data.imageUrl);
                    showToast('Profile photo updated!', 'success');
                } else {
                    showToast(data.message || 'Upload failed', 'error');
                }
            } catch {
                showToast('Upload failed', 'error');
            }
            input.value = '';
        }
    </script>
}

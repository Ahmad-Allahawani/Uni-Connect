@model Uni_Connect.Models.User
@{
    ViewData["Title"] = Model.Name + " — UniConnect Profile";
}

@section Styles {
<link href="~/css/site.css" rel="stylesheet" />
<style>
    :root {
        --indigo: #3D52A0; --indigo-dark: #2d3f7a; --indigo-light: #EEF2FF;
        --violet: #7091E6; --violet-light: #EDE9FE;
        --amber: #F59E0B; --amber-light: #FEF3C7;
        --bg: #F8F9FF; --surface: #fff; --border: #E2E8F0;
        --text: #0F172A; --text-2: #64748B;
        --radius: 12px;
    }

    body { background: var(--bg); color: var(--text); }
    .app-wrap { max-width: 1440px; margin: 0 auto; display: grid; grid-template-columns: 260px 1fr; gap: 24px; padding: 24px 5%; min-height: calc(100vh - 64px); }
    
    .sidebar { position: sticky; top: 24px; height: fit-content; }
    .sidebar-user { display: flex; align-items: center; gap: 12px; padding: 12px; border-radius: 16px; background: var(--surface); border: 1px solid var(--border); text-decoration: none; color: inherit; margin-bottom: 20px; }
    
    .nav-item { display: flex; align-items: center; gap: 12px; padding: 12px 16px; border-radius: 12px; font-size: 14px; font-weight: 700; color: var(--text-2); text-decoration: none; transition: all .2s; margin-bottom: 4px; }
    .nav-item:hover { background: var(--indigo-light); color: var(--indigo); }
    .nav-item.active { background: var(--indigo); color: #fff; box-shadow: 0 4px 12px rgba(61,82,160,0.15); }

    .profile-banner { height: 200px; background: linear-gradient(135deg, var(--indigo), var(--violet)); border-radius: 24px; position: relative; margin-bottom: 80px; }
    .profile-avatar-wrap { position: absolute; bottom: -60px; left: 40px; }
    .prof-av { width: 120px; height: 120px; border-radius: 30px; border: 6px solid var(--bg); background: var(--surface); display: flex; align-items: center; justify-content: center; overflow: hidden; }

    .stat-card { background: var(--surface); border: 1px solid var(--border); border-radius: 16px; padding: 20px; text-align: center; }
    .stat-val { font-size: 24px; font-weight: 900; margin-bottom: 4px; }
    
    .chip { display: inline-flex; align-items: center; gap: 6px; padding: 6px 14px; border-radius: 99px; font-size: 13px; font-weight: 800; }
    .chip-indigo { background: var(--indigo-light); color: var(--indigo); }
    .chip-violet { background: var(--violet-light); color: var(--violet); }
</style>
}

<div class="app-wrap">
    <aside class="sidebar">
        <a asp-action="Profile" class="sidebar-user">
            <div class="av av-md">
                <img src="https://ui-avatars.com/api/?name=@Model.Name&background=3D52A0&color=fff&size=44" alt="@Model.Name" />
            </div>
            <div>
                <div class="sidebar-user-name" style="font-weight:800; font-size:15px">@Model.Name</div>
                <div class="sidebar-user-pts" style="color:var(--amber); font-weight:700; font-size:13px">🪙 @Model.Points pts</div>
            </div>
        </a>

        <nav class="sidebar-nav">
            <a asp-action="Dashboard" class="nav-item"><span class="ni">🏠</span>Home Feed</a>
            <a asp-action="CreatePost" class="nav-item"><span class="ni">✏️</span>Ask a Question</a>
            <a asp-action="Sessions" class="nav-item"><span class="ni">💬</span>My Sessions</a>
            <a asp-action="Leaderboard" class="nav-item"><span class="ni">🏆</span>Leaderboard</a>
            <a asp-action="Notifications" class="nav-item"><span class="ni">🔔</span>Notifications</a>
            <a asp-action="Profile" class="nav-item active"><span class="ni">👤</span>My Profile</a>
        </nav>
    </aside>

    <main class="main" style="max-width: 900px">
        <div class="profile-banner">
            <div class="profile-avatar-wrap">
                <div class="prof-av">
                    <img src="https://ui-avatars.com/api/?name=@Model.Name&background=3D52A0&color=fff&size=120" alt="@Model.Name" style="width:100%; height:100%" />
                </div>
            </div>
            <div style="position: absolute; bottom: 16px; right: 24px">
                <button class="btn btn-white btn-sm">Edit Profile ✏️</button>
            </div>
        </div>

        <div style="margin-bottom: 32px">
            <h1 style="font-size: 32px; font-weight: 900; letter-spacing: -1px; margin-bottom: 12px">@Model.Name</h1>
            <div style="display: flex; gap: 10px; align-items: center">
                <span class="chip chip-indigo">💻 @Model.Faculty</span>
                <span class="chip chip-violet">🎓 @Model.YearOfStudy</span>
                <span class="chip" style="background:var(--amber-light); color:var(--amber)">🪙 @Model.Points Points</span>
            </div>
            <p style="color: var(--text-2); font-size: 15px; margin-top: 20px; line-height: 1.8; max-width: 600px">
                Dedicated Philadelphia University student. Always looking to collaborate and solve complex problems with my peers.
            </p>
        </div>

        <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 32px">
            <div class="stat-card"><div class="stat-val" style="color:var(--indigo)">@Model.Points</div><div style="font-size:12px; font-weight:700; color:var(--text-2)">TOTAL POINTS</div></div>
            <div class="stat-card"><div class="stat-val" style="color:var(--emerald)">47</div><div style="font-size:12px; font-weight:700; color:var(--text-2)">ANSWERS</div></div>
            <div class="stat-card"><div class="stat-val" style="color:var(--amber)">12</div><div style="font-size:12px; font-weight:700; color:var(--text-2)">QUESTIONS</div></div>
            <div class="stat-card"><div class="stat-val" style="color:var(--violet)">8</div><div style="font-size:12px; font-weight:700; color:var(--text-2)">SESSIONS</div></div>
        </div>

        <div style="border-top: 1.5px solid var(--border); padding-top: 32px">
            <h2 style="font-size: 20px; font-weight: 850; margin-bottom: 24px">Recent Activity</h2>
            <div style="display: flex; flex-direction: column; gap: 16px">
                <div class="card" style="background:var(--surface); border:1px solid var(--border); border-radius:16px; padding:20px">
                    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:12px">
                        <span class="chip chip-indigo">IT Faculty</span>
                        <span style="font-size:12px; color:var(--text-2); font-weight:600">2 hours ago</span>
                    </div>
                    <div style="font-weight:800; font-size:16px; margin-bottom:8px; line-height:1.4">How does AVL tree rotation actually work?</div>
                    <div style="display:flex; gap:16px; font-size:13px; color:var(--text-2); font-weight:600">
                        <span>👍 42 upvotes</span><span>💬 7 answers</span>
                    </div>
                </div>
            </div>
        </div>
    </main>
</div>
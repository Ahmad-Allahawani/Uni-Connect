@model Uni_Connect.ViewModels.SettingsViewModel

@{
    ViewData["Title"] = "Settings";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

@section Styles {
    <link href="~/css/settings.css" rel="stylesheet" />
    <link href="~/css/notificationsettingsdelete.css" rel="stylesheet" />

  
}

<div class="settings-container">
    <div style="margin-bottom:28px">
        <h1 style="font-size:28px; font-weight:900; display:flex; align-items:center; gap:12px;">
            <i class="ph-duotone ph-gear" style="font-size:32px; color:var(--indigo);"></i> Settings
        </h1>
        <p style="color:var(--text-2); font-size:14px; margin-top:4px">Manage your account and security preferences</p>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div style="background:var(--emerald-light); color:var(--emerald); padding:12px 16px; border-radius:10px; margin-bottom:24px; font-size:14px; font-weight:600; display:flex; align-items:center; gap:8px;">
            <i class="ph-fill ph-check-circle" style="font-size:18px;"></i> @TempData["SuccessMessage"]
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div style="background:var(--rose-light); color:var(--rose); padding:12px 16px; border-radius:10px; margin-bottom:24px; font-size:14px; font-weight:600; display:flex; align-items:center; gap:8px;">
            <i class="ph-fill ph-x-circle" style="font-size:18px;"></i> @TempData["ErrorMessage"]
        </div>
    }

    <form asp-action="Settings" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="UserID" />

        <!-- Profile Section -->
        <div class="card">
            <div class="card-title">
                <i class="ph-duotone ph-user-circle" style="font-size:20px;"></i> Profile Information
            </div>

            <div style="display:flex; align-items:center; gap:20px; margin-bottom:24px;">
                <div class="av av-xl" style="border:4px solid var(--indigo-light)">
                    <img id="profilePreview"
                         src="@(string.IsNullOrEmpty(Model.ProfileImageUrl) ? AvatarHelper.Url(Model.Name, 80) : Model.ProfileImageUrl)"
                         alt="Avatar" />
                </div>

                <div>
                    <label class="btn btn-ghost btn-sm" style="display:inline-flex;align-items:center;gap:8px;cursor:pointer;">
                        <i class="ph ph-camera" style="font-size:16px;"></i> Change Photo
                        <input type="file"
                               name="profileImage"
                               id="profileImageFile"
                               accept="image/jpeg,image/png,image/gif,image/webp"
                               style="display:none;"
                               onchange="previewFile(this)" />
                    </label>

                    <div style="margin-top:6px;">
                        <span class="form-hint" id="photoFileName">JPG, PNG, GIF or WebP — max 5 MB</span>
                    </div>
                </div>

                <input type="hidden" asp-for="ProfileImageUrl" id="hiddenImageUrl" />
            </div>

            <div class="form-grid">
                <div class="form-group">
                    <label class="form-label">Full Name</label>
                    <input asp-for="Name" class="form-input" placeholder="Enter your full name" />
                </div>

                <div class="form-group">
                    <label class="form-label">University Email</label>
                    <input asp-for="Email" class="form-input" disabled />
                    <span class="form-hint">Email cannot be changed</span>
                </div>

                <div class="form-group">
                    <label class="form-label">Faculty</label>
                    <select asp-for="Faculty" class="form-input form-select">
                        <option value="IT Faculty">Faculty of Information Technology</option>
                        <option value="Engineering">Faculty of Engineering</option>
                        <option value="Business">Faculty of Business</option>
                        <option value="Science">Faculty of Science</option>
                        <option value="Pharmacy">Faculty of Pharmacy</option>
                        <option value="Law">Faculty of Law</option>
                        <option value="Arts">Faculty of Arts</option>
                    </select>
                </div>

                <div class="form-group">
                    <label class="form-label">Year of Study</label>
                    <select asp-for="YearOfStudy" class="form-input form-select">
                        <option value="1st Year">1st Year</option>
                        <option value="2nd Year">2nd Year</option>
                        <option value="3rd Year">3rd Year</option>
                        <option value="4th Year">4th Year</option>
                        <option value="Graduate">Graduate</option>
                    </select>
                </div>
            </div>

            <div style="margin-top:10px;">
                <button type="submit" class="btn btn-primary">Save Changes</button>
            </div>
        </div>

        <!-- Security Section -->
        <div class="card">
            <div class="card-title">
                <i class="ph-duotone ph-shield-check" style="font-size:20px;"></i> Security & Password
            </div>

            <div style="max-width: 500px;">
                <div class="form-group">
                    <label class="form-label">Current Password</label>
                    <input asp-for="CurrentPassword" type="password" class="form-input" placeholder="Enter current password to verify" />
                </div>

                <div class="form-grid">
                    <div class="form-group">
                        <label class="form-label">New Password</label>
                        <input asp-for="NewPassword" type="password" class="form-input" placeholder="Minimum 6 characters" />
                    </div>

                    <div class="form-group">
                        <label class="form-label">Confirm New Password</label>
                        <input asp-for="ConfirmPassword" type="password" class="form-input" placeholder="Repeat new password" />
                    </div>
                </div>
            </div>

            <div style="margin-top:10px;">
                <button type="submit" class="btn btn-primary">Update Password</button>
            </div>
        </div>
    </form>

    <!-- Notification Toggles -->
    <div class="card">
        <div class="card-title">
            <i class="ph-duotone ph-bell" style="font-size:20px;"></i> Notifications
        </div>

        
        <form asp-action="Settings" method="post">
            
            <div class="settings-row">
                <div class="settings-row-info">
                    <div class="settings-row-label">
                        Answers to my questions
                    </div>
                    <div class="settings-row-sub">Get notified when someone helps you out</div>
                </div>
                <div class="toggle-switch">
                    <input type="hidden" name="NotifyOnAnswers" value="false" />
                    <input type="checkbox" asp-for="NotifyOnAnswers" value="true" />
                </div>
            </div>
            <div class="settings-row">
                <div class="settings-row-info">
                    <div class="settings-row-label">
                        Session requests
                    </div>
                    <div class="settings-row-sub">Alerts for new private tutoring requests</div>
                </div>
                <div class="toggle-switch">
                    <input type="hidden" name="NotifyOnSessionRequests" value="false" />
                    <input type="checkbox" asp-for="NotifyOnSessionRequests" value="true" />
                </div>
            </div>
            <div style="margin-top:10px;">
                <button type="submit" class="btn btn-primary">Save Changes</button>
            </div>
            
        </form>

        
    </div>

    <!-- Danger Zone -->
    <div class="card danger-card">
        <div class="card-title danger-title">
            <i class="ph-fill ph-warning" style="font-size:20px;"></i> Danger Zone
        </div>

        <div style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:16px;">
            <div>
                <div style="font-weight:700; font-size:14px; margin-bottom:4px">Delete Account</div>
                <div style="font-size:12px; color:var(--text-2)">Your account will be deactivated and hidden from the platform immediately.</div>
            </div>

            <button type="button" class="btn btn-rose btn-sm" id="openDeleteModalBtn">
                Delete Account
            </button>
        </div>
    </div>

    <!-- Delete Confirmation Modal -->
    <div class="confirm-overlay" id="deleteModal" role="dialog" aria-modal="true" aria-labelledby="deleteModalTitle">
        <div class="confirm-modal">
            <div class="modal-icon">
                <i class="ph-fill ph-warning"></i>
            </div>

            <h3 id="deleteModalTitle">Delete your account?</h3>

            <p>
                This will immediately deactivate your account. Your posts and answers will remain
                but your profile will no longer be visible or accessible.
            </p>

            <div class="modal-actions">
                <button type="button" class="btn-cancel" id="cancelDeleteBtn">Cancel</button>

                <form asp-action="DeleteAccount" asp-controller="Dashboard" method="post" style="flex:1;margin:0;">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn-danger" style="width:100%;">Yes, delete my account</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Photo preview
        function previewFile(input) {
            const file = input.files[0];
            if (!file) return;

            document.getElementById('photoFileName').textContent = file.name;

            const reader = new FileReader();
            reader.onload = e => {
                document.getElementById('profilePreview').src = e.target.result;
            };

            reader.readAsDataURL(file);
            showToast('Photo selected — click Save Changes to upload.', 'success');
        }

        // Delete account modal
        const modal = document.getElementById('deleteModal');
        const openBtn = document.getElementById('openDeleteModalBtn');
        const cancelBtn = document.getElementById('cancelDeleteBtn');

        openBtn?.addEventListener('click', () => {
            modal.classList.add('active');
            cancelBtn.focus();
        });

        cancelBtn?.addEventListener('click', () => {
            modal.classList.remove('active');
        });

        modal?.addEventListener('click', e => {
            if (e.target === modal) {
                modal.classList.remove('active');
            }
        });

        document.addEventListener('keydown', e => {
            if (e.key === 'Escape') {
                modal.classList.remove('active');
            }
        });
    </script>
}
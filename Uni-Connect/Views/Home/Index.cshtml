                <div class="pts-item"><div class="pts-ico"><i class="ph-bold ph-question" style="font-size:20px;color:var(--rose);"></i></div><div><div style="font-weight:700;font-size:13px">Post Question</div><div style="font-size:11px;opacity:.7">Costs points</div></div><div class="pts-val cost">−10</div></div>

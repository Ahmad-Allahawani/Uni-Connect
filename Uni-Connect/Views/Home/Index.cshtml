<!-- HOW IT WORKS -->
<section class="section" id="how" data-num="01">
    <div style="max-width:1100px;margin:0 auto">
        <div class="center">
            <div class="section-tag"><i class="ph-bold ph-lightning" style="font-size:13px;vertical-align:middle;margin-right:4px;"></i> Simple Process</div>
            <h2 class="section-title">How UniConnect works</h2>
            <p class="section-sub">Six steps — from creating your account to redeeming real discounts at campus venues.</p>
        </div>
        <div class="steps-grid">
            <div class="step"><span class="step-ico"><i class="ph-duotone ph-envelope" style="font-size:24px;color:var(--indigo);"></i></span><div class="step-num">01</div><div class="step-title">Register with university email</div><div class="step-desc">Sign up using your official Philadelphia University email. Only enrolled students can join — verified against the university registry. You receive <strong>+50 welcome points</strong> instantly.</div></div>
            <div class="step"><span class="step-ico"><i class="ph-duotone ph-hand-waving" style="font-size:24px;color:var(--indigo);"></i></span><div class="step-num">02</div><div class="step-title">Ask questions or help others</div><div class="step-desc">Post academic questions (costs 10 pts) and answer others to earn points back. Better answers get more upvotes. Best Answer earns +15 pts bonus automatically.</div></div>
            <div class="step"><span class="step-ico"><i class="ph-fill ph-coin" style="font-size:24px;color:var(--amber);"></i></span><div class="step-num">03</div><div class="step-title">Earn points for every contribution</div><div class="step-desc">Every helpful action earns points — upvotes, best answers, private tutoring sessions, daily logins. Reach 1,000 pts to unlock <strong>Verified Tutor</strong> badge.</div></div>
            <div class="step"><span class="step-ico"><i class="ph-bold ph-chat-circle-dots" style="font-size:24px;color:var(--indigo);"></i></span><div class="step-num">04</div><div class="step-title">Request private tutoring sessions</div><div class="step-desc">Need deeper help? Request a one-on-one private chat session with a verified tutor. Rate your session to help others in the future.</div></div>
            <div class="step"><span class="step-ico"><i class="ph-fill ph-trophy" style="font-size:24px;color:var(--amber);"></i></span><div class="step-num">05</div><div class="step-title">Climb the faculty leaderboard</div><div class="step-desc">Monthly rankings for each faculty. Top contributors earn special recognition and unlock exclusive rewards. Compete with classmates in a friendly academic environment.</div></div>
            <div class="step" style="background:linear-gradient(135deg,var(--indigo-light),var(--indigo-light));border-color:var(--border)"><span class="step-ico"><i class="ph-duotone ph-gift" style="font-size:24px;color:var(--indigo);"></i></span><div class="step-num">06</div><div class="step-title">Redeem at campus venues</div><div class="step-desc">Exchange points for <strong>real discounts</strong> at the university cafeteria, library, bookshop, print centre and more. A QR code is sent to your university email — scan it at the venue.</div></div>
        </div>
    </div>
</section>

<!-- FEATURES -->
<section class="section features-bg" id="features" data-num="02">
    <canvas id="features-canvas" aria-hidden="true"></canvas>
    <div style="max-width:1100px;margin:0 auto">
        <div class="center">
            <div class="section-tag"><i class="ph-bold ph-star" style="font-size:13px;vertical-align:middle;margin-right:4px;"></i> Platform Features</div>
            <h2 class="section-title">Built for university life</h2>
            <p class="section-sub">Every feature designed around how students actually study, ask for help, and collaborate.</p>
        </div>
        <div class="features-grid">
            <div class="feat"><div class="feat-ico" style="background:var(--indigo-light)"><i class="ph-bold ph-magnifying-glass" style="font-size:22px;color:var(--indigo);"></i></div><div class="feat-title">Smart Question Feed</div><div class="feat-desc">Browse questions by faculty, course, or topic. Live search finds existing answers before you post — saving your 10 pts asking cost.</div></div>
            <div class="feat"><div class="feat-ico" style="background:var(--emerald-light)"><i class="ph-fill ph-check-circle" style="font-size:22px;color:var(--emerald);"></i></div><div class="feat-title">Best Answer System</div><div class="feat-desc">Question owners mark the most helpful answer. Best answers are pinned at the top and earn the contributor an automatic +15 pt reward.</div></div>
            <div class="feat"><div class="feat-ico" style="background:var(--violet-light)"><i class="ph-bold ph-chats" style="font-size:22px;color:var(--violet);"></i></div><div class="feat-title">Private Tutoring Chat</div><div class="feat-desc">One-on-one real-time chat with verified tutors. Sessions are private and rated by both parties for transparency and quality.</div></div>
            <div class="feat"><div class="feat-ico" style="background:var(--amber-light)"><i class="ph-fill ph-coin" style="font-size:22px;color:var(--amber);"></i></div><div class="feat-title">Points & Campus Rewards</div><div class="feat-desc">Earn points helping others and spend them at real campus locations — cafeteria, library, bookshop, print centre, gym and more.</div></div>
            <div class="feat"><div class="feat-ico" style="background:var(--rose-light)"><i class="ph-fill ph-trophy" style="font-size:22px;color:var(--rose);"></i></div><div class="feat-title">Faculty Leaderboard</div><div class="feat-desc">Monthly rankings per faculty. Top 3 contributors earn special recognition badges and exclusive rewards for their academic community.</div></div>
            <div class="feat"><div class="feat-ico" style="background:var(--indigo-light)"><i class="ph-fill ph-shield-check" style="font-size:22px;color:var(--indigo);"></i></div><div class="feat-title">AI-Assisted Moderation</div><div class="feat-desc">Content reviewed by AI and human admins. Report inappropriate posts anytime — admins review within 24 hours to keep the platform safe.</div></div>
        </div>
    </div>
</section>


                <div style="display:flex;align-items:center;gap:11px;background:rgba(255,255,255,.1);border-radius:12px;padding:12px 16px"><i class="ph-duotone ph-envelope" style="font-size:20px;color:rgba(255,255,255,.85);"></i><span style="font-size:14px;color:rgba(255,255,255,.85);font-weight:600">QR codes sent directly to your university email</span></div>
                <div style="display:flex;align-items:center;gap:11px;background:rgba(255,255,255,.1);border-radius:12px;padding:12px 16px"><i class="ph-duotone ph-gift" style="font-size:20px;color:rgba(255,255,255,.85);"></i><span style="font-size:14px;color:rgba(255,255,255,.85);font-weight:600">Completely free — no credit card ever needed</span></div>
            </div>
        </div>
        <div>
            <div style="font-size:11px;font-weight:800;color:rgba(255,255,255,.5);text-transform:uppercase;letter-spacing:.09em;margin-bottom:14px">HOW POINTS WORK:</div>
            <div class="pts-grid">
                <div class="pts-item"><div class="pts-ico"><i class="ph-bold ph-chat-circle" style="font-size:20px;color:var(--indigo);"></i></div><div><div style="font-weight:700;font-size:13px">Post an Answer</div><div style="font-size:11px;opacity:.7">Help a classmate</div></div><div class="pts-val earn">+5</div></div>
                <div class="pts-item"><div class="pts-ico"><i class="ph-fill ph-thumbs-up" style="font-size:20px;color:var(--violet);"></i></div><div><div style="font-weight:700;font-size:13px">Get Upvoted</div><div style="font-size:11px;opacity:.7">Per upvote received</div></div><div class="pts-val earn">+10</div></div>
                <div class="pts-item"><div class="pts-ico"><i class="ph-fill ph-seal-check" style="font-size:20px;color:var(--emerald);"></i></div><div><div style="font-weight:700;font-size:13px">Best Answer</div><div style="font-size:11px;opacity:.7">Marked as best</div></div><div class="pts-val earn">+15</div></div>
                <div class="pts-item"><div class="pts-ico"><i class="ph-fill ph-graduation-cap" style="font-size:20px;color:var(--amber);"></i></div><div><div style="font-weight:700;font-size:13px">Tutor Session</div><div style="font-size:11px;opacity:.7">Accept a request</div></div><div class="pts-val earn">+20</div></div>
                <div class="pts-item"><div class="pts-ico"><i class="ph-fill ph-star" style="font-size:20px;color:var(--amber);"></i></div><div><div style="font-weight:700;font-size:13px">5-Star Rating</div><div style="font-size:11px;opacity:.7">Perfect session</div></div><div class="pts-val earn">+15</div></div>

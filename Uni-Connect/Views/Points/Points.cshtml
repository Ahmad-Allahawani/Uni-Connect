@model PointsViewModel

@{
    ViewData["Title"] = "Points & Rewards";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

@section Styles {
    <link href="~/css/points.css" rel="stylesheet" />
}

<div class="points-hero">
    <div class="points-hero-icon"><i class="ph-fill ph-coins"></i></div>
    <div style="z-index: 1;">
        <div style="font-size:13px; opacity:.75; margin-bottom:6px; font-weight:600">Your Current Balance</div>
        <div style="font-size:52px; font-weight:900; line-height:1; letter-spacing:-1px; display:flex; align-items:center; gap:12px;">@Model.CurrentPoints <i class="ph-fill ph-coins" style="font-size:32px;"></i></div>
        <div style="margin-top:12px; font-size:13px; opacity:.85">
            <strong>Level @Model.CurrentLevel</strong> — @Model.NextLevelPoints pts to Level @(Model.CurrentLevel + 1)
        </div>
        <div style="background:rgba(255,255,255,.25); border-radius:99px; height:7px; width:240px; margin-top:8px; overflow:hidden">
            <div style="width:@Model.ProgressPercentage%; height:100%; background:#fff; border-radius:99px"></div>
        </div>
    </div>
    <div style="display:flex; gap:14px; flex-wrap:wrap; z-index: 1;">
        <div style="background:rgba(255,255,255,0.15); border:1px solid rgba(255,255,255,0.2); border-radius:14px; padding:14px 20px; text-align:center; min-width:100px;">
            <div style="font-size:24px; font-weight:900">@Model.QuestionsAsked</div>
            <div style="font-size:11px; opacity:.8; margin-top:2px">Questions</div>
        </div>
        <div style="background:rgba(255,255,255,0.15); border:1px solid rgba(255,255,255,0.2); border-radius:14px; padding:14px 20px; text-align:center; min-width:100px;">
            <div style="font-size:24px; font-weight:900">@Model.AnswersGiven</div>
            <div style="font-size:11px; opacity:.8; margin-top:2px">Answers</div>
        </div>
    </div>
</div>

<!-- TABS -->
<div class="tabs">
    <div class="tab active" onclick="showTab('tab-venues', this)"><i class="ph-fill ph-gift"></i> Redeem at Venues</div>
    <div class="tab" onclick="showTab('tab-earn', this)"><i class="ph-duotone ph-trend-up"></i> How to Earn</div>
    <div class="tab" onclick="showTab('tab-history', this)"><i class="ph-duotone ph-receipt"></i> Transactions</div>
    <div class="tab" onclick="showTab('tab-achievements', this)"><i class="ph-duotone ph-trophy"></i> Achievements</div>
</div>

<div id="tab-container">
    <!-- ── VENUES TAB ── -->
    <div id="tab-venues" class="tab-content fade-in">
        <div style="margin-bottom:20px;">
            <h2 style="font-size:18px; font-weight:800">Redeem at Campus Venues</h2>
            <p style="font-size:13px; color:var(--text-2); margin-top:4px">Choose a discount — a QR code will be sent to your university email instantly</p>
        </div>

        <div class="venues-grid">
            <!-- Cafeteria -->
            <div class="venue-card" onclick="openRedeemModal('University Cafeteria', 'coffee', '10% OFF discount on any meal', 200, 'Main Building, Ground Floor')">
                <div class="venue-img" style="background:var(--amber-light);display:flex;align-items:center;justify-content:center;position:relative;"><i class="ph-duotone ph-coffee" style="font-size:40px;color:var(--amber-dark);"></i><div class="venue-off">10% OFF</div></div>
                <div class="venue-body">
                    <div class="venue-name">University Cafeteria</div>
                    <div class="venue-desc">Valid for all drinks, snacks, and full meals. Single-use voucher.</div>
                    <div class="venue-footer">
                        <div class="venue-pts"><i class="ph-fill ph-coin" style="font-size:14px;color:var(--amber);vertical-align:middle;"></i> 200 pts</div>
                        <button class="btn btn-amber btn-sm">Redeem</button>
                    </div>
                </div>
            </div>

            <!-- Library -->
            <div class="venue-card" onclick="openRedeemModal('University Library', 'books', '5 JD Printing Credit', 400, 'Library Building, Level 2')">
                <div class="venue-img" style="background:var(--indigo-light);display:flex;align-items:center;justify-content:center;position:relative;"><i class="ph-duotone ph-books" style="font-size:40px;color:var(--indigo);"></i><div class="venue-off">5 JD OFF</div></div>
                <div class="venue-body">
                    <div class="venue-name">University Library</div>
                    <div class="venue-desc">Use for printing, scanning, or study room bookings. Valid for 30 days.</div>
                    <div class="venue-footer">
                        <div class="venue-pts"><i class="ph-fill ph-coin" style="font-size:14px;color:var(--amber);vertical-align:middle;"></i> 400 pts</div>
                        <button class="btn btn-primary btn-sm">Redeem</button>
                    </div>
                </div>
            </div>

            <!-- Bookshop -->
            <div class="venue-card" onclick="openRedeemModal('Campus Bookshop', 'book-open', '15% OFF Stationery', 350, 'Student Centre, Level 1')">
                <div class="venue-img" style="background:var(--emerald-light);display:flex;align-items:center;justify-content:center;position:relative;"><i class="ph-duotone ph-book-open" style="font-size:40px;color:var(--emerald);"></i><div class="venue-off">15% OFF</div></div>
                <div class="venue-body">
                    <div class="venue-name">Campus Bookshop</div>
                    <div class="venue-desc">15% discount on all stationery and university merchandise.</div>
                    <div class="venue-footer">
                        <div class="venue-pts"><i class="ph-fill ph-coin" style="font-size:14px;color:var(--amber);vertical-align:middle;"></i> 350 pts</div>
                        <button class="btn btn-emerald btn-sm">Redeem</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ── EARN TAB ── -->
    <div id="tab-earn" class="tab-content hidden fade-in">
        <div style="display:grid; grid-template-columns: 1fr 1fr; gap: 24px;">
            <div>
                <h3 style="font-size:16px; font-weight:800; margin-bottom:12px; display:flex; align-items:center; gap:8px;"><i class="ph-bold ph-trend-up" style="font-size:18px;color:var(--emerald);"></i> Ways to Earn Points</h3>
                <div class="card" style="padding:0; overflow:hidden;">
                    <div style="padding:14px; display:flex; justify-content:space-between; align-items:center; border-bottom:1px solid var(--border)">
                        <div><strong>Answer a Question</strong><br /><small style="color:var(--text-2)">Help a fellow student</small></div>
                        <span class="chip chip-emerald">+5 pts</span>
                    </div>
                    <div style="padding:14px; display:flex; justify-content:space-between; align-items:center; border-bottom:1px solid var(--border)">
                        <div><strong>Get an Upvote</strong><br /><small style="color:var(--text-2)">Per upvote on your answer</small></div>
                        <span class="chip chip-emerald">+10 pts</span>
                    </div>
                    <div style="padding:14px; display:flex; justify-content:space-between; align-items:center;">
                        <div><strong>Best Answer Selected</strong><br /><small style="color:var(--text-2)">Earn bonus for high quality</small></div>
                        <span class="chip chip-emerald">+15 pts</span>
                    </div>
                </div>
            </div>
            <div>
                <h3 style="font-size:16px; font-weight:800; margin-bottom:12px; display:flex; align-items:center; gap:8px;"><i class="ph-bold ph-trend-down" style="font-size:18px;color:var(--rose);"></i> Points Decisions</h3>
                <div class="card" style="padding:0; overflow:hidden;">
                    <div style="padding:14px; display:flex; justify-content:space-between; align-items:center; border-bottom:1px solid var(--border)">
                        <div><strong>Post a Question</strong><br /><small style="color:var(--text-2)">Encourages searching first</small></div>
                        <span class="chip chip-rose">−10 pts</span>
                    </div>
                    <div style="padding:14px; display:flex; justify-content:space-between; align-items:center;">
                        <div><strong>Request Tutoring Session</strong><br /><small style="color:var(--text-2)">Per private request</small></div>
                        <span class="chip chip-rose">−5 pts</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ── HISTORY TAB ── -->
    <div id="tab-history" class="tab-content hidden fade-in">
        <div class="card" style="padding:0; overflow:hidden;">
            @if (Model.Transactions == null || !Model.Transactions.Any())
            {
                <div style="padding:40px; text-align:center; color:var(--text-2)">No transaction history yet.</div>
            }
            else
            {
                @foreach (var tx in Model.Transactions)
                {
                    <div style="padding:16px 20px; display:flex; justify-content:space-between; align-items:center; border-bottom:1px solid var(--border)">
                        <div style="display:flex; align-items:center; gap:16px;">
                            @if (tx.Amount > 0)
                            {
                                <i class="ph-fill ph-arrow-fat-up" style="font-size:16px;color:var(--emerald);"></i>
                            }
                            else
                            {
                                <i class="ph-fill ph-arrow-fat-down" style="font-size:16px;color:var(--rose);"></i>
                            }
                            <div>
                                <div style="font-weight:700; font-size:14px;">@tx.Title</div>
                                <div style="font-size:12px; color:var(--text-2);">@tx.Time · @tx.Detail</div>
                            </div>
                        </div>
                        <span style="font-weight:800; color:@(tx.Amount >= 0 ? "var(--emerald)" : "var(--rose)")">
                            @(tx.Amount >= 0 ? "+" : "")@tx.Amount
                        </span>
                    </div>
                }
            }
        </div>
    </div>

    <!-- ── ACHIEVEMENTS TAB ── -->
    <div id="tab-achievements" class="tab-content hidden fade-in">
        <div style="display:grid; grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap: 16px;">
            @foreach (var achievement in Model.Achievements)
            {
                var achIcon = achievement.Title switch
                {
                    "First Steps" => "ph-fill ph-target",
                    "Helper" => "ph-fill ph-handshake",
                    "Questioner" => "ph-bold ph-question",
                    "Tutor" => "ph-fill ph-seal-check",
                    _ => "ph-fill ph-star"
                };
                <div class="card @(achievement.Unlocked ? "" : "locked")" style="text-align:center; @(achievement.Unlocked ? "background:var(--amber-light); border-color:var(--amber);" : "")">
                    <div style="font-size:32px; margin-bottom:10px; display:flex; justify-content:center;"><i class="@achIcon" style="font-size:40px;"></i></div>
                    <div style="font-weight:700; font-size:13px; margin-bottom:4px;">@achievement.Title</div>
                    <div style="font-size:11px; color:var(--text-2);">@achievement.Description</div>
                    @if (achievement.Unlocked)
                    {
                        <div style="font-size:10px; color:var(--amber-dark); margin-top:8px; font-weight:700; display:inline-flex; align-items:center; gap:3px;"><i class="ph-fill ph-check-circle" style="font-size:12px;"></i> UNLOCKED</div>
                    }
                </div>
            }
        </div>
    </div>
</div>

<!-- REDEEM MODAL -->
<div class="modal-overlay" id="redeemModal">
    <div class="modal-box">
        <div style="text-align:center; margin-bottom:24px;">
            <div id="modalIcon" style="font-size:64px; margin-bottom:12px; display:flex; align-items:center; justify-content:center;"><i id="modalIconEl" class="ph-duotone ph-coffee" style="font-size:64px;color:var(--amber-dark);"></i></div>
            <h3 id="modalTitle" style="font-size:20px; font-weight:900;">Venue Name</h3>
            <p id="modalDesc" style="font-size:14px; color:var(--text-2);">Discount description goes here.</p>
            <div id="modalLoc" style="font-size:12px; color:var(--text-3); margin-top:8px; display:flex; align-items:center; justify-content:center; gap:4px;"><i class="ph-fill ph-map-pin" style="font-size:13px;"></i><span id="modalLocText">Location Info</span></div>
        </div>
        <div style="background:var(--indigo-light); border:1.5px solid var(--border); border-radius:14px; padding:20px; text-align:center; margin-bottom:24px;">
            <div style="font-size:13px; color:var(--text-2); margin-bottom:4px;">This will cost</div>
            <div id="modalCost" style="font-size:32px; font-weight:900; color:var(--indigo);">200 pts</div>
            <div style="font-size:12px; color:var(--text-2); margin-top:6px;">Your current balance: <strong>@Model.CurrentPoints pts</strong></div>
        </div>
        <div style="display:flex; gap:12px;">
            <button class="btn btn-ghost btn-full" onclick="closeRedeemModal()">Cancel</button>
            <button class="btn btn-primary btn-full" onclick="confirmRedeem()">Confirm Redeem</button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function showTab(id, el) {
            // Update tabs
            document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
            el.classList.add('active');

            // Update content
            document.querySelectorAll('.tab-content').forEach(c => c.classList.add('hidden'));
            document.getElementById(id).classList.remove('hidden');
        }

        const _iconMap = { coffee: 'ph-coffee', books: 'ph-books', 'book-open': 'ph-book-open' };
        function openRedeemModal(name, icon, desc, cost, loc) {
            document.getElementById('modalTitle').textContent = name;
            const el = document.getElementById('modalIconEl');
            el.className = 'ph-duotone ' + (_iconMap[icon] || 'ph-gift');
            document.getElementById('modalDesc').textContent = desc;
            document.getElementById('modalCost').textContent = cost + " pts";
            document.getElementById('modalLocText').textContent = loc;

            const modal = document.getElementById('redeemModal');
            modal.classList.add('open');
            document.body.style.overflow = 'hidden';
        }

        function closeRedeemModal() {
            const modal = document.getElementById('redeemModal');
            modal.classList.remove('open');
            document.body.style.overflow = '';
        }

        function confirmRedeem() {
            const venueName = document.getElementById('modalTitle')?.textContent || 'this venue';
            const cost = document.getElementById('modalCost')?.textContent || '?';
            closeRedeemModal();
            showToast('Redemption coming soon! ' + venueName + ' (' + cost + ') will launch after deployment.', 'warn');
        }

        // Close modal on escape
        document.addEventListener('keydown', e => {
            if (e.key === 'Escape') closeRedeemModal();
        });
    </script>
}

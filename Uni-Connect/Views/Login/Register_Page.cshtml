@model Uni_Connect.ViewModels.RegisterViewModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1.0" />
    <title>Register — UniConnect</title>
    <link rel="icon" type="image/svg+xml" href="~/images/logo/icon.svg" />
    <link href="~/css/login.css" rel="stylesheet" />
    <script src="https://unpkg.com/@@phosphor-icons/web@@2.1.1"></script>
</head>
<body class="auth-bg">
    <nav class="auth-navbar">
        <a asp-controller="Home" asp-action="Index" class="nav-logo">
            <div class="nav-logo-icon" style="padding:0;overflow:visible;background:none;border:none;">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" width="32" height="32" role="img" aria-label="UniConnect">
                    <rect width="64" height="64" rx="17" fill="#ffffff"/>
                    <path d="M32 13 C 27 13, 14 16, 11 21 L 11 50 C 14 46, 27 43, 32 43 L 32 13 Z" fill="#3D52A0"/>
                    <path d="M32 13 C 37 13, 50 16, 53 21 L 53 50 C 50 46, 37 43, 32 43 L 32 13 Z" fill="#7091E6"/>
                    <rect x="30.5" y="12" width="3" height="32" rx="1.5" fill="#1E2A5E" opacity="0.22"/>
                    <path d="M 11 50 Q 32 55 53 50" stroke="#3D52A0" stroke-width="1.5" fill="none" stroke-opacity="0.1" stroke-linecap="round"/>
                    <circle cx="19" cy="58" r="5" fill="#F59E0B"/>
                    <circle cx="45" cy="58" r="5" fill="#7091E6"/>
                    <line x1="19" y1="53" x2="31" y2="43.5" stroke="#F59E0B" stroke-width="2" stroke-linecap="round" stroke-opacity="0.9"/>
                    <line x1="45" y1="53" x2="33" y2="43.5" stroke="#7091E6" stroke-width="2" stroke-linecap="round" stroke-opacity="0.9"/>
                </svg>
            </div>
            <span>UniConnect</span>
        </a>
        <div style="display:flex;align-items:center;gap:12px">
            <span style="font-size:14px;color:var(--text-2)">Already have an account?</span>
            <a asp-controller="Login" asp-action="Login_Page"><button class="btn btn-ghost btn-sm">Sign In</button></a>
        </div>
    </nav>
    <div class="auth-body">
        <div style="width:100%;max-width:460px">
            <div style="text-align:center;margin-bottom:24px">
                <div class="auth-logo-icon"><i class="ph-duotone ph-graduation-cap" style="font-size:40px;color:var(--indigo);"></i></div>
                <h1 class="auth-title">Create your account</h1>
                <p class="auth-subtitle">Only enrolled Philadelphia University students</p>
            </div>

            <form asp-action="Register_Page" method="post">
                @Html.AntiForgeryToken()
                <div class="auth-card" id="reg-form">

                    <div asp-validation-summary="ModelOnly" class="validation-error-box"></div>

                    <div class="form-group">
                        <label class="form-label" asp-for="Name">Full Name</label>
                        <input class="form-input" asp-for="Name" type="text" />
                        <span asp-validation-for="Name" class="field-validation-error"></span>
                    </div>

                    <div class="form-group">
                        <label class="form-label" asp-for="Email">University Email</label>
                        <input class="form-input" asp-for="Email" type="email" placeholder="StudentID@philadelphia.edu.jo" />
                        <div class="form-hint">Format: StudentID@philadelphia.edu.jo</div>
                        <span asp-validation-for="Email" class="field-validation-error"></span>
                    </div>

                    <div class="form-group">
                        <label class="form-label" asp-for="Faculty">Faculty</label>
                        <select class="form-input form-select" asp-for="Faculty">
                            <option value="">Select faculty...</option>
                            <option value="IT Faculty">Faculty of Information Technology</option>
                            <option value="Engineering">Faculty of Engineering</option>
                            <option value="Business">Faculty of Business</option>
                            <option value="Science">Faculty of Science</option>
                            <option value="Pharmacy">Faculty of Pharmacy</option>
                            <option value="Law">Faculty of Law</option>
                            <option value="Arts">Faculty of Arts</option>
                        </select>
                        <span asp-validation-for="Faculty" class="field-validation-error"></span>
                    </div>

                    <div class="form-group">
                        <label class="form-label" asp-for="YearOfStudy">Year of Study</label>
                        <select class="form-input form-select" asp-for="YearOfStudy">
                            <option value="">Select year...</option>
                            <option value="1st Year">1st Year</option>
                            <option value="2nd Year">2nd Year</option>
                            <option value="3rd Year">3rd Year</option>
                            <option value="4th Year">4th Year</option>
                            <option value="Graduate">Graduate</option>
                        </select>
                        <span asp-validation-for="YearOfStudy" class="field-validation-error"></span>
                    </div>

                    <div class="form-group">
                        <label class="form-label" asp-for="Password">Password</label>
                        <input class="form-input" asp-for="Password" type="password" placeholder="Minimum 8 characters" />
                        <div class="form-hint">Must include uppercase, lowercase, number, and special character (e.g. Test@1234)</div>
                        <span asp-validation-for="Password" class="field-validation-error"></span>
                    </div>

                    <div class="form-group" style="margin-bottom:22px">
                        <label class="form-label" asp-for="ConfirmPassword">Confirm Password</label>
                        <input class="form-input" asp-for="ConfirmPassword" type="password" placeholder="Repeat password" />
                        <span asp-validation-for="ConfirmPassword" class="field-validation-error"></span>
                    </div>

                    <button type="submit" class="btn btn-primary btn-full btn-lg">Create Account →</button>
                </div>
            </form>

            <div class="auth-notice"><span style="flex-shrink:0;display:flex;"><i class="ph-fill ph-lock" style="font-size:18px;"></i></span><p>UniConnect is exclusively for enrolled Philadelphia University students. Only @@philadelphia.edu.jo emails are accepted.</p></div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    <script src="https://unpkg.com/@@phosphor-icons/web@@2.1.1"></script>

</body>
</html>

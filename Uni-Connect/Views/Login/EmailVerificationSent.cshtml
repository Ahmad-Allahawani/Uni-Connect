@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1.0" />
    <title>Verify Your Email — UniConnect</title>
    <link rel="icon" type="image/svg+xml" href="~/images/logo/icon.svg" />
    <link href="~/css/login.css" rel="stylesheet" />
    <script src="https://unpkg.com/@@phosphor-icons/web@@2.1.1"></script>
</head>
<body class="auth-bg">
    <nav class="auth-navbar">
        <a asp-controller="Home" asp-action="Index" class="nav-logo">
            <div class="nav-logo-icon" style="padding:0;overflow:visible;background:none;border:none;">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" width="32" height="32" role="img" aria-label="UniConnect">
                    <rect width="64" height="64" rx="17" fill="#ffffff" />
                    <path d="M32 13 C 27 13, 14 16, 11 21 L 11 50 C 14 46, 27 43, 32 43 L 32 13 Z" fill="#3D52A0" />
                    <path d="M32 13 C 37 13, 50 16, 53 21 L 53 50 C 50 46, 37 43, 32 43 L 32 13 Z" fill="#7091E6" />
                    <rect x="30.5" y="12" width="3" height="32" rx="1.5" fill="#1E2A5E" opacity="0.22" />
                    <circle cx="19" cy="58" r="5" fill="#F59E0B" />
                    <circle cx="45" cy="58" r="5" fill="#7091E6" />
                    <line x1="19" y1="53" x2="31" y2="43.5" stroke="#F59E0B" stroke-width="2" stroke-linecap="round" stroke-opacity="0.9" />
                    <line x1="45" y1="53" x2="33" y2="43.5" stroke="#7091E6" stroke-width="2" stroke-linecap="round" stroke-opacity="0.9" />
                </svg>
            </div>
            <span>UniConnect</span>
        </a>
    </nav>

    <div class="auth-body">
        <div style="width:100%;max-width:460px">
            <div class="auth-card" style="text-align:center;padding:40px 32px;">

                <!-- Envelope icon -->
                <div class="auth-logo-icon" style="margin:0 auto 20px;">
                    <i class="ph-duotone ph-envelope-open" style="font-size:40px;color:var(--indigo);"></i>
                </div>

                <h1 class="auth-title" style="margin-bottom:8px;">Check your email</h1>
                <p class="auth-subtitle" style="margin-bottom:24px;">
                    We sent a verification link to
                </p>

                <!-- Email pill -->
                <div style="display:inline-block;background:var(--surface-2,#f0f2ff);border:1px solid var(--indigo-light,#c7d0f8);border-radius:8px;padding:10px 20px;font-weight:600;color:var(--indigo);font-size:15px;margin-bottom:28px;word-break:break-all;">
                    @ViewBag.Email
                </div>

                <p style="font-size:14px;color:var(--text-2);line-height:1.6;margin-bottom:28px;">
                    Click the link in that email to activate your account before signing in.
                    If you don't see it, check your spam or junk folder.
                </p>

                <a asp-controller="Login" asp-action="Login_Page">
                    <button class="btn btn-primary btn-full btn-lg">Go to Sign In →</button>
                </a>

                <p style="margin-top:20px;font-size:13px;color:var(--text-3);">
                    Wrong email?
                    <a asp-controller="Login" asp-action="Register_Page" style="color:var(--indigo);text-decoration:underline;">Register again</a>
                </p>
            </div>
        </div>
    </div>

    <script src="https://unpkg.com/@@phosphor-icons/web@@2.1.1"></script>
</body>
</html>
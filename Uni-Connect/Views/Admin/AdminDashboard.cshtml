@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

@section Styles {
<link href="~/css/admin.css" rel="stylesheet" />
}

<div class="dashboard-header">
    <div>
        <h1 class="h2">Administrator Dashboard</h1>
        <p class="text-2">Platform overview and moderation control.</p>
    </div>
</div>


<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-icon" style="background:var(--indigo-light); color:var(--indigo);"><i class="ph-duotone ph-users" style="font-size:22px;"></i></div>
        <div class="stat-value">@ViewBag.UserCount</div>
        <div class="stat-label">Total Users</div>
    </div>
    <div class="stat-card">
        <div class="stat-icon" style="background:var(--emerald-light); color:var(--emerald);"><i class="ph-duotone ph-file-text" style="font-size:22px;"></i></div>
        <div class="stat-value">@ViewBag.PostCount</div>
        <div class="stat-label">Total Posts</div>
    </div>
    <div class="stat-card">
        <div class="stat-icon" style="background:var(--rose-light); color:var(--rose);"><i class="ph-fill ph-warning" style="font-size:22px;"></i></div>
        <div class="stat-value">@ViewBag.ReportCount</div>
        <div class="stat-label">Unresolved Reports</div>
    </div>
    <div class="stat-card">
        <div class="stat-icon" style="background:var(--rose-light); color:var(--rose);"><i class="ph-fill ph-warning" style="font-size:22px;"></i></div>
        <div class="stat-value">@ViewBag.BestAnswerRequestCount</div>
        <div class="stat-label">Unresolved Requests</div>
    </div>
</div>

<div class="card" style="margin-top: 24px;">
    <div class="card-header">
        <h3 class="h4">Moderation Quick Links</h3>
    </div>
    <div class="card-body">
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 16px;">
            <a asp-action="ManageUsers" class="btn btn-primary" style="text-align: center; display: block; text-decoration: none;">
                <i class="ph-bold ph-user-gear" style="font-size:16px;margin-right:8px; vertical-align:middle;"></i> Manage Users
            </a>
            <a asp-action="ManageReports" class="btn btn-primary" style="text-align: center; display: block; text-decoration: none;">
                <i class="ph-fill ph-flag" style="font-size:16px;margin-right:8px; vertical-align:middle;"></i> Review Reports
            </a>
            <a 
               asp-action="ManageContent"
               class="btn btn-primary" style="text-align: center; display: block; text-decoration: none;">
                <i class="ph-fill ph-note-pencil"></i>Manage Posts & Answers
            </a>
            <a asp-action="DeletedPosts" class="btn btn-primary" style="text-align: center; display: block; text-decoration: none;">
                <i class="ph-fill ph-archive-box"></i> View Deleted Posts
            </a>
            <a asp-action="BestAnswerRequests" class="btn btn-primary" style="text-align: center; display: block; text-decoration: none;">
                <i class="ph-fill ph-star"></i> Review Best Answer Requests
            </a>
        </div>
    </div>
</div>

@model IEnumerable<Uni_Connect.Models.User>
@{
    ViewData["Title"] = "Manage Users";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

@section Styles {
<link href="~/css/admin.css" rel="stylesheet" />
}

<div class="dashboard-header">
    <div>
        <h1 class="h2">Manage Users</h1>
        <p class="text-2">Total registered students and staff.</p>
    </div>
    <a asp-action="AdminDashboard" class="btn btn-secondary"><i class="ph ph-arrow-left" style="font-size:16px;"></i> Back to Dashboard</a>
</div>

<div class="card">
    <div style="padding:0 0 16px 0;">
        <input id="userSearch" type="text" placeholder="Search by name, email, or university ID…"
               oninput="filterUsers(this.value)" class="form-input"
               style="max-width:360px;" autocomplete="off" />
    </div>
    <div class="table-container">
        <table class="data-table">
            <thead>
                <tr>
                    <th>University ID</th>
                    <th>User</th>
                    <th>Email</th>
                    <th>Role</th>
                    <th>Faculty</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td class="text-mono">@user.UniversityID</td>
                        <td>
                            <div style="display:flex; align-items:center; gap:12px;">
                                @if (!string.IsNullOrEmpty(user.ProfileImageUrl))
                                {
                                    <div class="av av-sm"><img src="@user.ProfileImageUrl" alt="User" /></div>
                                }
                                else
                                {
                                    <div class="av av-sm"><img src="@AvatarHelper.Url(user.Name, 40)" alt="User" /></div>
                                }
                                <div>
                                    <div style="font-weight:600;">@user.Name</div>
                                    <div class="text-3">@@@user.Username</div>
                                </div>
                            </div>
                        </td>
                        <td>@user.Email</td>
                        <td><span class="badge badge-primary">@user.Role</span></td>
                        <td class="text-2">@user.Faculty</td>
                        <td>
                            @if (user.IsDeleted)
                            {
                                <span class="badge" style="background:var(--rose-light); color:var(--rose);">Deleted</span>
                            }
                            else
                            {
                                <span class="badge" style="background:var(--emerald-light); color:var(--emerald);">Active</span>
                            }
                        </td>
                        <td>
                            <form asp-action="ToggleUserDelete" method="post" style="display:inline;">
                                <input type="hidden" name="id" value="@user.UserID" />
                                <button type="submit" class="btn btn-sm @(user.IsDeleted ? "btn-secondary" : "btn-danger")" onclick="return confirm('Are you sure you want to @(user.IsDeleted ? "restore" : "delete") this user?')">
                                    <i class="ph @(user.IsDeleted ? "ph-arrow-clockwise" : "ph-user-minus")" style="font-size:14px;"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<script>
    function filterUsers(q) {
        q = q.toLowerCase();
        document.querySelectorAll('.data-table tbody tr').forEach(function(row) {
            row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
        });
    }
</script>


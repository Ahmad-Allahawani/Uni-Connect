@model List<Uni_Connect.Models.BestAnswerRequest>

@{
    ViewData["Title"] = "Best Answer Requests";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

@section Styles {
    <link href="~/css/admin.css" rel="stylesheet" />
}

<div class="dashboard-header">
    <div>
        <h1 class="h2">Best Answer Requests</h1>
        <p class="text-2">Review answers marked as best by post owners before points are awarded.</p>
    </div>

    <a asp-action="AdminDashboard" class="btn btn-secondary">
        <i class="ph ph-arrow-left" style="font-size:16px;"></i>
        Back to Dashboard
    </a>
</div>

<div class="card">
    <div class="table-container">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Requested At</th>
                    <th>Post Owner</th>
                    <th>Requested By</th>
                    <th>Answer Owner</th>
                    <th>Post</th>
                    <th>Answer</th>
                    <th>Actions</th>
                </tr>
            </thead>

            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="7" style="text-align:center; padding:40px; color:var(--text-3);">
                            <div style="display:flex;flex-direction:column;align-items:center;justify-content:center;">
                                <i class="ph-duotone ph-seal-check" style="font-size:48px; margin-bottom:16px; opacity:.5;"></i>
                                <div style="font-weight:700;color:var(--text);">No pending Best Answer requests</div>
                                <div class="text-2" style="margin-top:6px;">
                                    When a post owner marks an answer as best, it will appear here.
                                </div>
                            </div>
                        </td>
                    </tr>
                }

                @foreach (var request in Model)
                {
                    var postOwner = request.Post?.User;
                    var requester = request.RequestedByUser;
                    var answerOwner = request.Answer?.User;

                    var answerText = request.Answer?.Content ?? "";
                    var answerPreview = answerText.Length > 120
                    ? answerText.Substring(0, 120) + "..."
                    : answerText;

                    <tr>
                        <td class="text-2">
                            @request.CreatedAt.ToString("MMM dd, HH:mm")
                        </td>

                        <td>
                            <div style="display:flex;align-items:center;gap:8px;">
                                @if (!string.IsNullOrEmpty(postOwner?.ProfileImageUrl))
                                {
                                    <img src="@postOwner.ProfileImageUrl"
                                         style="width:24px;height:24px;border-radius:50%;object-fit:cover;" />
                                }
                                else
                                {
                                    <img src="@AvatarHelper.Url(postOwner?.Name, 24)"
                                         style="width:24px;height:24px;border-radius:50%;" />
                                }

                                <div>
                                    <div style="font-weight:600;">@(postOwner?.Name ?? "Unknown")</div>
                                    <div class="text-3">@@@(postOwner?.Username ?? "unknown")</div>
                                </div>
                            </div>
                        </td>

                        <td>
                            <div style="display:flex;align-items:center;gap:8px;">
                                @if (!string.IsNullOrEmpty(requester?.ProfileImageUrl))
                                {
                                    <img src="@requester.ProfileImageUrl"
                                         style="width:24px;height:24px;border-radius:50%;object-fit:cover;" />
                                }
                                else
                                {
                                    <img src="@AvatarHelper.Url(requester?.Name, 24)"
                                         style="width:24px;height:24px;border-radius:50%;" />
                                }

                                <div>
                                    <div style="font-weight:600;">@(requester?.Name ?? "Unknown")</div>
                                    <div class="text-3">@@@(requester?.Username ?? "unknown")</div>
                                </div>
                            </div>
                        </td>

                        <td>
                            <div style="display:flex;align-items:center;gap:8px;">
                                @if (!string.IsNullOrEmpty(answerOwner?.ProfileImageUrl))
                                {
                                    <img src="@answerOwner.ProfileImageUrl"
                                         style="width:24px;height:24px;border-radius:50%;object-fit:cover;" />
                                }
                                else
                                {
                                    <img src="@AvatarHelper.Url(answerOwner?.Name, 24)"
                                         style="width:24px;height:24px;border-radius:50%;" />
                                }

                                <div>
                                    <div style="font-weight:600;">@(answerOwner?.Name ?? "Unknown")</div>
                                    <div class="text-3">@@@(answerOwner?.Username ?? "unknown")</div>
                                </div>
                            </div>
                        </td>

                        <td>
                            <strong>@(request.Post?.Title ?? "Deleted post")</strong>
                        </td>

                        <td style="max-width:360px;">
                            @answerPreview
                        </td>

                        <td>
                            <div style="display:flex;gap:8px;align-items:center;">
                                <a href="@Url.Action("SinglePost", "Dashboard", new { id = request.PostID })"
                                   target="_blank"
                                   class="btn btn-sm btn-secondary"
                                   title="View Post">
                                    <i class="ph ph-eye" style="font-size:14px;"></i>
                                </a>

                                <form asp-action="ApproveBestAnswerRequest" method="post" style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@request.BestAnswerRequestID" />
                                    <button type="submit" class="btn btn-sm btn-primary" title="Approve">
                                        <i class="ph-bold ph-check" style="font-size:14px;"></i>
                                    </button>
                                </form>

                                <form asp-action="RejectBestAnswerRequest" method="post" style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@request.BestAnswerRequestID" />
                                    <button type="submit" class="btn btn-sm btn-secondary" title="Reject">
                                        <i class="ph-bold ph-x" style="font-size:14px;"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>